---
import type { FilesystemWork } from '../../lib/loaders/loadWork';
import type { WorkFull } from '../../lib/db/types';

interface Props {
  work: WorkFull | FilesystemWork;
}

const { work } = Astro.props;

const tmdbId = ('tmdb_id' in work && work.tmdb_id) ? work.tmdb_id : null;
const TMDB_API_KEY = import.meta.env.TMDB_API_KEY;
const TMDB_W1280 = 'https://image.tmdb.org/t/p/w1280';
const TMDB_W780  = 'https://image.tmdb.org/t/p/w780';

type BackdropEntry = { full: string; thumb: string };
let backdrops: BackdropEntry[] = [];

if (tmdbId && TMDB_API_KEY) {
  try {
    const res = await fetch(
      `https://api.themoviedb.org/3/movie/${tmdbId}/images?api_key=${TMDB_API_KEY}&include_image_language=null,en`
    );
    if (res.ok) {
      const json = await res.json() as { backdrops?: Array<{ file_path: string; vote_average: number }> };
      backdrops = (json.backdrops ?? [])
        .sort((a, b) => b.vote_average - a.vote_average)
        .slice(0, 9)
        .map(b => ({
          full:  `${TMDB_W1280}${b.file_path}`,
          thumb: `${TMDB_W780}${b.file_path}`,
        }));
    }
  } catch {
    // silently skip on network failure
  }
}
---

{backdrops.length > 0 && (
  <section class="film-backdrops">
    <div class="site-container">
      <p class="film-backdrops__label">Fotografías</p>
      <div class="film-backdrops__grid">
        {backdrops.map((b) => (
          <a
            href={b.full}
            target="_blank"
            rel="noopener noreferrer"
            class="film-backdrops__item"
          >
            <img src={b.thumb} alt="" loading="lazy" decoding="async" />
          </a>
        ))}
      </div>
    </div>
  </section>
)}

<style>
.film-backdrops {
  padding: 3rem 0 0;
}

.film-backdrops__label {
  font-family: var(--font-sans);
  font-size: 0.68rem;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin: 0 0 1rem;
}

.film-backdrops__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8px;
}

.film-backdrops__item {
  display: block;
  border-radius: 4px;
  overflow: hidden;
  aspect-ratio: 16 / 9;
  background: var(--surface-card);
}

.film-backdrops__item img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: filter 180ms ease;
}

.film-backdrops__item:hover img {
  filter: brightness(1.1);
}

@media (max-width: 600px) {
  .film-backdrops__grid {
    grid-template-columns: repeat(2, 1fr);
  }
}
</style>
