---
import { getPaletteEntry, isLightColor } from '../../lib/color/colorPalette';
import type { FilesystemWork } from '../../lib/loaders/loadWork';
import type { WorkFull } from '../../lib/db/types';

interface Props {
  work: WorkFull | FilesystemWork;
}

const { work } = Astro.props;

// ── TMDB backdrops ────────────────────────────────────────────────────────────
const tmdbId = ('tmdb_id' in work && work.tmdb_id) ? work.tmdb_id : null;
const TMDB_API_KEY = import.meta.env.TMDB_API_KEY;
const TMDB_BACKDROP = 'https://image.tmdb.org/t/p/w1280';
const TMDB_THUMB    = 'https://image.tmdb.org/t/p/w780';

type BackdropEntry = { src: string; thumb: string; alt: string };
let backdrops: BackdropEntry[] = [];

if (tmdbId && TMDB_API_KEY) {
  try {
    const res = await fetch(
      `https://api.themoviedb.org/3/movie/${tmdbId}/images?api_key=${TMDB_API_KEY}&include_image_language=null,en`
    );
    if (res.ok) {
      const json = await res.json() as { backdrops?: Array<{ file_path: string; vote_average: number }> };
      backdrops = (json.backdrops ?? [])
        .sort((a, b) => b.vote_average - a.vote_average)
        .slice(0, 6)
        .map(b => ({
          src:   `${TMDB_BACKDROP}${b.file_path}`,
          thumb: `${TMDB_THUMB}${b.file_path}`,
          alt:   work.title,
        }));
    }
  } catch {
    // silently skip on network failure
  }
}

// Resolve color ID from either data shape
const colorId: string =
  ('color_assignments' in work && work.color_assignments?.color_iconico)
    ? work.color_assignments.color_iconico
    : ('prisma_palette' in work && (work as FilesystemWork).prisma_palette?.primary)
      ? (work as FilesystemWork).prisma_palette!.primary
      : 'azul_nocturno';

const palette = getPaletteEntry(colorId);
const hex = palette?.hex ?? '#1B2A41';
const colorName = palette?.name ?? '';
const lightText = isLightColor(colorId);

// Resolve director name + slug for link
let directorName: string | null = null;
let directorSlug: string | null = null;
if ('work_people' in work && Array.isArray(work.work_people)) {
  const dir = (work as WorkFull).work_people.find((wp) => wp.role === 'director');
  directorName = dir?.people?.name ?? null;
  directorSlug = dir?.people?.id?.replace(/^person_/, '') ?? null;
} else if ('people' in work) {
  const fsWork = work as FilesystemWork;
  const dirs = fsWork.people?.director;
  if (dirs && dirs.length > 0) {
    directorSlug = dirs[0].replace(/^person_/, '');
    directorName = directorSlug
      .split('-')
      .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
      .join(' ');
  }
}

const heroTextColor = lightText ? '#0A0A0F' : '#F0EEE8';
const heroSubColor = lightText ? 'rgba(10,10,15,0.6)' : 'rgba(240,238,232,0.5)';

// Compute decade for badge link
const decade = work.year ? `${Math.floor(work.year / 10) * 10}s` : null;

// Resolve poster path (TMDB or filesystem)
const TMDB_BASE = 'https://image.tmdb.org/t/p/w500';
let posterUrl: string | null = null;
if ('tmdb_poster_path' in work && work.tmdb_poster_path) {
  posterUrl = `${TMDB_BASE}${work.tmdb_poster_path}`;
} else if ('media' in work && (work as FilesystemWork).media?.poster_path) {
  posterUrl = `${TMDB_BASE}${(work as FilesystemWork).media!.poster_path}`;
}
---

<section
  class="film-hero"
  style={`--hero-color: ${hex}; --hero-text: ${heroTextColor}; --hero-sub: ${heroSubColor};`}
>
  <div class="film-hero__wash" />

  {/* Backdrop mosaic — blurred decorative layer, no lightbox trigger */}
  {backdrops.length > 0 && (
    <div class="film-hero__backdrop-mosaic" aria-hidden="true">
      {backdrops.slice(0, 4).map((b) => (
        <img src={b.thumb} alt="" loading="eager" decoding="async" />
      ))}
    </div>
  )}

  <div class="film-hero__inner site-container">
    {posterUrl && (
      <div class="film-hero__poster">
        <img src={posterUrl} alt={`${work.title} poster`} loading="eager" />
      </div>
    )}

    <div class="film-hero__content">
      {colorName && (
        <div class="film-hero__color-chip">
          <span class="film-hero__color-dot" style={`background:${hex}`} />
          <a href={`/colors/${colorId}`} class="film-hero__color-label">{colorName}</a>
        </div>
      )}

      <h1 class="film-hero__title">{work.title}</h1>

      <div class="film-hero__meta">
        {directorName && (
          directorSlug
            ? <a href={`/people/${directorSlug}`} class="film-hero__director film-hero__director--link">{directorName}</a>
            : <span class="film-hero__director">{directorName}</span>
        )}
        {directorName && work.year && <span class="film-hero__sep">·</span>}
        {work.year && <span class="film-hero__year">{work.year}</span>}
        {'duration_min' in work && work.duration_min && (
          <>
            <span class="film-hero__sep">·</span>
            <span class="film-hero__runtime">{work.duration_min} min</span>
          </>
        )}
        {decade && (
          <a href={`/decades/${decade}`} class="film-hero__decade-badge">{decade}</a>
        )}
      </div>
    </div>
  </div>

</section>

<style>
.film-hero {
  position: relative;
  min-height: min(100vh, 680px);
  display: flex;
  align-items: flex-end;
  overflow: hidden;
  padding-bottom: 5rem;
}

/* Backdrop mosaic — blurred decorative background layer */
.film-hero__backdrop-mosaic {
  position: absolute;
  inset: 0;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  opacity: 0.15;
  filter: blur(2px);
  z-index: 0;
  overflow: hidden;
  pointer-events: none;
}
.film-hero__backdrop-mosaic img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.film-hero__wash {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    155deg,
    var(--hero-color) 0%,
    color-mix(in srgb, var(--hero-color) 55%, #0D0D0F) 42%,
    #0D0D0F 100%
  );
}

.film-hero__inner {
  position: relative;
  z-index: 1;
  padding-top: 10rem;
  display: flex;
  gap: 3rem;
  align-items: flex-end;
}

.film-hero__poster {
  flex-shrink: 0;
  width: clamp(180px, 22vw, 300px);
  border-radius: 8px;
  overflow: hidden;
  box-shadow: 0 12px 40px rgba(0, 0, 0, 0.5);
  animation: posterIn 0.65s cubic-bezier(0.25, 0.46, 0.45, 0.94) both 0.1s;
}

.film-hero__poster img {
  width: 100%;
  height: auto;
  display: block;
}

.film-hero__content {
  flex: 1;
  min-width: 0;
}

.film-hero__color-chip {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  margin-bottom: 1.5rem;
}

.film-hero__color-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  flex-shrink: 0;
}

.film-hero__color-label {
  font-size: 0.68rem;
  font-family: var(--font-sans);
  font-weight: 500;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--hero-sub);
  transition: color 160ms ease;
}
.film-hero__color-label:hover { color: var(--hero-text); }

.film-hero__title {
  font-family: var(--font-serif);
  font-size: clamp(2.5rem, 6.5vw, 5.25rem);
  font-weight: 400;
  line-height: 1.06;
  color: var(--hero-text);
  max-width: 18ch;
  margin-bottom: 1.25rem;
  animation: heroTitleIn 0.55s cubic-bezier(0.25, 0.46, 0.45, 0.94) both;
}

.film-hero__meta {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  flex-wrap: wrap;
}

.film-hero__director,
.film-hero__year,
.film-hero__runtime {
  font-size: 0.85rem;
  color: var(--hero-sub);
}

a.film-hero__director--link {
  transition: color 160ms ease;
}
a.film-hero__director--link:hover { color: var(--hero-text); }

.film-hero__sep { color: var(--hero-sub); opacity: 0.35; }

.film-hero__decade-badge {
  display: inline-flex;
  align-items: center;
  font-size: 0.7rem;
  font-family: var(--font-sans);
  font-weight: 600;
  letter-spacing: 0.06em;
  color: var(--hero-sub);
  background: color-mix(in srgb, var(--hero-text) 8%, transparent);
  border: 1px solid color-mix(in srgb, var(--hero-text) 12%, transparent);
  border-radius: 100px;
  padding: 0.2em 0.7em;
  margin-left: 0.25rem;
  text-decoration: none;
  transition: background 160ms ease, color 160ms ease, border-color 160ms ease;
}
.film-hero__decade-badge:hover {
  color: var(--hero-text);
  background: color-mix(in srgb, var(--hero-text) 14%, transparent);
  border-color: color-mix(in srgb, var(--hero-text) 22%, transparent);
}

@keyframes heroTitleIn {
  from { opacity: 0; transform: translateY(18px); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes posterIn {
  from { opacity: 0; transform: translateY(24px) scale(0.94); }
  to   { opacity: 1; transform: translateY(0) scale(1); }
}

@media (max-width: 768px) {
  .film-hero__inner {
    flex-direction: column;
    align-items: flex-start;
    gap: 2rem;
  }

  .film-hero__poster {
    width: clamp(160px, 45vw, 240px);
  }
}

@media (max-width: 640px) {
  /* Hide backdrop mosaic on mobile — saves bandwidth */
  .film-hero__backdrop-mosaic { display: none; }
  /* Hide backdrop gallery strip too */
  .film-gallery { display: none; }

  .film-hero {
    min-height: auto;
    padding-bottom: 2.5rem;
    align-items: flex-start;
  }

  .film-hero__inner {
    padding-top: 5rem;
    gap: 1.25rem;
  }

  /* Poster full-width on mobile */
  .film-hero__poster {
    width: 100%;
    max-width: none;
    border-radius: 6px;
  }

  .film-hero__title {
    font-size: clamp(1.75rem, 7vw, 2.75rem);
  }
}

/* ── Backdrop gallery strip ────────────────────────────────────────────────── */
.film-gallery {
  padding: 1.5rem 0 0;
}

.film-gallery__strip {
  display: flex;
  gap: 0.75rem;
  overflow-x: auto;
  scrollbar-width: none;
  padding-bottom: 0.25rem;
}
.film-gallery__strip::-webkit-scrollbar { display: none; }

.film-gallery__thumb {
  flex-shrink: 0;
  height: 200px;
  aspect-ratio: 16 / 9;
  border-radius: 4px;
  overflow: hidden;
  background: var(--surface-card);
  border: none;
  padding: 0;
  cursor: pointer;
  transition: transform 200ms ease, box-shadow 200ms ease;
}
.film-gallery__thumb:hover {
  transform: scale(1.02);
  box-shadow: 0 6px 20px rgba(0,0,0,0.5);
}

.film-gallery__thumb img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

@media (max-width: 640px) {
  .film-gallery__thumb { height: 140px; }
}
</style>
