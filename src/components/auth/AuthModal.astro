---
// src/components/auth/AuthModal.astro
// ─────────────────────────────────────
// Auth modal — shown when unauthenticated users interact with
// rate / seen / watchlist actions. Supports Google OAuth + magic link.
---

<div id="auth-modal" class="auth-modal" hidden aria-modal="true" role="dialog" aria-labelledby="auth-modal-heading">
  <div class="auth-modal__overlay"></div>
  <div class="auth-modal__card">

    <button class="auth-modal__close" aria-label="Close" id="auth-modal-close">✕</button>

    <div class="auth-modal__logo" aria-hidden="true">PRISMA</div>

    <h2 class="auth-modal__heading" id="auth-modal-heading">Únete a PRISMA</h2>
    <p class="auth-modal__sub">Rastrea películas, califica, y descubre tu identidad cinematográfica.</p>

    <div class="auth-modal__actions">
      <!-- Google OAuth -->
      <button class="auth-btn auth-btn--google" id="btn-google-signin" type="button">
        <svg class="auth-btn__icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
          <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
          <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
          <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
        </svg>
        Continuar con Google
      </button>

      <div class="auth-modal__separator">
        <span>o</span>
      </div>

      <!-- Magic link / email -->
      <div class="auth-email-form" id="auth-email-form" hidden>
        <input
          type="email"
          id="auth-email-input"
          class="auth-email-input"
          placeholder="your@email.com"
          autocomplete="email"
        />
        <button class="auth-btn auth-btn--email-submit" id="btn-email-submit" type="button">
          Enviar enlace mágico
        </button>
        <p class="auth-email-hint" id="auth-email-hint" hidden></p>
      </div>

      <button class="auth-btn auth-btn--email" id="btn-email-toggle" type="button">
        Continuar con email
      </button>
    </div>

    <p class="auth-modal__terms">
      Al unirte aceptas nuestros <a href="/terms">términos</a> y <a href="/privacy">política de privacidad</a>.
    </p>

  </div>
</div>

<script is:inline>
  console.log('[AuthModal] Script loaded');

  const modal    = document.getElementById('auth-modal')
  const overlay  = modal.querySelector('.auth-modal__overlay')
  const closeBtn = document.getElementById('auth-modal-close')

  // ── Show / hide ───────────────────────────────────────────────────────────
  function showModal() { 
    console.log('[AuthModal] Showing modal');
    modal.removeAttribute('hidden') 
  }
  function hideModal() { 
    console.log('[AuthModal] Hiding modal');
    modal.setAttribute('hidden', '') 
  }

  // Expose globally so any page/component can call window.showAuthModal()
  window.showAuthModal = showModal
  window.hideAuthModal = hideModal
  
  console.log('[AuthModal] Global functions registered:', { 
    showAuthModal: typeof window.showAuthModal,
    hideAuthModal: typeof window.hideAuthModal
  });

  overlay.addEventListener('click', hideModal)
  closeBtn.addEventListener('click', hideModal)

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal.hasAttribute('hidden')) hideModal()
  })

  // ── Google OAuth ──────────────────────────────────────────────────────────
  // Simple server-side redirect - no client-side Supabase SDK needed
  const googleBtn = document.getElementById('btn-google-signin')
  if (googleBtn) {
    googleBtn.addEventListener('click', function() {
      console.log('[AuthModal] Redirecting to server-side OAuth handler');
      window.location.href = '/auth/signin'
    })
  }

  // ── Email (magic link) ────────────────────────────────────────────────────
  const emailToggle = document.getElementById('btn-email-toggle')
  const emailForm   = document.getElementById('auth-email-form')
  const emailInput  = document.getElementById('auth-email-input')
  const emailSubmit = document.getElementById('btn-email-submit')
  const emailHint   = document.getElementById('auth-email-hint')

  emailToggle.addEventListener('click', () => {
    emailForm.removeAttribute('hidden')
    emailToggle.setAttribute('hidden', '')
    emailInput.focus()
  })

  emailSubmit.addEventListener('click', async () => {
    try {
      const email = emailInput.value.trim()
      if (!email) return

      emailSubmit.textContent = 'Enviando…'
      emailSubmit.setAttribute('disabled', '')

      // Dynamically load Supabase client
      const { createBrowserClient } = await import('https://esm.sh/@supabase/ssr@0.5.1')
      const supabaseUrl     = document.querySelector('meta[name="supabase-url"]')?.getAttribute('content') || ''
      const supabaseAnonKey = document.querySelector('meta[name="supabase-anon-key"]')?.getAttribute('content') || ''
      
      const client = createBrowserClient(supabaseUrl, supabaseAnonKey, {
        auth: {
          flowType: 'pkce',
          detectSessionInUrl: true,
          persistSession: true,
        }
      })

      const { error } = await client.auth.signInWithOtp({
        email,
        options: { emailRedirectTo: `${window.location.origin}/auth/callback` },
      })

      emailHint.removeAttribute('hidden')
      if (error) {
        emailHint.textContent = error.message
        emailHint.classList.add('auth-email-hint--error')
      } else {
        emailHint.textContent = 'Revisa tu bandeja — ¡enlace mágico enviado!'
        emailHint.classList.remove('auth-email-hint--error')
      }

      emailSubmit.removeAttribute('disabled')
      emailSubmit.textContent = 'Enviar enlace mágico'
    } catch(e) {
      console.error('[AuthModal] Email sign in error:', e)
      emailHint.removeAttribute('hidden')
      emailHint.textContent = 'Ocurrió un error. Por favor intenta de nuevo.'
      emailHint.classList.add('auth-email-hint--error')
      emailSubmit.removeAttribute('disabled')
      emailSubmit.textContent = 'Enviar enlace mágico'
    }
  })
</script>
</script>

<style>
/* ── Overlay ── */
.auth-modal {
  position: fixed;
  inset: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 1rem;
}
.auth-modal[hidden] { display: none; }

.auth-modal__overlay {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.72);
  backdrop-filter: blur(4px);
}

/* ── Card ── */
.auth-modal__card {
  position: relative;
  z-index: 1;
  width: 100%;
  max-width: 420px;
  background: var(--surface-elevated);
  border: 1px solid var(--surface-border);
  border-radius: 8px;
  padding: 2.5rem 2rem 2rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0;
}

/* ── Close ── */
.auth-modal__close {
  position: absolute;
  top: 1rem;
  right: 1rem;
  background: none;
  border: none;
  color: var(--text-muted);
  font-size: 1rem;
  cursor: pointer;
  line-height: 1;
  padding: 0.25rem;
  transition: color 120ms ease;
}
.auth-modal__close:hover { color: var(--text-primary); }

/* ── Logo wordmark ── */
.auth-modal__logo {
  font-family: var(--font-serif);
  font-size: 1.125rem;
  font-weight: 400;
  letter-spacing: 0.18em;
  color: var(--text-muted);
  margin-bottom: 1.5rem;
}

/* ── Heading ── */
.auth-modal__heading {
  font-family: var(--font-serif);
  font-size: 1.75rem;
  font-weight: 400;
  color: var(--text-primary);
  margin: 0 0 0.5rem;
  text-align: center;
}

.auth-modal__sub {
  font-size: 0.875rem;
  color: var(--text-muted);
  text-align: center;
  line-height: 1.5;
  margin: 0 0 1.75rem;
  max-width: 300px;
}

/* ── Actions ── */
.auth-modal__actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  margin-bottom: 1.5rem;
}

/* ── Buttons ── */
.auth-btn {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.625rem;
  padding: 0.75rem 1rem;
  border-radius: 5px;
  font-size: 0.875rem;
  font-weight: 500;
  cursor: pointer;
  transition: opacity 120ms ease, background 120ms ease;
  border: none;
}

.auth-btn--google {
  background: #fff;
  color: #1a1a1a;
}
.auth-btn--google:hover { opacity: 0.9; }

.auth-btn__icon {
  width: 18px;
  height: 18px;
  flex-shrink: 0;
}

.auth-btn--email {
  background: transparent;
  color: var(--text-secondary);
  border: 1px solid var(--surface-border);
}
.auth-btn--email:hover {
  border-color: var(--surface-border-strong);
  color: var(--text-primary);
}

/* ── Separator ── */
.auth-modal__separator {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  color: var(--text-muted);
  font-size: 0.75rem;
}
.auth-modal__separator::before,
.auth-modal__separator::after {
  content: '';
  flex: 1;
  height: 1px;
  background: var(--surface-border);
}

/* ── Email form ── */
.auth-email-form {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  width: 100%;
}
.auth-email-form[hidden] { display: none; }

.auth-email-input {
  width: 100%;
  padding: 0.75rem 0.875rem;
  background: var(--surface-card);
  border: 1px solid var(--surface-border);
  border-radius: 5px;
  color: var(--text-primary);
  font-size: 0.875rem;
  outline: none;
  transition: border-color 120ms ease;
  box-sizing: border-box;
}
.auth-email-input:focus { border-color: var(--text-muted); }
.auth-email-input::placeholder { color: var(--text-muted); }

.auth-btn--email-submit {
  background: var(--text-primary);
  color: var(--surface-base);
  font-size: 0.875rem;
  font-weight: 500;
  border: none;
}
.auth-btn--email-submit:hover { opacity: 0.88; }
.auth-btn--email-submit:disabled { opacity: 0.5; cursor: not-allowed; }

.auth-email-hint {
  font-size: 0.78rem;
  color: var(--text-muted);
  text-align: center;
}
.auth-email-hint[hidden] { display: none; }
.auth-email-hint--error { color: #e05252; }

/* ── Terms ── */
.auth-modal__terms {
  font-size: 0.72rem;
  color: var(--text-muted);
  text-align: center;
  line-height: 1.5;
}
.auth-modal__terms a {
  color: var(--text-muted);
  text-decoration: underline;
  text-underline-offset: 2px;
}
.auth-modal__terms a:hover { color: var(--text-secondary); }
</style>
