---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { isSupabaseConfigured, createServiceClient } from '../../lib/db/client';
import { getPaletteEntry } from '../../lib/color/colorPalette';
import { isoToFlag, isoToName, slugToIso } from '../../lib/countries';
import { loadAllWorks } from '../../lib/loaders/loadWork';
import type { PrismaColorId } from '../../lib/db/types';
import FilmSortBar from '../../components/ui/FilmSortBar.astro';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/404');

const iso2 = slugToIso(slug);
const countryName = isoToName(iso2);
const countryFlag = isoToFlag(iso2);

type FilmEntry = {
  id: string;
  title: string;
  year: number | null;
  tmdb_poster_path: string | null;
  color_iconico: PrismaColorId | null;
  numeric_score: number | null;
};

let films: FilmEntry[] = [];

if (isSupabaseConfigured()) {
  const db = createServiceClient();
  const { data, error } = await db
    .from('works')
    .select(`
      id,
      title,
      year,
      tmdb_poster_path,
      color_assignments(color_iconico, numeric_score)
    `)
    .contains('countries', [iso2])
    .eq('is_published', true)
    .order('year', { ascending: false })
    .limit(500);

  if (error) console.error('[countries/slug] Error:', error);

  for (const row of (data ?? []) as any[]) {
    const ca = Array.isArray(row.color_assignments)
      ? row.color_assignments[0]
      : row.color_assignments;
    films.push({
      id: row.id,
      title: row.title,
      year: row.year,
      tmdb_poster_path: row.tmdb_poster_path,
      color_iconico: ca?.color_iconico ?? null,
      numeric_score: ca?.numeric_score ?? null,
    });
  }
} else {
  const works = loadAllWorks();
  films = works
    .filter((w) => (w.countries ?? []).includes(iso2))
    .map((w) => ({
      id: w.id,
      title: w.title,
      year: w.year ?? null,
      tmdb_poster_path: w.media?.poster_path ?? null,
      color_iconico: (w.prisma_palette?.primary as PrismaColorId) ?? null,
      numeric_score: null,
    }));
}

if (films.length === 0) return Astro.redirect('/404');

// ── Sort param ────────────────────────────────────────────────────────────────
const sort = (Astro.url.searchParams.get('sort') ?? 'ranking') as
  'ranking' | 'year_desc' | 'year_asc' | 'title'

// Top 5 poster row — always by score desc, independent of sort
const TMDB_IMG = 'https://image.tmdb.org/t/p/w342';
const top5 = films
  .filter((f) => f.tmdb_poster_path)
  .sort((a, b) => (b.numeric_score ?? 0) - (a.numeric_score ?? 0))
  .slice(0, 5);

// Film list sorted by chosen param
const sorted = [...films].sort((a, b) => {
  if (sort === 'year_desc') return (b.year ?? 0) - (a.year ?? 0);
  if (sort === 'year_asc')  return (a.year ?? 0) - (b.year ?? 0);
  if (sort === 'title')     return a.title.localeCompare(b.title);
  // 'ranking': scored first (score desc), then unscored (year desc)
  if (a.numeric_score != null && b.numeric_score != null) return b.numeric_score - a.numeric_score;
  if (a.numeric_score != null) return -1;
  if (b.numeric_score != null) return 1;
  return (b.year ?? 0) - (a.year ?? 0);
});

const topFilmNames = films.slice(0, 3).map(f => f.title);
const topFilmList = topFilmNames.length ? ` Incluye ${topFilmNames.join(', ')} y más.` : '';

const pageTitle = `Cine de ${countryName} ${countryFlag} — PRISMA`;
const pageDescription = `Las mejores películas de ${countryName} según PRISMA. Cine de autor, festivales y directores de ${countryName}.${topFilmList}`.slice(0, 160);

const countryOgImage = films.find(f => f.tmdb_poster_path)?.tmdb_poster_path
  ? `https://image.tmdb.org/t/p/w780${films.find(f => f.tmdb_poster_path)!.tmdb_poster_path}`
  : undefined;

const SITE = 'https://prisma.film';
const countryJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: pageTitle,
  description: pageDescription,
  url: `${SITE}/countries/${slug}`,
  numberOfItems: films.length,
  itemListElement: films.slice(0, 10).map((film, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Movie',
      name: film.title,
      dateCreated: film.year?.toString(),
      url: `${SITE}/films/${film.id.replace(/^work_/, '')}`,
    },
  })),
};

const countryBreadcrumbs = [
  { name: 'PRISMA', url: SITE },
  { name: 'Países', url: `${SITE}/countries` },
  { name: countryName, url: `${SITE}/countries/${slug}` },
];
---

<BaseLayout title={pageTitle} description={pageDescription} ogImage={countryOgImage} jsonLd={countryJsonLd} breadcrumbs={countryBreadcrumbs}>
  <div class="country-page page-enter">

    <!-- Header -->
    <section class="country-header">
      <div class="site-container">
        <div class="country-header__inner">
          <div class="country-header__flag" aria-hidden="true">{countryFlag}</div>
          <div class="country-header__info">
            <div class="country-header__overline">Cine Nacional</div>
            <h1 class="country-header__name">{countryName}</h1>
            <p class="country-header__count">{films.length} {films.length === 1 ? 'película' : 'películas'} en el catálogo</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Top 5 poster row -->
    {top5.length > 0 && (
      <section class="country-posters">
        <div class="site-container">
          <div class="country-posters__label">Películas Destacadas</div>
          <div class="poster-row">
            {top5.map((film, i) => {
              const filmSlug = film.id.replace(/^work_/, '');
              const palette = film.color_iconico ? getPaletteEntry(film.color_iconico) : null;
              return (
                <a href={`/films/${filmSlug}`} class="poster-card">
                  <img
                    src={`${TMDB_IMG}${film.tmdb_poster_path}`}
                    alt={film.title}
                    class="poster-card__img"
                    loading="lazy"
                    decoding="async"
                  />
                  <span class="poster-card__num">#{i + 1}</span>
                  <div class="poster-card__overlay">
                    <span class="poster-card__overlay-title">{film.title}</span>
                    {film.year && <span class="poster-card__overlay-year">{film.year}</span>}
                    {palette && (
                      <span class="poster-card__overlay-color" style={`color: ${palette.hex}`}>
                        {palette.name}
                      </span>
                    )}
                  </div>
                </a>
              );
            })}
          </div>
        </div>
      </section>
    )}

    <!-- Film poster grid -->
    <section class="country-films">
      <div class="site-container">
        <div class="country-films__header">
          <h2 class="country-films__heading">Filmografía</h2>
        </div>
        <FilmSortBar
          currentSort={sort}
          totalCount={sorted.length}
          baseUrl={`/countries/${slug}`}
        />
        <div class="country-films__grid" id="films-grid">
          {sorted.map((film, i) => {
            const filmSlug = film.id.replace(/^work_/, '');
            const initial = film.title.charAt(0).toUpperCase();
            return (
              <a href={`/films/${filmSlug}`} class="film-pcard" data-idx={i}>
                <div class="film-pcard__img-wrap">
                  {film.tmdb_poster_path
                    ? <img src={`${TMDB_IMG}${film.tmdb_poster_path}`} alt={film.title} loading="lazy" decoding="async" />
                    : <div class="film-pcard__placeholder"><span>{initial}</span></div>
                  }
                </div>
                <div class="film-pcard__info">
                  <span class="film-pcard__title">{film.title}</span>
                  {film.year && <span class="film-pcard__year">{film.year}</span>}
                </div>
              </a>
            );
          })}
        </div>
        {sorted.length > 40 && (
          <div class="films-pagination">
            <button class="films-pagination__btn" id="films-prev" disabled>← Anterior</button>
            <span class="films-pagination__info" id="films-page-info">1 / {Math.ceil(sorted.length / 40)}</span>
            <button class="films-pagination__btn" id="films-next">Siguiente →</button>
          </div>
        )}
      </div>
    </section>

  </div>
</BaseLayout>

<style>
.country-page {
  padding-bottom: 6rem;
}

/* ─── Header ──────────────────────────────────────────────────────────────── */
.country-header {
  padding-top: 9rem;
  padding-bottom: 4rem;
  border-bottom: 1px solid var(--surface-border);
}

.country-header__inner {
  display: flex;
  gap: 2rem;
  align-items: center;
}

.country-header__flag {
  font-size: 3.5rem;
  line-height: 1;
  flex-shrink: 0;
}

.country-header__overline {
  font-size: 0.65rem;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 0.5rem;
}

.country-header__name {
  font-family: var(--font-serif);
  font-size: clamp(2rem, 5vw, 3.5rem);
  font-weight: 400;
  color: var(--text-primary);
  margin-bottom: 0.5rem;
}

.country-header__count {
  font-size: 0.8rem;
  color: var(--text-muted);
  font-family: var(--font-mono);
}

/* ─── Poster row ──────────────────────────────────────────────────────────── */
.country-posters {
  padding: 3rem 0 0;
}

.country-posters__label {
  font-family: var(--font-sans);
  font-size: 0.65rem;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 1rem;
}

.poster-row {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 1rem;
}

.poster-card {
  position: relative;
  display: block;
  aspect-ratio: 2 / 3;
  border-radius: 3px;
  overflow: hidden;
  text-decoration: none;
  background: var(--surface-card);
}

.poster-card__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  display: block;
  transition: transform 220ms ease;
}
.poster-card:hover .poster-card__img { transform: scale(1.03); }

.poster-card__num {
  position: absolute;
  top: 0.5rem;
  left: 0.5rem;
  font-family: var(--font-mono);
  font-size: 0.65rem;
  color: rgba(255,255,255,0.55);
  pointer-events: none;
  text-shadow: 0 1px 3px rgba(0,0,0,0.6);
}

.poster-card__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.88) 0%, rgba(0,0,0,0.3) 45%, transparent 70%);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 0.625rem 0.625rem 0.75rem;
  opacity: 0;
  transform: translateY(4px);
  transition: opacity 180ms ease, transform 180ms ease;
}
.poster-card:hover .poster-card__overlay { opacity: 1; transform: translateY(0); }

.poster-card__overlay-title {
  font-size: 0.72rem;
  color: #F0EEE8;
  line-height: 1.3;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.poster-card__overlay-year {
  font-size: 0.62rem;
  color: rgba(240,238,232,0.6);
  margin-top: 0.2rem;
  font-family: var(--font-mono);
}

.poster-card__overlay-color {
  font-size: 0.6rem;
  margin-top: 0.25rem;
  opacity: 0.8;
  font-family: var(--font-mono);
  letter-spacing: 0.05em;
}

@media (max-width: 640px) {
  .poster-row {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    gap: 0.625rem;
    padding-bottom: 0.5rem;
    scrollbar-width: none;
  }
  .poster-row::-webkit-scrollbar { display: none; }
  .poster-card {
    width: 140px;
    min-width: 140px;
    aspect-ratio: 2 / 3;
    scroll-snap-align: start;
  }
}

/* ─── Film poster grid ─────────────────────────────────────────────────────── */
.country-films {
  padding: 3rem 0 5rem;
}

.country-films__header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 1.5rem;
}

.country-films__heading {
  font-family: var(--font-serif);
  font-size: 1.25rem;
  font-weight: 400;
  color: var(--text-primary);
}

.country-films__count {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  color: var(--text-muted);
}

.country-films__grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
  gap: 1rem;
  margin-bottom: 2rem;
}

.film-pcard {
  display: block;
  text-decoration: none;
  transition: transform 200ms ease;
}
.film-pcard:hover { transform: scale(1.03); }

.film-pcard__img-wrap {
  aspect-ratio: 2 / 3;
  border-radius: 4px;
  overflow: hidden;
  background: var(--surface-card);
  box-shadow: 0 2px 8px rgba(0,0,0,0.3);
  transition: box-shadow 200ms ease;
}
.film-pcard:hover .film-pcard__img-wrap { box-shadow: 0 8px 24px rgba(0,0,0,0.5); }

.film-pcard__img-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  display: block;
}

.film-pcard__placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--surface-elevated);
}
.film-pcard__placeholder span {
  font-family: var(--font-serif);
  font-size: 2rem;
  color: var(--text-muted);
  opacity: 0.4;
}

.film-pcard__info {
  padding: 0.45rem 0 0;
  display: flex;
  flex-direction: column;
  gap: 0.15rem;
}

.film-pcard__title {
  font-size: 0.78rem;
  color: var(--text-secondary);
  line-height: 1.3;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  transition: color 160ms ease;
}
.film-pcard:hover .film-pcard__title { color: var(--text-primary); }

.film-pcard__year {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  color: var(--text-muted);
}

/* ── Pagination ── */
.films-pagination {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 1.5rem;
  padding: 1.5rem 0;
  border-top: 1px solid var(--surface-border);
}

.films-pagination__btn {
  font-family: var(--font-sans);
  font-size: 0.78rem;
  color: var(--text-muted);
  background: var(--surface-card);
  border: 1px solid var(--surface-border);
  border-radius: 3px;
  padding: 0.4rem 0.875rem;
  cursor: pointer;
  transition: color 160ms ease, border-color 160ms ease;
}
.films-pagination__btn:hover:not(:disabled) {
  color: var(--text-primary);
  border-color: var(--text-muted);
}
.films-pagination__btn:disabled { opacity: 0.35; cursor: not-allowed; }

.films-pagination__info {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  color: var(--text-muted);
}

@media (max-width: 600px) {
  .country-films__grid { grid-template-columns: repeat(auto-fill, minmax(100px, 1fr)); gap: 0.625rem; }
  .country-header__inner { gap: 1.25rem; }
  .country-header__flag { font-size: 2.5rem; }
}
</style>

<script is:inline>
(function () {
  var PAGE_SIZE = 40;
  var currentPage = 0;
  var cards = Array.from(document.querySelectorAll('.film-pcard'));
  var totalPages = Math.ceil(cards.length / PAGE_SIZE);
  if (totalPages <= 1) return;

  function showPage(page) {
    currentPage = page;
    cards.forEach(function (card, i) {
      card.style.display = (i >= page * PAGE_SIZE && i < (page + 1) * PAGE_SIZE) ? '' : 'none';
    });
    var prev = document.getElementById('films-prev');
    var next = document.getElementById('films-next');
    var info = document.getElementById('films-page-info');
    if (prev) prev.disabled = (page === 0);
    if (next) next.disabled = (page >= totalPages - 1);
    if (info) info.textContent = (page + 1) + ' / ' + totalPages;
  }

  showPage(0);

  var prevBtn = document.getElementById('films-prev');
  var nextBtn = document.getElementById('films-next');
  if (prevBtn) prevBtn.addEventListener('click', function () { if (currentPage > 0) { showPage(currentPage - 1); var g = document.getElementById('films-grid'); if (g) window.scrollTo({ top: g.offsetTop - 80, behavior: 'smooth' }); } });
  if (nextBtn) nextBtn.addEventListener('click', function () { if (currentPage < totalPages - 1) { showPage(currentPage + 1); var g = document.getElementById('films-grid'); if (g) window.scrollTo({ top: g.offsetTop - 80, behavior: 'smooth' }); } });
})();
</script>
