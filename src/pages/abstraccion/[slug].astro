---
import BaseLayout from '../../layouts/BaseLayout.astro'
import {
  ABSTRACTION_LABELS,
  ABSTRACTION_DESCRIPTIONS,
  slugToAbstraction,
  type VisualAbstraction,
} from '../../lib/film/filmDimensions'
import { getWorksByAbstraction } from '../../lib/db/works'

export const prerender = true

export async function getStaticPaths() {
  const abstractions: VisualAbstraction[] = [
    'extremadamente_realista',
    'realista_con_estilizacion',
    'estilizado',
    'muy_estilizado',
    'extremadamente_abstracto',
  ]
  return abstractions.map((a) => ({
    params: { slug: a.replace(/_/g, '-') },
    props: { abstractionId: a },
  }))
}

const { abstractionId } = Astro.props as { abstractionId: VisualAbstraction }
const label = ABSTRACTION_LABELS[abstractionId]
const description = ABSTRACTION_DESCRIPTIONS[abstractionId]
const works = await getWorksByAbstraction(abstractionId, 100)

const TMDB_IMG = 'https://image.tmdb.org/t/p/w185'
---

<BaseLayout
  title={`${label} — Abstracción Visual · Prisma`}
  description={description}
>
  <div class="dim-page">
    <header class="dim-page__header site-container">
      <p class="dim-page__category reveal">Abstracción Visual</p>
      <h1 class="dim-page__title reveal" data-delay="60">{label}</h1>
      <p class="dim-page__description reveal" data-delay="120">{description}</p>
      <p class="dim-page__count reveal" data-delay="160">{works.length} películas</p>
    </header>

    <div class="dim-page__grid site-container">
      {works.map((work, i) => {
        const filmSlug = work.id.replace('work_', '')
        const posterPath = (work as any).tmdb_poster_path as string | null
        return (
          <a
            href={`/films/${filmSlug}`}
            class="dim-poster reveal"
            data-delay={String(Math.min(i * 30, 400))}
          >
            {posterPath
              ? <img
                  src={`${TMDB_IMG}${posterPath}`}
                  alt={work.title}
                  loading="lazy"
                  decoding="async"
                />
              : <div class="dim-poster__fallback">
                  <span>{work.title}</span>
                </div>
            }
            <div class="dim-poster__overlay">
              <span class="dim-poster__title">{work.title}</span>
              {work.year && <span class="dim-poster__year">{work.year}</span>}
            </div>
          </a>
        )
      })}
    </div>
  </div>
</BaseLayout>

<style>
.dim-page {
  padding-top: var(--space-16);
  padding-bottom: var(--space-16);
}

.dim-page__header {
  max-width: 56ch;
  margin-bottom: var(--space-10);
}

.dim-page__category {
  font-size: var(--text-xs);
  font-weight: var(--weight-semi);
  letter-spacing: var(--tracking-widest);
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: var(--space-3);
}

.dim-page__title {
  font-family: var(--font-serif);
  font-size: clamp(2.5rem, 5vw, 4rem);
  font-weight: 400;
  letter-spacing: -0.02em;
  color: var(--text-primary);
  margin-bottom: var(--space-4);
  line-height: 1.08;
}

.dim-page__description {
  font-size: 1rem;
  line-height: 1.75;
  color: var(--text-secondary);
  margin-bottom: var(--space-4);
}

.dim-page__count {
  font-size: var(--text-xs);
  color: var(--text-muted);
  letter-spacing: var(--tracking-wide);
}

.dim-page__grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
  gap: var(--space-4);
}

.dim-poster {
  position: relative;
  display: block;
  aspect-ratio: 2 / 3;
  border-radius: var(--radius-md);
  overflow: hidden;
  text-decoration: none;
  background: var(--bg-raised);
  box-shadow: var(--shadow-card);
  transition:
    transform var(--dur-base) var(--ease-editorial),
    box-shadow var(--dur-base) var(--ease-editorial);
  will-change: transform;
}

.dim-poster:hover {
  transform: translateY(-4px) scale(1.015);
  box-shadow: var(--shadow-raised);
}

.dim-poster img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  display: block;
  transition: transform var(--dur-slow) var(--ease-editorial);
}

.dim-poster:hover img { transform: scale(1.04); }

.dim-poster__fallback {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-3);
  background: var(--bg-elevated);
}

.dim-poster__fallback span {
  font-size: var(--text-xs);
  color: var(--text-muted);
  text-align: center;
  line-height: 1.4;
}

.dim-poster__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.3) 40%, transparent 65%);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 0.625rem 0.75rem 0.75rem;
  opacity: 0;
  transform: translateY(3px);
  transition:
    opacity var(--dur-base) var(--ease-editorial),
    transform var(--dur-base) var(--ease-editorial);
}

.dim-poster:hover .dim-poster__overlay {
  opacity: 1;
  transform: translateY(0);
}

.dim-poster__title {
  font-family: var(--font-sans);
  font-size: 0.72rem;
  color: #F0EEE8;
  line-height: 1.3;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.dim-poster__year {
  font-family: var(--font-mono);
  font-size: 0.6rem;
  color: rgba(240,238,232,0.6);
  margin-top: 0.2rem;
}

@media (max-width: 640px) {
  .dim-page__grid {
    grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
    gap: var(--space-2);
  }
}
</style>
