---
import Layout from '../../layouts/Layout.astro';
import { getPaletteEntry } from '../../lib/color/colorPalette';
import { isSupabaseConfigured, createServiceClient } from '../../lib/db/client';
import { loadAllWorks } from '../../lib/loaders/loadWork';

const PER_PAGE = 50;
const pageParam = Astro.url.searchParams.get('page');
const currentPage = Math.max(1, parseInt(pageParam ?? '1', 10));

type RankedFilm = {
  slug: string;
  title: string;
  year: number | null;
  rank: number;
  score: number | null;
  colorId: string | null;
  colorHex: string;
  colorName: string;
  tier: string | null;
};

let allRankedWorks: RankedFilm[] = [];

if (isSupabaseConfigured()) {
  const db = createServiceClient();

  // Fetch all ranking scores (no artificial limit)
  const { data: rankings } = await db
    .from('ranking_scores')
    .select('entity_id, score, rank')
    .eq('entity_type', 'work')
    .eq('context', 'global')
    .order('rank', { ascending: true })
    .limit(1000);

  // Fetch ALL published works
  const { data: allWorks, error } = await db
    .from('works')
    .select('id, title, year, color_assignments(color_iconico, tier, numeric_score)')
    .eq('is_published', true)
    .limit(1000);

  if (error) console.error('[rankings/films] Error fetching works:', error);

  const rankMap = new Map(
    (rankings ?? []).map((r: { entity_id: string; score: number; rank: number | null }) => [r.entity_id, r])
  );

  const fsColorMap = new Map(
    loadAllWorks().map(w => [w.id, w.prisma_palette?.primary ?? null])
  );

  const merged = (allWorks ?? []).map((work: {
    id: string;
    title: string;
    year: number | null;
    color_assignments: Array<{ color_iconico: string; tier: string; numeric_score: number }> | null;
  }) => {
    const ranking = rankMap.get(work.id);
    const colorId = work.color_assignments?.[0]?.color_iconico ?? fsColorMap.get(work.id) ?? null;
    const p = colorId ? getPaletteEntry(colorId) : null;
    return {
      slug: work.id.replace('work_', ''),
      title: work.title,
      year: work.year,
      _hasRank: ranking != null,
      _rawRank: ranking?.rank ?? null,
      score: ranking?.score ?? null,
      colorId,
      colorHex: p?.hex ?? '#1B2A41',
      colorName: p?.name ?? '',
      tier: work.color_assignments?.[0]?.tier ?? null,
    };
  });

  // Ranked works first (by score desc), then unranked by year desc
  merged.sort((a, b) => {
    if (a._hasRank && b._hasRank) return (a._rawRank ?? 9999) - (b._rawRank ?? 9999);
    if (a._hasRank) return -1;
    if (b._hasRank) return 1;
    return (b.year ?? 0) - (a.year ?? 0);
  });

  allRankedWorks = merged.map((w, i) => ({
    slug: w.slug,
    title: w.title,
    year: w.year,
    rank: i + 1,
    score: w.score,
    colorId: w.colorId,
    colorHex: w.colorHex,
    colorName: w.colorName,
    tier: w.tier,
  }));

} else {
  // Filesystem fallback
  const works = loadAllWorks();
  allRankedWorks = works.map((w, i) => {
    const colorId = w.prisma_palette?.primary ?? null;
    const p = colorId ? getPaletteEntry(colorId) : null;
    return {
      slug: w.slug,
      title: w.title,
      year: w.year ?? null,
      rank: i + 1,
      score: null,
      colorId,
      colorHex: p?.hex ?? '#1B2A41',
      colorName: p?.name ?? '',
      tier: null,
    };
  });
}

const totalFilms = allRankedWorks.length;
const totalPages = Math.max(1, Math.ceil(totalFilms / PER_PAGE));
const safePage = Math.min(currentPage, totalPages);
const offset = (safePage - 1) * PER_PAGE;
const pageWorks = allRankedWorks.slice(offset, offset + PER_PAGE);

const SITE = 'https://prisma.film';
const rankingsTitle = 'Rankings de Películas — PRISMA | Mejores Películas de Autor';
const rankingsDescription = 'El ranking PRISMA de las mejores películas de cine de autor, ordenadas por peso cultural, premios internacionales y calificación editorial. Descubre las joyas del cine mundial.';

const rankingsBreadcrumbs = [
  { name: 'PRISMA', url: SITE },
  { name: 'Rankings', url: `${SITE}/rankings/films` },
];

const rankingsJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: rankingsTitle,
  description: rankingsDescription,
  url: `${SITE}/rankings/films`,
  numberOfItems: totalFilms,
  itemListElement: pageWorks.slice(0, 20).map((film, i) => ({
    '@type': 'ListItem',
    position: offset + i + 1,
    item: {
      '@type': 'Movie',
      name: film.title,
      dateCreated: film.year?.toString(),
      url: `${SITE}/films/${film.slug}`,
    },
  })),
};

function pageUrl(p: number): string {
  return `/rankings/films${p === 1 ? '' : `?page=${p}`}`;
}

// Page window: always show first, last, and up to 2 around current
function pageWindow(current: number, total: number): (number | '…')[] {
  if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1);
  const pages: (number | '…')[] = [1];
  if (current > 3) pages.push('…');
  for (let p = Math.max(2, current - 1); p <= Math.min(total - 1, current + 1); p++) pages.push(p);
  if (current < total - 2) pages.push('…');
  pages.push(total);
  return pages;
}
---

<Layout title={rankingsTitle} description={rankingsDescription} jsonLd={rankingsJsonLd} breadcrumbs={rankingsBreadcrumbs}>
  <div class="rankings-page page-enter">
    <div class="rankings-header site-container">
      <h1 class="rankings-header__title">Rankings de Películas</h1>
      <p class="rankings-header__desc">
        Clasificadas por puntaje de prestigio: canon (40%), reconocimiento en festivales (30%),
        engagement (20%), distribución arthouse (10%).
      </p>
      <p class="rankings-header__count">
        {totalFilms} películas &middot; página {safePage} de {totalPages}
      </p>
    </div>

    <div class="site-container">
      {pageWorks.length === 0 ? (
        <div class="rankings-empty">
          <p>Aún no hay rankings disponibles. Los rankings se calculan a partir de las obras ingresadas.</p>
        </div>
      ) : (
        <>
          <div class="rankings-list">
            {pageWorks.map((item) => (
              <a href={`/films/${item.slug}`} class="ranking-row">
                <div class="ranking-row__num">#{item.rank}</div>

                <div
                  class="ranking-row__color-strip"
                  style={`background: ${item.colorHex}`}
                  title={item.colorName}
                />

                <div class="ranking-row__info">
                  <span class="ranking-row__title">{item.title}</span>
                  {item.year && <span class="ranking-row__year">{item.year}</span>}
                </div>

                <div class="ranking-row__meta">
                  {item.colorName && (
                    <span class="ranking-row__color">{item.colorName}</span>
                  )}
                  {item.tier && (
                    <span class={`tier-badge tier-badge--${item.tier}`}>{item.tier}</span>
                  )}
                  {item.score && (
                    <span class="ranking-row__score">{item.score.toFixed(1)}</span>
                  )}
                </div>
              </a>
            ))}
          </div>

          {totalPages > 1 && (
            <nav class="pagination" aria-label="Rankings pages">
              <a
                href={pageUrl(safePage - 1)}
                class={`pagination__btn${safePage === 1 ? ' pagination__btn--disabled' : ''}`}
                aria-disabled={safePage === 1}
              >
                ← Anterior
              </a>

              <div class="pagination__pages">
                {pageWindow(safePage, totalPages).map((p) =>
                  p === '…' ? (
                    <span class="pagination__ellipsis">…</span>
                  ) : (
                    <a
                      href={pageUrl(p as number)}
                      class={`pagination__page${p === safePage ? ' pagination__page--active' : ''}`}
                      aria-current={p === safePage ? 'page' : undefined}
                    >
                      {p}
                    </a>
                  )
                )}
              </div>

              <a
                href={pageUrl(safePage + 1)}
                class={`pagination__btn${safePage === totalPages ? ' pagination__btn--disabled' : ''}`}
                aria-disabled={safePage === totalPages}
              >
                Siguiente →
              </a>
            </nav>
          )}
        </>
      )}
    </div>
  </div>
</Layout>

<style>
.rankings-page {
  padding-top: 8rem;
  padding-bottom: 6rem;
}

.rankings-header {
  margin-bottom: 3rem;
}

.rankings-header__title {
  font-family: var(--font-serif);
  font-size: clamp(2rem, 5vw, 3.5rem);
  font-weight: 400;
  color: var(--text-primary);
  margin-bottom: 0.875rem;
}

.rankings-header__desc {
  font-size: 0.875rem;
  color: var(--text-muted);
  max-width: 55ch;
  line-height: 1.65;
}

.rankings-header__count {
  margin-top: 0.5rem;
  font-size: 0.75rem;
  color: var(--text-muted);
  font-family: var(--font-mono);
  letter-spacing: 0.03em;
}

.rankings-empty {
  padding: 3rem;
  border: 1px solid var(--surface-border);
  border-radius: 4px;
}

.rankings-empty p {
  font-size: 0.875rem;
  color: var(--text-muted);
  font-style: italic;
}

.rankings-list {
  display: flex;
  flex-direction: column;
  gap: 1px;
  border: 1px solid var(--surface-border);
  border-radius: 4px;
  overflow: hidden;
}

.ranking-row {
  display: grid;
  grid-template-columns: 3rem 3px 1fr auto;
  align-items: center;
  gap: 1.25rem;
  padding: 1rem 1.25rem;
  background: var(--surface-card);
  text-decoration: none;
  transition: background 160ms ease;
}

.ranking-row:hover { background: var(--surface-elevated); }

.ranking-row__num {
  font-family: var(--font-mono);
  font-size: 0.8rem;
  color: var(--text-muted);
  text-align: right;
}

.ranking-row__color-strip {
  height: 2rem;
  border-radius: 1.5px;
  width: 3px;
  flex-shrink: 0;
}

.ranking-row__info {
  display: flex;
  align-items: baseline;
  gap: 0.75rem;
  min-width: 0;
}

.ranking-row__title {
  font-size: 0.9rem;
  color: var(--text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  transition: color 160ms ease;
}
.ranking-row:hover .ranking-row__title { color: var(--text-primary); }

.ranking-row__year {
  font-size: 0.75rem;
  color: var(--text-muted);
  flex-shrink: 0;
}

.ranking-row__meta {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  flex-shrink: 0;
}

.ranking-row__color {
  font-size: 0.7rem;
  color: var(--text-muted);
}

.ranking-row__score {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  color: var(--text-muted);
}

/* ── Pagination ── */
.pagination {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  margin-top: 2.5rem;
  flex-wrap: wrap;
}

.pagination__btn {
  padding: 0.45rem 1rem;
  font-size: 0.8rem;
  color: var(--text-secondary);
  background: var(--surface-card);
  border: 1px solid var(--surface-border);
  border-radius: 3px;
  text-decoration: none;
  transition: background 140ms ease, color 140ms ease;
}
.pagination__btn:hover:not(.pagination__btn--disabled) {
  background: var(--surface-elevated);
  color: var(--text-primary);
}
.pagination__btn--disabled {
  opacity: 0.35;
  pointer-events: none;
}

.pagination__pages {
  display: flex;
  align-items: center;
  gap: 0.25rem;
}

.pagination__page {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 2rem;
  height: 2rem;
  font-size: 0.8rem;
  font-family: var(--font-mono);
  color: var(--text-secondary);
  background: var(--surface-card);
  border: 1px solid var(--surface-border);
  border-radius: 3px;
  text-decoration: none;
  transition: background 140ms ease, color 140ms ease;
}
.pagination__page:hover {
  background: var(--surface-elevated);
  color: var(--text-primary);
}
.pagination__page--active {
  background: var(--text-primary);
  color: var(--surface-bg);
  border-color: var(--text-primary);
  pointer-events: none;
}

.pagination__ellipsis {
  width: 2rem;
  text-align: center;
  font-size: 0.8rem;
  color: var(--text-muted);
}

@media (max-width: 600px) {
  .ranking-row { grid-template-columns: 2.5rem 3px 1fr; }
  .ranking-row__meta { display: none; }
}
</style>
