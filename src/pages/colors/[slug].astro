---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getColorProfile } from '../../lib/db/colors';
import { isSupabaseConfigured, createServiceClient } from '../../lib/db/client';
import { isLightColor } from '../../lib/color/colorPalette';
import type { WorkCard, PrismaColorId } from '../../lib/db/types';

const { slug } = Astro.params;

if (!slug) return Astro.redirect('/404');

// Convert URL slug (hyphen) to database/doctrine format (underscore)
// URL: "cian-melancolico" → DB: "cian_melancolico"
const colorId = slug.replace(/-/g, '_') as PrismaColorId;

const doctrine = getColorProfile(colorId);
if (!doctrine) return Astro.redirect('/404');

const lightBg = isLightColor(colorId);
const heroTextColor = lightBg ? '#0A0A0F' : '#F0EEE8';
const heroSubColor = lightBg ? 'rgba(10,10,15,0.55)' : 'rgba(240,238,232,0.45)';

// Fetch films for this color
type GroupedFilms = { canon: WorkCard[]; core: WorkCard[]; strong: WorkCard[]; peripheral: WorkCard[] };
let films: GroupedFilms = { canon: [], core: [], strong: [], peripheral: [] };

if (isSupabaseConfigured()) {
  try {
    const db = createServiceClient();
    const { data, error } = await db
      .from('color_assignments')
      .select(`
        color_iconico,
        tier,
        tier_rank,
        numeric_score,
        works!inner(
          id,
          title,
          year,
          countries,
          tmdb_poster_path,
          criterion_title,
          is_published
        )
      `)
      .eq('color_iconico', colorId)
      .eq('review_status', 'approved')
      .order('tier', { ascending: true })
      .order('tier_rank', { ascending: true, nullsFirst: false })
      .limit(200);

    if (!error && data) {
      for (const row of data as any[]) {
        const work = row.works;
        if (!work) continue;

        const workCard: WorkCard = {
          id: work.id,
          title: work.title,
          year: work.year,
          countries: work.countries,
          tmdb_poster_path: work.tmdb_poster_path,
          criterion_title: work.criterion_title,
          color_iconico: row.color_iconico,
          tier: row.tier,
          tier_rank: row.tier_rank,
          numeric_score: row.numeric_score,
          prestige_score: null,
          global_rank: null,
        };

        const t: string = row.tier ?? 'uncertain';
        if (t === 'canon') films.canon.push(workCard);
        else if (t === 'core') films.core.push(workCard);
        else if (t === 'strong') films.strong.push(workCard);
        else if (t === 'peripheral') films.peripheral.push(workCard);
        else films.peripheral.push(workCard);
      }
    }
  } catch (err) {
    console.error('[colors/slug] Error fetching films:', err);
  }
}

const allFilms = [...films.canon, ...films.core, ...films.strong, ...films.peripheral];

// Top 10 poster grid — films with posters, sorted by numeric_score desc
const top10 = allFilms
  .filter((f) => f.tmdb_poster_path)
  .sort((a, b) => (b.numeric_score ?? 0) - (a.numeric_score ?? 0))
  .slice(0, 10);
const posterRow1 = top10.slice(0, 5);
const posterRow2 = top10.slice(5, 10);

const TMDB_IMG = 'https://image.tmdb.org/t/p/w342';
const TMDB_SM   = 'https://image.tmdb.org/t/p/w342';

const colorDisplayName = doctrine.name;
const colorMood = doctrine.cultural_context ?? '';
const topFilmNames = allFilms.slice(0, 3).map(f => f.title);
const topFilmList = topFilmNames.length ? ` Incluye ${topFilmNames.join(', ')} y más.` : '';

const pageTitle = `${colorDisplayName} — Paleta PRISMA | Cine de Autor`;
const pageDescription = `Las mejores películas de cine de autor clasificadas como ${colorDisplayName} en PRISMA. ${colorMood}${topFilmList}`.slice(0, 160);

const colorOgImage = allFilms.find(f => f.tmdb_poster_path)?.tmdb_poster_path
  ? `https://image.tmdb.org/t/p/w780${allFilms.find(f => f.tmdb_poster_path)!.tmdb_poster_path}`
  : undefined;

const SITE = 'https://prisma.film';
const colorJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: pageTitle,
  description: pageDescription,
  url: `${SITE}/colors/${slug}`,
  numberOfItems: allFilms.length,
  itemListElement: allFilms.slice(0, 10).map((film, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Movie',
      name: film.title,
      dateCreated: film.year?.toString(),
      url: `${SITE}/films/${film.id.replace(/^work_/, '')}`,
    },
  })),
};

const colorBreadcrumbs = [
  { name: 'PRISMA', url: SITE },
  { name: 'Colores', url: `${SITE}/colors` },
  { name: colorDisplayName, url: `${SITE}/colors/${slug}` },
];

// ── Cinematographer name → people slug map ────────────────────────────────
// Maps exact names from color_doctrine to their person page slugs.
// Only names confirmed to exist as person records are included.
const CINEMATOGRAPHER_SLUG: Record<string, string> = {
  'Agnes Godard':        'agnes-godard',
  'Bruno Delbonnel':     'bruno-delbonnel',
  'Christopher Doyle':   'christopher-doyle',
  'Ed Lachman':          'edward-lachman',
  'Edward Lachman':      'edward-lachman',
  'Emmanuel Lubezki':    'emmanuel-lubezki',
  'Gordon Willis':       'gordon-willis',
  'Gregg Toland':        'gregg-toland',
  'Harris Savides':      'harris-savides',
  'Raoul Coutard':       'raoul-coutard',
  'Robert Richardson':   'robert-richardson',
  'Robert Yeoman':       'robert-d-yeoman',
  'Rodrigo Prieto':      'rodrigo-prieto',
  'Roger Deakins':       'roger-deakins',
  'Sven Nykvist':        'sven-nykvist',
  'Vittorio Storaro':    'vittorio-storaro',
};
---

<BaseLayout title={pageTitle} description={pageDescription} ogImage={colorOgImage} jsonLd={colorJsonLd} breadcrumbs={colorBreadcrumbs}>

  <!-- ─── Color Hero — immersive full-width wash ──────────────────────────── -->
  <section
    class="color-hero"
    style={`--c-hex: ${doctrine.hex}; --c-text: ${heroTextColor}; --c-sub: ${heroSubColor};`}
  >
    <div class="color-hero__wash" />
    <!-- Vertical accent bar — ColorsxStudios color identity edge -->
    <div class="color-hero__edge" style={`background: ${doctrine.hex}`} />

    <div class="color-hero__inner site-container">
      <div class="color-hero__overline">Paleta Prisma</div>
      <h1 class="color-hero__name">{doctrine.name}</h1>
      <div class="color-hero__hex">{doctrine.hex}</div>
      <p class="color-hero__context">{doctrine.cultural_context}</p>
      <div class="color-hero__moods">
        {doctrine.moods.map((mood) => (
          <span class="color-hero__mood">{mood}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── Cinematographic notes ────────────────────────────────────────────── -->
  <section class="color-notes">
    <div class="site-container">
      <div class="color-notes__inner">
        <p class="color-notes__text reveal">{doctrine.cinematographic_notes}</p>
        {doctrine.cinematographer_signatures.length > 0 && (
          <div class="color-notes__sigs reveal" data-delay="100">
            <span class="color-notes__sigs-label">Cinefotógrafos asociados</span>
            <span class="color-notes__sigs-names">
              {doctrine.cinematographer_signatures.map((name, i) => {
                const personSlug = CINEMATOGRAPHER_SLUG[name];
                return (
                  <>
                    {i > 0 && <span class="color-notes__sigs-sep"> · </span>}
                    {personSlug
                      ? <a href={`/people/${personSlug}`} class="color-notes__sigs-link">{name}</a>
                      : <span>{name}</span>
                    }
                  </>
                );
              })}
            </span>
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- ─── Top 10 Poster Ranking ─────────────────────────────────────────────── -->
  {top10.length > 0 && (
    <section class="poster-ranking">
      <div class="site-container">
        <div class="section-label poster-ranking__label reveal">Ranking</div>

        <div class="poster-row">
          {posterRow1.map((film, i) => {
            const filmSlug = film.id.replace(/^work_/, '');
            return (
              <a href={`/films/${filmSlug}`} class="pcard reveal" data-delay={String(i * 60)}>
                {film.tmdb_poster_path
                  ? <img src={`${TMDB_IMG}${film.tmdb_poster_path}`} alt={film.title} loading="lazy" decoding="async" />
                  : <div class="pcard__fallback" style={`background: ${doctrine.hex}`}>
                      <span>{film.title}</span>
                    </div>
                }
                <span class="pcard__num">#{i + 1}</span>
                <div class="pcard__overlay">
                  <span class="pcard__overlay-title">{film.title}</span>
                  {film.year && <span class="pcard__overlay-year">{film.year}</span>}
                </div>
              </a>
            );
          })}
        </div>

        {posterRow2.length > 0 && (
          <div class="poster-row poster-row--secondary">
            {posterRow2.map((film, i) => {
              const filmSlug = film.id.replace(/^work_/, '');
              return (
                <a href={`/films/${filmSlug}`} class="pcard reveal" data-delay={String(i * 50)}>
                  {film.tmdb_poster_path
                    ? <img src={`${TMDB_IMG}${film.tmdb_poster_path}`} alt={film.title} loading="lazy" decoding="async" />
                    : <div class="pcard__fallback" style={`background: ${doctrine.hex}`}>
                        <span>{film.title}</span>
                      </div>
                  }
                  <span class="pcard__num">#{i + 6}</span>
                  <div class="pcard__overlay">
                    <span class="pcard__overlay-title">{film.title}</span>
                    {film.year && <span class="pcard__overlay-year">{film.year}</span>}
                  </div>
                </a>
              );
            })}
          </div>
        )}
      </div>
    </section>
  )}

  <!-- ─── Film grid — poster-based tiers ──────────────────────────────────── -->
  {allFilms.length > 0 ? (
    <section class="color-films">
      <div class="site-container">
        <div class="color-films__header reveal">
          <h2 class="color-films__heading">Películas en este color</h2>
          <span class="color-films__count">{allFilms.length} obras</span>
        </div>

        {films.canon.length > 0 && (
          <div class="color-films__tier reveal">
            <div class="color-films__tier-label">
              <span class="tier-badge tier-badge--canon">Canon</span>
            </div>
            <div class="color-poster-grid">
              {films.canon.map((film) => {
                const filmSlug = film.id.replace(/^work_/, '');
                return (
                  <a href={`/films/${filmSlug}`} class="pcard">
                    {film.tmdb_poster_path
                      ? <img src={`${TMDB_SM}${film.tmdb_poster_path}`} alt={film.title} loading="lazy" decoding="async" />
                      : <div class="pcard__fallback" style={`background: ${doctrine.hex}`}>
                          <span>{film.title}</span>
                        </div>
                    }
                    <div class="pcard__overlay">
                      <span class="pcard__overlay-title">{film.title}</span>
                      {film.year && <span class="pcard__overlay-year">{film.year}</span>}
                    </div>
                  </a>
                );
              })}
            </div>
          </div>
        )}

        {films.core.length > 0 && (
          <div class="color-films__tier reveal">
            <div class="color-films__tier-label">
              <span class="tier-badge tier-badge--core">Core</span>
            </div>
            <div class="color-poster-grid">
              {films.core.map((film) => {
                const filmSlug = film.id.replace(/^work_/, '');
                return (
                  <a href={`/films/${filmSlug}`} class="pcard">
                    {film.tmdb_poster_path
                      ? <img src={`${TMDB_SM}${film.tmdb_poster_path}`} alt={film.title} loading="lazy" decoding="async" />
                      : <div class="pcard__fallback" style={`background: ${doctrine.hex}`}>
                          <span>{film.title}</span>
                        </div>
                    }
                    <div class="pcard__overlay">
                      <span class="pcard__overlay-title">{film.title}</span>
                      {film.year && <span class="pcard__overlay-year">{film.year}</span>}
                    </div>
                  </a>
                );
              })}
            </div>
          </div>
        )}

        {films.strong.length > 0 && (
          <div class="color-films__tier reveal">
            <div class="color-films__tier-label">
              <span class="tier-badge tier-badge--strong">Strong</span>
            </div>
            <div class="color-poster-grid">
              {films.strong.map((film) => {
                const filmSlug = film.id.replace(/^work_/, '');
                return (
                  <a href={`/films/${filmSlug}`} class="pcard">
                    {film.tmdb_poster_path
                      ? <img src={`${TMDB_SM}${film.tmdb_poster_path}`} alt={film.title} loading="lazy" decoding="async" />
                      : <div class="pcard__fallback" style={`background: ${doctrine.hex}`}>
                          <span>{film.title}</span>
                        </div>
                    }
                    <div class="pcard__overlay">
                      <span class="pcard__overlay-title">{film.title}</span>
                      {film.year && <span class="pcard__overlay-year">{film.year}</span>}
                    </div>
                  </a>
                );
              })}
            </div>
          </div>
        )}

        {films.peripheral.length > 0 && (
          <div class="color-films__tier reveal">
            <div class="color-films__tier-label">
              <span class="tier-badge tier-badge--peripheral">Peripheral</span>
            </div>
            <div class="color-poster-grid">
              {films.peripheral.map((film) => {
                const filmSlug = film.id.replace(/^work_/, '');
                return (
                  <a href={`/films/${filmSlug}`} class="pcard">
                    {film.tmdb_poster_path
                      ? <img src={`${TMDB_SM}${film.tmdb_poster_path}`} alt={film.title} loading="lazy" decoding="async" />
                      : <div class="pcard__fallback" style={`background: ${doctrine.hex}`}>
                          <span>{film.title}</span>
                        </div>
                    }
                    <div class="pcard__overlay">
                      <span class="pcard__overlay-title">{film.title}</span>
                      {film.year && <span class="pcard__overlay-year">{film.year}</span>}
                    </div>
                  </a>
                );
              })}
            </div>
          </div>
        )}
      </div>
    </section>
  ) : (
    <section class="color-films">
      <div class="site-container">
        <p class="color-films__empty">Aún no hay películas asignadas a este color.</p>
      </div>
    </section>
  )}

  <!-- ─── Reference examples ──────────────────────────────────────────────── -->
  {doctrine.reference_examples.length > 0 && (
    <section class="color-refs">
      <div class="site-container">
        <div class="color-refs__inner">
          <div class="section-label color-refs__label reveal">Ejemplos de referencia</div>
          <p class="color-refs__note reveal" data-delay="60">Ilustrativos únicamente — no son asignaciones canónicas.</p>
          <ul class="color-refs__list">
            {doctrine.reference_examples.map((ex, i) => (
              <li class="color-refs__item reveal" data-delay={String(i * 40)}>{ex}</li>
            ))}
          </ul>
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
/* ─── Color Hero ─────────────────────────────────────────────────────────── */
.color-hero {
  position: relative;
  min-height: min(95vh, 680px);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding-bottom: var(--space-12);
  overflow: hidden;
}

.color-hero__wash {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    145deg,
    var(--c-hex) 0%,
    color-mix(in srgb, var(--c-hex) 60%, #0D0D0F) 40%,
    color-mix(in srgb, var(--c-hex) 20%, #0D0D0F) 75%,
    #0A0A0F 100%
  );
}

/* Left edge accent bar — ColorsxStudios color identity line */
.color-hero__edge {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 3px;
  opacity: 0.7;
}

.color-hero__inner {
  position: relative;
  z-index: 1;
  padding-top: var(--space-20);
}

.color-hero__overline {
  font-size: var(--text-xs);
  font-weight: var(--weight-semi);
  letter-spacing: var(--tracking-widest);
  text-transform: uppercase;
  color: var(--c-sub);
  margin-bottom: var(--space-4);
}

/* Massive serif name — display-scale headline */
.color-hero__name {
  font-family: var(--font-serif);
  font-size: clamp(3.5rem, 10vw, 7rem);
  font-weight: 400;
  line-height: 1.0;
  letter-spacing: -0.025em;
  color: var(--c-text);
  margin-bottom: var(--space-4);
  animation: colorHeroIn 0.65s cubic-bezier(0.16, 1, 0.3, 1) both;
}

@keyframes colorHeroIn {
  from { opacity: 0; transform: translateY(24px); }
  to   { opacity: 1; transform: translateY(0); }
}

.color-hero__hex {
  font-family: var(--font-mono);
  font-size: 0.8rem;
  color: var(--c-sub);
  letter-spacing: 0.12em;
  margin-bottom: var(--space-6);
}

.color-hero__context {
  font-size: 1.05rem;
  line-height: 1.7;
  color: var(--c-sub);
  max-width: 52ch;
  margin-bottom: var(--space-6);
  font-style: italic;
  animation: colorHeroIn 0.65s cubic-bezier(0.16, 1, 0.3, 1) both 0.12s;
}

.color-hero__moods {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
  animation: colorHeroIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) both 0.22s;
}

.color-hero__mood {
  font-size: var(--text-xs);
  font-weight: var(--weight-medium);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 0.28rem 0.7rem;
  border: 1px solid color-mix(in srgb, var(--c-text) 20%, transparent);
  border-radius: var(--radius-sm);
  color: var(--c-sub);
  backdrop-filter: blur(4px);
}

/* ─── Cinematographic notes ──────────────────────────────────────────────── */
.color-notes {
  padding: var(--space-12) 0;
  border-bottom: 1px solid var(--surface-border);
}

.color-notes__inner {
  max-width: var(--grid-content);
  display: flex;
  flex-direction: column;
  gap: var(--space-5);
}

.color-notes__text {
  font-size: 1.05rem;
  line-height: 1.85;
  color: var(--text-secondary);
}

.color-notes__sigs {
  display: flex;
  align-items: baseline;
  gap: 1rem;
  flex-wrap: wrap;
}

.color-notes__sigs-label {
  font-size: var(--text-xs);
  font-weight: var(--weight-semi);
  letter-spacing: var(--tracking-wider);
  text-transform: uppercase;
  color: var(--text-muted);
  flex-shrink: 0;
}

.color-notes__sigs-names {
  font-size: var(--text-base);
  color: var(--text-secondary);
}

.color-notes__sigs-link {
  color: var(--text-secondary);
  text-decoration: none;
  border-bottom: 1px solid rgba(255,255,255,0.12);
  transition: color 140ms ease, border-color 140ms ease;
}
.color-notes__sigs-link:hover {
  color: var(--text-primary);
  border-bottom-color: rgba(255,255,255,0.35);
}

/* ─── Poster ranking ─────────────────────────────────────────────────────── */
.poster-ranking {
  padding: var(--space-12) 0 var(--space-6);
}

.poster-ranking__label {
  margin-bottom: var(--space-6);
}

.poster-row {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: var(--space-4);
  margin-bottom: var(--space-4);
}

.poster-row--secondary {
  opacity: 0.85;
}

/* ─── pcard: poster card used in ranking + tier grids ───────────────────── */
.pcard {
  position: relative;
  display: block;
  aspect-ratio: 2 / 3;
  border-radius: var(--radius-md);
  overflow: hidden;
  text-decoration: none;
  background: var(--bg-raised);
  box-shadow: var(--shadow-card);
  transition:
    transform var(--dur-base) var(--ease-editorial),
    box-shadow var(--dur-base) var(--ease-editorial);
  will-change: transform;
}

.pcard:hover {
  transform: translateY(-4px) scale(1.015);
  box-shadow: var(--shadow-raised);
}

.pcard img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  display: block;
  transition: transform var(--dur-slow) var(--ease-editorial);
}

.pcard:hover img {
  transform: scale(1.04);
}

.pcard__fallback {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0.75rem;
}

.pcard__fallback span {
  font-size: 0.72rem;
  color: rgba(255,255,255,0.7);
  text-align: center;
  line-height: 1.4;
}

.pcard__num {
  position: absolute;
  top: 0.5rem;
  left: 0.5rem;
  font-family: var(--font-mono);
  font-size: 0.62rem;
  color: rgba(255,255,255,0.6);
  text-shadow: 0 1px 4px rgba(0,0,0,0.7);
  pointer-events: none;
}

.pcard__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.88) 0%, rgba(0,0,0,0.3) 40%, transparent 65%);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 0.625rem 0.75rem 0.75rem;
  opacity: 0;
  transform: translateY(3px);
  transition: opacity var(--dur-base) var(--ease-editorial), transform var(--dur-base) var(--ease-editorial);
}

.pcard:hover .pcard__overlay {
  opacity: 1;
  transform: translateY(0);
}

.pcard__overlay-title {
  font-family: var(--font-sans);
  font-size: 0.72rem;
  color: #F0EEE8;
  line-height: 1.3;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.pcard__overlay-year {
  font-family: var(--font-mono);
  font-size: 0.6rem;
  color: rgba(240,238,232,0.6);
  margin-top: 0.2rem;
}

/* ─── Film tier grids (poster-based) ─────────────────────────────────────── */
.color-films {
  padding: var(--space-12) 0;
}

.color-films__header {
  display: flex;
  align-items: baseline;
  gap: var(--space-5);
  margin-bottom: var(--space-10);
}

.color-films__heading {
  font-family: var(--font-serif);
  font-size: clamp(1.5rem, 3vw, 2rem);
  font-weight: 400;
  color: var(--text-primary);
  letter-spacing: -0.01em;
}

.color-films__count {
  font-size: var(--text-xs);
  color: var(--text-muted);
  letter-spacing: var(--tracking-wide);
}

