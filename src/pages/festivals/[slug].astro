---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { isSupabaseConfigured, createServiceClient } from '../../lib/db/client';
import { isoToFlag, isoToName } from '../../lib/countries';
import { getPaletteEntry } from '../../lib/color/colorPalette';
import type { PrismaColorId } from '../../lib/db/types';
import { getFestivalLogoUrl, getFestivalMonogram, isFestivalLogoLocal } from '../../lib/festivalUtils';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/404');

const festivalId = `festival_${slug}`;

if (!isSupabaseConfigured()) return Astro.redirect('/festivals');

const db = createServiceClient();

// ── 1. Festival metadata ──────────────────────────────────────────────────────
const { data: festRow, error: festErr } = await (db as any)
  .from('festivals')
  .select('id, name, name_local, country, city, founded_year, tier, description, website, is_active, logo_path')
  .eq('id', festivalId)
  .single();

if (festErr || !festRow) return Astro.redirect('/404');

const festival = festRow as unknown as {
  id: string;
  name: string;
  name_local: string | null;
  country: string | null;
  city: string | null;
  founded_year: number | null;
  tier: 'A' | 'B' | 'C' | 'D' | null;
  description: string | null;
  website: string | null;
  is_active: boolean;
  logo_path: string | null;
};

// ── 2. All work_awards for this festival ──────────────────────────────────────
const { data: waData } = await db
  .from('work_awards')
  .select(`
    id,
    result,
    year,
    work_id,
    award_id,
    awards!inner(id, name, scoring_points, is_grand_prize, festival_id),
    works(id, title, year, tmdb_poster_path, color_assignments(color_iconico))
  `)
  .eq('awards.festival_id', festivalId)
  .order('year', { ascending: false })
  .limit(1000);

type AwardRow = {
  id: number;
  result: 'win' | 'nomination';
  year: number | null;
  work_id: string;
  award_id: string;
  awards: { id: string; name: string; scoring_points: number; is_grand_prize: boolean };
  works: {
    id: string;
    title: string;
    year: number | null;
    tmdb_poster_path: string | null;
    color_assignments: { color_iconico: PrismaColorId } | { color_iconico: PrismaColorId }[] | null;
  } | null;
};

const rows = (waData ?? []) as unknown as AwardRow[];
const wins = rows.filter(r => r.result === 'win');
const noms = rows.filter(r => r.result === 'nomination');

// ── 3. Stats ─────────────────────────────────────────────────────────────────
const uniqueFilms = new Set(rows.map(r => r.work_id));
const totalWins = wins.length;
const totalNoms = noms.length;

// ── 4. Top 5 winners (poster grid) ───────────────────────────────────────────
const TMDB_IMG = 'https://image.tmdb.org/t/p/w342';

// Distinct winning works, sorted by year desc
const seenWinWorks = new Set<string>();
const topWinners: AwardRow[] = [];
for (const r of wins) {
  if (!r.works?.tmdb_poster_path) continue;
  if (seenWinWorks.has(r.work_id)) continue;
  seenWinWorks.add(r.work_id);
  topWinners.push(r);
  if (topWinners.length >= 5) break;
}

// ── 5. Awards history — group by award name, sorted by scoring_points desc ───
type AwardGroup = {
  awardId: string;
  awardName: string;
  isGrandPrize: boolean;
  wins: AwardRow[];
  noms: AwardRow[];
};

const awardGroupMap = new Map<string, AwardGroup>();
for (const r of rows) {
  const aid = r.award_id;
  if (!awardGroupMap.has(aid)) {
    awardGroupMap.set(aid, {
      awardId: aid,
      awardName: r.awards.name,
      isGrandPrize: r.awards.is_grand_prize,
      wins: [],
      noms: [],
    });
  }
  if (r.result === 'win') awardGroupMap.get(aid)!.wins.push(r);
  else awardGroupMap.get(aid)!.noms.push(r);
}

// Sort award groups: grand prize first, then by win count desc, then by points desc
const awardGroups = [...awardGroupMap.values()].sort((a, b) => {
  if (a.isGrandPrize !== b.isGrandPrize) return a.isGrandPrize ? -1 : 1;
  return b.wins.length - a.wins.length;
});

function filmSlug(workId: string) {
  return workId.replace(/^work_/, '');
}

function getColor(work: AwardRow['works']): PrismaColorId | null {
  if (!work) return null;
  const ca = Array.isArray(work.color_assignments)
    ? work.color_assignments[0]
    : work.color_assignments;
  return ca?.color_iconico ?? null;
}

const flag = festival.country ? isoToFlag(festival.country) : '🎬';
const countryName = festival.country ? isoToName(festival.country) : '';
const festLogoUrl = getFestivalLogoUrl(festival.logo_path);
const festLogoIsLocal = isFestivalLogoLocal(festival.logo_path);
const festMonogram = getFestivalMonogram(festival.name);
---

<BaseLayout
  title={`${festival.name} — PRISMA`}
  description={festival.description ?? `${festival.name} — films and awards in the PRISMA catalog.`}
>
  <div class="festival-page page-enter">

    <!-- ── Header ── -->
    <section class="fest-header">
      <div class="site-container">
        <div class="fest-header__inner">

          <div class="fest-header__logo-wrap">
            {festLogoUrl
              ? <img src={festLogoUrl} alt="" class={`fest-header__logo${festLogoIsLocal ? ' festival-logo--local' : ''}`} loading="eager" />
              : <div class="fest-header__monogram" aria-hidden="true">{festMonogram}</div>
            }
            <span class="fest-header__flag" aria-hidden="true">{flag}</span>
          </div>

          <div class="fest-header__info">
            <div class="fest-header__overline">
              {festival.city && <span>{festival.city}</span>}
              {festival.city && countryName && <span aria-hidden="true">·</span>}
              {countryName && <span>{countryName}</span>}
              {festival.founded_year && (
                <>
                  <span aria-hidden="true">·</span>
                  <span>est. {festival.founded_year}</span>
                </>
              )}
              {festival.tier && (
                <span class="fest-tier-badge">[{festival.tier}]</span>
              )}
            </div>

            <h1 class="fest-header__title">{festival.name}</h1>

            {festival.name_local && festival.name_local !== festival.name && (
              <p class="fest-header__local">{festival.name_local}</p>
            )}

            {festival.description && (
              <p class="fest-header__desc">{festival.description}</p>
            )}

            <div class="fest-header__links">
              {festival.website && (
                <a href={festival.website} target="_blank" rel="noopener noreferrer" class="fest-website-link">
                  Official website ↗
                </a>
              )}
            </div>
          </div>
        </div>

        <!-- Stats bar -->
        {rows.length > 0 && (
          <div class="fest-stats">
            <span class="fest-stat"><strong>{totalWins}</strong> wins in catalog</span>
            <span class="fest-stat-sep" aria-hidden="true">·</span>
            <span class="fest-stat"><strong>{totalNoms}</strong> nominations</span>
            <span class="fest-stat-sep" aria-hidden="true">·</span>
            <span class="fest-stat"><strong>{uniqueFilms.size}</strong> films</span>
          </div>
        )}
      </div>
    </section>

    {rows.length === 0 ? (
      <div class="site-container fest-empty">
        <p>No films from this festival in the catalog yet.</p>
      </div>
    ) : (
      <>
        <!-- ── Winners poster row ── -->
        {topWinners.length > 0 && (
          <section class="fest-posters">
            <div class="site-container">
              <div class="sect-label">Winners in Catalog</div>
              <div class="poster-row">
                {topWinners.map((r, i) => {
                  const colorId = getColor(r.works);
                  const palette = colorId ? getPaletteEntry(colorId) : null;
                  return (
                    <a href={`/films/${filmSlug(r.work_id)}`} class="poster-card">
                      <img
                        src={`${TMDB_IMG}${r.works!.tmdb_poster_path}`}
                        alt={r.works!.title}
                        class="poster-card__img"
                        loading="lazy"
                        decoding="async"
                      />
                      <span class="poster-card__num">#{i + 1}</span>
                      <div class="poster-card__overlay">
                        <span class="poster-card__overlay-title">{r.works!.title}</span>
                        {r.works!.year && (
                          <span class="poster-card__overlay-year">{r.works!.year}</span>
                        )}
                        <span class="poster-card__overlay-award">{r.awards.name}</span>
                        {palette && (
                          <span class="poster-card__overlay-color" style={`color: ${palette.hex}`}>
                            {palette.name}
                          </span>
                        )}
                      </div>
                    </a>
                  );
                })}
              </div>
            </div>
          </section>
        )}

        <!-- ── Awards history ── -->
        <section class="fest-history">
          <div class="site-container">
            <h2 class="sect-label">Awards History</h2>
            <div class="award-groups">
              {awardGroups.map(group => (
                <div class="award-group">
                  <h3 class="award-group__name">
                    {group.isGrandPrize && <span class="award-group__star" aria-hidden="true">★</span>}
                    {group.awardName}
                    <span class="award-group__counts">
                      {group.wins.length > 0 && <span class="count-win">{group.wins.length}W</span>}
                      {group.noms.length > 0 && <span class="count-nom">{group.noms.length}N</span>}
                    </span>
                  </h3>

                  <ul class="award-rows" role="list">
                    {/* Wins first */}
                    {[...group.wins].sort((a, b) => (b.year ?? 0) - (a.year ?? 0)).map(r => (
                      <li class="award-row award-row--win">
                        <span class="award-row__year">{r.year ?? '—'}</span>
                        {r.works ? (
                          <a href={`/films/${filmSlug(r.work_id)}`} class="award-row__title">
                            {r.works.title}
                          </a>
                        ) : (
                          <span class="award-row__title award-row__title--unknown">{r.work_id}</span>
                        )}
                        <span class="award-row__badge award-row__badge--win">WIN</span>
                      </li>
                    ))}
                    {/* Nominations */}
                    {[...group.noms].sort((a, b) => (b.year ?? 0) - (a.year ?? 0)).map(r => (
                      <li class="award-row award-row--nom">
                        <span class="award-row__year">{r.year ?? '—'}</span>
                        {r.works ? (
                          <a href={`/films/${filmSlug(r.work_id)}`} class="award-row__title">
                            {r.works.title}
                          </a>
                        ) : (
                          <span class="award-row__title award-row__title--unknown">{r.work_id}</span>
                        )}
                        <span class="award-row__badge award-row__badge--nom">NOM</span>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </div>
        </section>
      </>
    )}

  </div>
</BaseLayout>

<style>
.festival-page {
  padding-bottom: 6rem;
}

/* ── Header ── */
.fest-header {
  padding-top: 8rem;
  padding-bottom: 3rem;
  border-bottom: 1px solid var(--surface-border);
}

.fest-header__inner {
  display: flex;
  gap: 2rem;
  align-items: flex-start;
  margin-bottom: 2rem;
}

.fest-header__logo-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
  flex-shrink: 0;
}

.fest-header__flag {
  font-size: 1.5rem;
  line-height: 1;
}

.fest-header__logo {
  width: 96px;
  height: 96px;
  object-fit: contain;
  padding-top: 0.5rem;
}

.festival-logo--local {
  filter: invert(1) brightness(2);
  opacity: 0.9;
}

.fest-header__monogram {
  width: 80px;
  height: 80px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border-radius: 6px;
  background: rgba(201, 138, 46, 0.1);
  border: 1px solid rgba(201, 138, 46, 0.2);
  font-family: var(--font-mono);
  font-size: 1.5rem;
  font-weight: 700;
  color: #C98A2E;
  letter-spacing: 0.02em;
}

.fest-header__overline {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
  align-items: center;
  font-family: var(--font-mono);
  font-size: 0.7rem;
  color: var(--text-muted);
  margin-bottom: 0.625rem;
}

.fest-tier-badge {
  font-weight: 700;
  color: #C98A2E;
}

.fest-header__title {
  font-family: var(--font-serif);
  font-size: clamp(1.75rem, 4vw, 3rem);
  font-weight: 400;
  color: var(--text-primary);
  margin-bottom: 0.375rem;
}

.fest-header__local {
  font-size: 0.875rem;
  color: var(--text-muted);
  font-style: italic;
  margin-bottom: 0.875rem;
}

.fest-header__desc {
  font-size: 0.9rem;
  color: var(--text-secondary);
  line-height: 1.65;
  max-width: 56ch;
  margin-bottom: 1rem;
}

.fest-website-link {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  color: var(--text-muted);
  text-decoration: none;
  transition: color 140ms ease;
}
.fest-website-link:hover { color: var(--text-secondary); }

/* ── Stats bar ── */
.fest-stats {
  display: flex;
  align-items: center;
  gap: 0.625rem;
  font-family: var(--font-mono);
  font-size: 0.72rem;
  color: var(--text-muted);
}
.fest-stats strong { color: var(--text-secondary); }
.fest-stat-sep { opacity: 0.4; }

/* ── Poster row (reused from countries) ── */
.fest-posters {
  padding: 3rem 0 0;
}

.sect-label {
  font-family: var(--font-sans);
  font-size: 0.65rem;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 1rem;
}

.poster-row {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 1rem;
}

.poster-card {
  position: relative;
  display: block;
  aspect-ratio: 2 / 3;
  border-radius: 3px;
  overflow: hidden;
  text-decoration: none;
  background: var(--surface-card);
}

.poster-card__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  display: block;
  transition: transform 220ms ease;
}
.poster-card:hover .poster-card__img { transform: scale(1.03); }

.poster-card__num {
  position: absolute;
  top: 0.5rem;
  left: 0.5rem;
  font-family: var(--font-mono);
  font-size: 0.65rem;
  color: rgba(255,255,255,0.55);
  pointer-events: none;
  text-shadow: 0 1px 3px rgba(0,0,0,0.6);
}

.poster-card__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.3) 45%, transparent 70%);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 0.625rem;
  opacity: 0;
  transform: translateY(4px);
  transition: opacity 180ms ease, transform 180ms ease;
}
.poster-card:hover .poster-card__overlay { opacity: 1; transform: translateY(0); }

.poster-card__overlay-title {
  font-size: 0.72rem;
  color: #F0EEE8;
  line-height: 1.3;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.poster-card__overlay-year {
  font-size: 0.62rem;
  color: rgba(240,238,232,0.6);
  margin-top: 0.2rem;
  font-family: var(--font-mono);
}

.poster-card__overlay-award {
  font-size: 0.6rem;
  color: #C98A2E;
  margin-top: 0.15rem;
  font-family: var(--font-mono);
  letter-spacing: 0.04em;
}

.poster-card__overlay-color {
  font-size: 0.58rem;
  margin-top: 0.15rem;
  opacity: 0.8;
  font-family: var(--font-mono);
}

/* ── Awards history ── */
.fest-history {
  padding: 3rem 0 0;
}

.award-groups {
  display: flex;
  flex-direction: column;
  gap: 2.5rem;
}

.award-group__name {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-family: var(--font-serif);
  font-size: 1.1rem;
  font-weight: 400;
  color: var(--text-primary);
  margin-bottom: 0.875rem;
}

.award-group__star {
  color: #C98A2E;
  font-size: 0.9rem;
}

.award-group__counts {
  display: flex;
  gap: 0.375rem;
  margin-left: auto;
}

.count-win {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  color: #C98A2E;
  font-weight: 600;
}

.count-nom {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  color: var(--text-muted);
}

.award-rows {
  list-style: none;
  padding: 0;
  margin: 0;
  border-top: 1px solid var(--surface-border);
}

.award-row {
  display: grid;
  grid-template-columns: 3.5rem 1fr auto;
  align-items: center;
  gap: 1rem;
  padding: 0.55rem 0;
  border-bottom: 1px solid var(--surface-border);
}

.award-row__year {
  font-family: var(--font-mono);
  font-size: 0.75rem;
  color: var(--text-muted);
}

.award-row__title {
  font-size: 0.875rem;
  color: var(--text-secondary);
  text-decoration: none;
  transition: color 140ms ease;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
a.award-row__title:hover { color: var(--text-primary); }

.award-row__title--unknown {
  font-size: 0.75rem;
  color: var(--text-muted);
  font-style: italic;
}

.award-row__badge {
  font-family: var(--font-mono);
  font-size: 0.58rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  padding: 0.15rem 0.35rem;
  border-radius: 2px;
}

.award-row__badge--win {
  color: #C98A2E;
  background: rgba(201, 138, 46, 0.12);
}

.award-row__badge--nom {
  color: var(--text-muted);
  background: var(--surface-elevated);
}

/* ── Empty state ── */
.fest-empty {
  padding: 3rem 0;
  font-size: 0.875rem;
  color: var(--text-muted);
  font-style: italic;
}

/* ── Responsive ── */
@media (max-width: 640px) {
  .poster-row {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    gap: 0.625rem;
    padding-bottom: 0.5rem;
    scrollbar-width: none;
  }
  .poster-row::-webkit-scrollbar { display: none; }
  .poster-card {
    width: 140px;
    min-width: 140px;
    scroll-snap-align: start;
  }

  .fest-header__inner { flex-direction: column; gap: 1rem; }
  .fest-header__logo { width: 64px; height: 64px; }
  .fest-header__monogram { width: 56px; height: 56px; }
  .award-row { grid-template-columns: 3rem 1fr auto; gap: 0.625rem; }
}
</style>
