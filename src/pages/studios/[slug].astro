---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPaletteEntry } from '../../lib/color/colorPalette';
import { isSupabaseConfigured, createServiceClient } from '../../lib/db/client';
import { isoToFlag, isoToName } from '../../lib/countries';
import fs from 'node:fs';
import path from 'node:path';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/404');

const studioId = `studio_${slug}`;

// ── Types ─────────────────────────────────────────────────────────────────────

interface StudioData {
  id: string;
  name: string;
  country?: string | null;
  founded_year?: number | null;
  tmdb_id?: number | null;
  logo_path?: string | null;
}

interface FilmEntry {
  id: string;
  title: string;
  year: number | null;
  color_iconico?: string | null;
  tier?: string | null;
  tmdb_poster_path?: string | null;
  numeric_score?: number | null;
}

// ── Load studio ───────────────────────────────────────────────────────────────

let studio: StudioData | null = null;
let films: FilmEntry[] = [];

if (isSupabaseConfigured()) {
  try {
    const db = createServiceClient();
    const { data: studioData } = await db
      .from('studios')
      .select('id, name, country, founded_year, tmdb_id, logo_path')
      .eq('id', studioId)
      .maybeSingle();

    if (studioData) {
      studio = studioData as StudioData;

      const { data: filmData } = await db
        .from('work_studios')
        .select(`
          works!inner(
            id, title, year, is_published, tmdb_poster_path,
            color_assignments(color_iconico, tier, numeric_score)
          )
        `)
        .eq('studio_id', studioId)
        .eq('works.is_published', true);

      films = ((filmData ?? []) as unknown[]).map((row: unknown) => {
        const r = row as {
          works: {
            id: string;
            title: string;
            year: number | null;
            tmdb_poster_path: string | null;
            color_assignments: Array<{
              color_iconico: string | null;
              tier: string | null;
              numeric_score: number | null;
            }> | null;
          };
        };
        const ca = r.works.color_assignments?.[0] ?? null;
        return {
          id:               r.works.id,
          title:            r.works.title,
          year:             r.works.year,
          color_iconico:    ca?.color_iconico ?? null,
          tier:             ca?.tier ?? null,
          tmdb_poster_path: r.works.tmdb_poster_path ?? null,
          numeric_score:    ca?.numeric_score ?? null,
        };
      });
    }
  } catch {
    // Fall through to filesystem
  }
}

// ── Filesystem fallback ───────────────────────────────────────────────────────

if (!studio) {
  const studioPath = path.resolve(`pipeline/normalized/studios/${studioId}.json`);
  if (fs.existsSync(studioPath)) {
    try {
      const raw = JSON.parse(fs.readFileSync(studioPath, 'utf-8'));
      studio = { id: raw.id, name: raw.name, country: raw.country, founded_year: raw.founded_year };
    } catch {
      // ignore
    }
  }
}

if (studio && films.length === 0) {
  const worksDir = path.resolve('pipeline/normalized/works');
  if (fs.existsSync(worksDir)) {
    for (const file of fs.readdirSync(worksDir).filter((f) => f.endsWith('.json'))) {
      try {
        const work = JSON.parse(fs.readFileSync(path.join(worksDir, file), 'utf-8'));
        const studios: string[] = work.studios ?? [];
        if (studios.includes(studioId)) {
          const palette = work.prisma_palette as { primary?: string } | null;
          films.push({
            id: work.id, title: work.title, year: work.year ?? null,
            color_iconico: palette?.primary ?? null, tier: null,
            tmdb_poster_path: null, numeric_score: null,
          });
        }
      } catch { /* skip */ }
    }
  }
}

if (!studio) return Astro.redirect('/404');

// ── Derived ───────────────────────────────────────────────────────────────────

// Poster grid: top 5 films with posters, sorted by score
const topFilms = [...films]
  .filter(f => f.tmdb_poster_path)
  .sort((a, b) => (b.numeric_score ?? 0) - (a.numeric_score ?? 0))
  .slice(0, 5);

// Film list: all films sorted by year desc
films.sort((a, b) => (b.year ?? 0) - (a.year ?? 0));

// Studio logo
const TMDB_IMG = 'https://image.tmdb.org/t/p';
const logoUrl = studio.logo_path ? `${TMDB_IMG}/w300${studio.logo_path}` : null;

function getStudioMonogram(name: string): string {
  return name.split(/\s+/).slice(0, 3).map(w => w[0]?.toUpperCase() ?? '').join('');
}
const monogram = getStudioMonogram(studio.name);
const flag = studio.country ? isoToFlag(studio.country) : null;
const countryName = studio.country ? isoToName(studio.country) : null;

const pageTitle = `${studio.name} — PRISMA`;
const pageDescription = `${studio.name}${countryName ? ` (${countryName})` : ''}${studio.founded_year ? `, fundado en ${studio.founded_year}` : ''} — ${films.length} película${films.length !== 1 ? 's' : ''} en el catálogo PRISMA.`;

const SITE = 'https://prisma.film';

const studioBreadcrumbs = [
  { name: 'PRISMA', url: SITE },
  { name: 'Estudios', url: SITE },
  { name: studio.name, url: `${SITE}/studios/${slug}` },
];

const studioJsonLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: studio.name,
  url: `${SITE}/studios/${slug}`,
  ...(logoUrl ? { logo: logoUrl } : {}),
  ...(countryName ? { location: { '@type': 'Place', name: countryName } } : {}),
  ...(studio.founded_year ? { foundingDate: String(studio.founded_year) } : {}),
};
---

<BaseLayout title={pageTitle} description={pageDescription} ogImage={logoUrl ?? undefined} jsonLd={studioJsonLd} breadcrumbs={studioBreadcrumbs}>
  <div class="studio-page page-enter">

    <!-- ── Header ── -->
    <section class="studio-header">
      <div class="site-container">
        <div class="studio-header__inner">

          <!-- Logo or monogram -->
          <div class="studio-header__logo-wrap">
            {logoUrl
              ? <img src={logoUrl} alt="" class="studio-header__logo" loading="eager" />
              : <div class="studio-header__monogram" aria-hidden="true">{monogram}</div>
            }
            {flag && <span class="studio-header__flag" aria-hidden="true">{flag}</span>}
          </div>

          <div class="studio-header__info">
            <p class="studio-header__overline">Production Studio</p>
            <h1 class="studio-header__name">{studio.name}</h1>
            <div class="studio-header__meta">
              {countryName && (
                <span class="studio-header__meta-item">{countryName}</span>
              )}
              {studio.founded_year && (
                <span class="studio-header__meta-item">Fund. {studio.founded_year}</span>
              )}
              {films.length > 0 && (
                <span class="studio-header__meta-item">
                  {films.length} {films.length === 1 ? 'película' : 'películas'} en catálogo
                </span>
              )}
            </div>
          </div>
        </div>
      </div>
    </section>

    {films.length === 0 ? (
      <section class="studio-empty">
        <div class="site-container">
          <p class="studio-empty__text">Aún no hay películas de este estudio en el catálogo.</p>
        </div>
      </section>
    ) : (
      <>
        <!-- ── Poster grid (top 5 by score) ── -->
        {topFilms.length > 0 && (
          <section class="studio-posters">
            <div class="site-container">
              <div class="sect-label">Películas Destacadas</div>
              <div class="poster-row">
                {topFilms.map((film, i) => {
                  const filmSlug = film.id.replace(/^work_/, '');
                  const palette = film.color_iconico ? getPaletteEntry(film.color_iconico) : null;
                  return (
                    <a href={`/films/${filmSlug}`} class="poster-card">
                      <img
                        src={`${TMDB_IMG}/w342${film.tmdb_poster_path}`}
                        alt={film.title}
                        class="poster-card__img"
                        loading="lazy"
                        decoding="async"
                      />
                      <span class="poster-card__num">#{i + 1}</span>
                      <div class="poster-card__overlay">
                        <span class="poster-card__overlay-title">{film.title}</span>
                        {film.year && (
                          <span class="poster-card__overlay-year">{film.year}</span>
                        )}
                        {palette && (
                          <span class="poster-card__overlay-color" style={`color: ${palette.hex}`}>
                            {palette.name}
                          </span>
                        )}
                      </div>
                    </a>
                  );
                })}
              </div>
            </div>
          </section>
        )}

        <!-- ── Full film list ── -->
        <section class="studio-films">
          <div class="site-container">
            <div class="studio-films__list">
              {films.map((film) => {
                const filmSlug = film.id.replace(/^work_/, '');
                const palette = film.color_iconico ? getPaletteEntry(film.color_iconico) : null;
                return (
                  <a href={`/films/${filmSlug}`} class="studio-film-item">
                    <div
                      class="studio-film-item__color-strip"
                      style={palette ? `background: ${palette.hex}` : 'background: var(--surface-border)'}
                    />
                    <span class="studio-film-item__year">{film.year ?? '—'}</span>
                    <span class="studio-film-item__title">{film.title}</span>
                    {palette && (
                      <span class="studio-film-item__color">{palette.name}</span>
                    )}
                  </a>
                );
              })}
            </div>
          </div>
        </section>
      </>
    )}

  </div>
</BaseLayout>

<style>
.studio-page {
  padding-bottom: 6rem;
}

/* ── Header ── */
.studio-header {
  padding-top: 8rem;
  padding-bottom: 3rem;
  border-bottom: 1px solid var(--surface-border);
}

.studio-header__inner {
  display: flex;
  gap: 2rem;
  align-items: flex-start;
  max-width: var(--content-max-width);
}

/* Logo / monogram column */
.studio-header__logo-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.625rem;
  flex-shrink: 0;
}

.studio-header__logo {
  height: 80px;
  width: auto;
  max-width: 160px;
  object-fit: contain;
  filter: invert(1) brightness(1.8);
  opacity: 0.85;
}

.studio-header__monogram {
  width: 80px;
  height: 80px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 6px;
  background: rgba(201, 138, 46, 0.08);
  border: 1px solid rgba(201, 138, 46, 0.18);
  font-family: var(--font-mono);
  font-size: 1.4rem;
  font-weight: 700;
  color: #C98A2E;
  letter-spacing: 0.05em;
}

.studio-header__flag {
  font-size: 1.25rem;
  line-height: 1;
}

/* Info column */
.studio-header__info {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
  padding-top: 0.25rem;
}

.studio-header__overline {
  font-size: 0.65rem;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 0.375rem;
}

.studio-header__name {
  font-family: var(--font-serif);
  font-size: clamp(1.75rem, 4vw, 3rem);
  font-weight: 400;
  color: var(--text-primary);
  margin-bottom: 0.75rem;
  line-height: 1.15;
}

.studio-header__meta {
  display: flex;
  gap: 1.5rem;
  flex-wrap: wrap;
}

.studio-header__meta-item {
  font-size: 0.8rem;
  color: var(--text-muted);
}

@media (max-width: 640px) {
  .studio-header__inner { flex-direction: column; gap: 1.25rem; }
  .studio-header__logo-wrap { flex-direction: row; align-items: center; }
  .studio-header__logo { height: 56px; }
  .studio-header__monogram { width: 56px; height: 56px; font-size: 1rem; }
}

/* ── Section label ── */
.sect-label {
  font-family: var(--font-sans);
  font-size: 0.65rem;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 1rem;
}

/* ── Poster grid ── */
.studio-posters {
  padding: 3rem 0 0;
}

.poster-row {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 1rem;
}

.poster-card {
  position: relative;
  display: block;
  aspect-ratio: 2 / 3;
  border-radius: 3px;
  overflow: hidden;
  text-decoration: none;
  background: var(--surface-card);
}

.poster-card__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  display: block;
  transition: transform 220ms ease;
}
.poster-card:hover .poster-card__img { transform: scale(1.03); }

.poster-card__num {
  position: absolute;
  top: 0.5rem;
  left: 0.5rem;
  font-family: var(--font-mono);
  font-size: 0.65rem;
  color: rgba(255,255,255,0.55);
  pointer-events: none;
  text-shadow: 0 1px 3px rgba(0,0,0,0.6);
}

.poster-card__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.3) 45%, transparent 70%);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 0.625rem;
  opacity: 0;
  transform: translateY(4px);
  transition: opacity 180ms ease, transform 180ms ease;
}
.poster-card:hover .poster-card__overlay { opacity: 1; transform: translateY(0); }

.poster-card__overlay-title {
  font-size: 0.72rem;
  color: #F0EEE8;
  line-height: 1.3;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.poster-card__overlay-year {
  font-size: 0.62rem;
  color: rgba(240,238,232,0.6);
  margin-top: 0.2rem;
  font-family: var(--font-mono);
}

.poster-card__overlay-color {
  font-size: 0.58rem;
  margin-top: 0.15rem;
  opacity: 0.8;
  font-family: var(--font-mono);
}

/* ── Film list ── */
.studio-films {
  padding: 3rem 0 0;
}

.studio-films__list {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.studio-film-item {
  display: grid;
  grid-template-columns: 3px 4rem 1fr auto;
  align-items: center;
  gap: 1.25rem;
  padding: 0.875rem 0;
  border-bottom: 1px solid var(--surface-border);
  text-decoration: none;
  transition: background 160ms ease;
}

.studio-film-item:hover {
  background: var(--surface-card);
  padding-left: 0.75rem;
  margin-left: -0.75rem;
  border-radius: 3px;
}

.studio-film-item__color-strip {
  width: 3px;
  height: 2rem;
  border-radius: 1.5px;
}

.studio-film-item__year {
  font-family: var(--font-mono);
  font-size: 0.8rem;
  color: var(--text-muted);
  text-align: right;
}

.studio-film-item__title {
  font-size: 0.9rem;
  color: var(--text-secondary);
  transition: color 160ms ease;
}
.studio-film-item:hover .studio-film-item__title { color: var(--text-primary); }

.studio-film-item__color {
  font-size: 0.7rem;
  color: var(--text-muted);
}

@media (max-width: 640px) {
  .studio-film-item { grid-template-columns: 3px 3.5rem 1fr; }
  .studio-film-item__color { display: none; }
  .poster-row {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    gap: 0.625rem;
    padding-bottom: 0.5rem;
    scrollbar-width: none;
  }
  .poster-row::-webkit-scrollbar { display: none; }
  .poster-card {
    width: 130px;
    min-width: 130px;
    scroll-snap-align: start;
  }
}

/* ── Empty ── */
.studio-empty {
  padding: 4rem 0;
}

.studio-empty__text {
  font-size: 0.9rem;
  color: var(--text-muted);
}
</style>
