---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { isSupabaseConfigured, createServiceClient } from '../../lib/db/client';

// ── Types ─────────────────────────────────────────────────────────────────────

interface StudioRow {
  id: string;
  name: string;
  country: string | null;
  founded_year: number | null;
  logo_path: string | null;
  film_count: number;
}

// ── Data fetch ────────────────────────────────────────────────────────────────

let studios: StudioRow[] = [];
let error = false;

if (isSupabaseConfigured()) {
  try {
    const db = createServiceClient();

    // Fetch all studio→work relationships for published works, then count
    const { data: joinData } = await db
      .from('work_studios')
      .select(`
        studio_id,
        works!inner(is_published)
      `)
      .eq('works.is_published', true);

    if (joinData) {
      // Count films per studio
      const counts: Record<string, number> = {};
      for (const row of joinData as unknown as Array<{ studio_id: string }>) {
        counts[row.studio_id] = (counts[row.studio_id] ?? 0) + 1;
      }

      // Only studios with 2+ films
      const studioIds = Object.entries(counts)
        .filter(([, c]) => c >= 2)
        .map(([id]) => id);

      if (studioIds.length > 0) {
        const { data: studioData } = await db
          .from('studios')
          .select('id, name, country, founded_year, logo_path')
          .in('id', studioIds);

        if (studioData) {
          studios = (studioData as StudioRow[]).map((s) => ({
            ...s,
            film_count: counts[s.id] ?? 0,
          }));

          // Sort: most films first, then alphabetically
          studios.sort((a, b) => {
            if (b.film_count !== a.film_count) return b.film_count - a.film_count;
            return a.name.localeCompare(b.name);
          });
        }
      }
    }
  } catch (e) {
    console.error('[studios/index] fetch error', e);
    error = true;
  }
}

// ── Slug helper (mirrors [slug].astro convention) ─────────────────────────────
function slugFromId(id: string) {
  // id = "studio_warner-bros-pictures" → slug = "warner-bros-pictures"
  return id.replace(/^studio_/, '');
}

const TMDB_LOGO = 'https://image.tmdb.org/t/p/w185';

// Country display helper
const COUNTRY_NAMES: Record<string, string> = {
  US: 'Estados Unidos', FR: 'Francia', JP: 'Japón', GB: 'Reino Unido',
  DE: 'Alemania', IT: 'Italia', ES: 'España', CN: 'China', KR: 'Corea del Sur',
  IN: 'India', MX: 'México', AR: 'Argentina', BR: 'Brasil', RU: 'Rusia',
  AU: 'Australia', CA: 'Canadá', SE: 'Suecia', DK: 'Dinamarca', NO: 'Noruega',
  NL: 'Países Bajos', BE: 'Bélgica', CH: 'Suiza', AT: 'Austria', PL: 'Polonia',
  PT: 'Portugal', RO: 'Rumanía', HU: 'Hungría', CZ: 'República Checa',
  IR: 'Irán', TW: 'Taiwán', HK: 'Hong Kong', TH: 'Tailandia',
  SN: 'Senegal', GH: 'Ghana', NG: 'Nigeria', ZA: 'Sudáfrica',
};
function countryName(iso: string | null) {
  if (!iso) return null;
  return COUNTRY_NAMES[iso.toUpperCase()] ?? iso;
}

// Monogram from studio name
function monogram(name: string) {
  const words = name.split(/\s+/).filter(Boolean);
  if (words.length >= 2) return (words[0][0] + words[1][0]).toUpperCase();
  return name.slice(0, 2).toUpperCase();
}
---

<BaseLayout
  title="Estudios — PRISMA"
  description="Explora las casas productoras y estudios de cine que forman parte de la base de datos cinematográfica PRISMA."
  breadcrumbs={[
    { name: 'PRISMA', url: '/' },
    { name: 'Estudios', url: '/studios' },
  ]}
>
  <main class="studios-index">

    <header class="studios-header">
      <p class="studios-header__eyebrow">Base de datos</p>
      <h1 class="studios-header__title">Estudios</h1>
      <p class="studios-header__desc">
        Casas productoras y distribuidoras con presencia en nuestra colección.
      </p>
    </header>

    {error && (
      <div class="studios-error">
        No se pudo cargar la lista de estudios. Inténtalo de nuevo más tarde.
      </div>
    )}

    {!error && studios.length === 0 && (
      <div class="studios-empty">
        No hay estudios disponibles en este momento.
      </div>
    )}

    {!error && studios.length > 0 && (
      <section class="studios-grid" aria-label="Lista de estudios">
        {studios.map((studio) => {
          const slug = slugFromId(studio.id);
          const logoUrl = studio.logo_path ? `${TMDB_LOGO}${studio.logo_path}` : null;
          const country = countryName(studio.country);

          return (
            <a href={`/studios/${slug}`} class="studio-card" aria-label={`${studio.name} — ${studio.film_count} películas`}>
              <div class="studio-card__logo-wrap">
                {logoUrl ? (
                  <img
                    src={logoUrl}
                    alt={studio.name}
                    class="studio-card__logo"
                    loading="lazy"
                    decoding="async"
                  />
                ) : (
                  <span class="studio-card__monogram">{monogram(studio.name)}</span>
                )}
              </div>

              <div class="studio-card__body">
                <p class="studio-card__name">{studio.name}</p>
                <div class="studio-card__meta">
                  {country && <span class="studio-card__country">{country}</span>}
                  {studio.founded_year && <span class="studio-card__year">Est. {studio.founded_year}</span>}
                </div>
              </div>

              <span class="studio-card__count">
                {studio.film_count} {studio.film_count === 1 ? 'película' : 'películas'}
              </span>
            </a>
          );
        })}
      </section>
    )}

  </main>
</BaseLayout>

<style>
/* ── Layout ── */
.studios-index {
  max-width: 1280px;
  margin: 0 auto;
  padding: 6rem 2rem 5rem;
}

/* ── Header ── */
.studios-header {
  text-align: center;
  margin-bottom: 3.5rem;
}

.studios-header__eyebrow {
  font-size: 0.6875rem;
  font-weight: 500;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin: 0 0 0.75rem;
}

.studios-header__title {
  font-family: var(--font-serif);
  font-size: clamp(2.25rem, 5vw, 3.5rem);
  font-weight: 400;
  margin: 0 0 1rem;
  color: var(--text-primary);
  letter-spacing: -0.02em;
}

.studios-header__desc {
  font-size: 0.9375rem;
  color: var(--text-muted);
  margin: 0;
  max-width: 480px;
  margin-inline: auto;
  line-height: 1.65;
}

/* ── States ── */
.studios-error,
.studios-empty {
  text-align: center;
  color: var(--text-muted);
  padding: 4rem 0;
  font-size: 0.9375rem;
}

/* ── Grid ── */
.studios-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  gap: 1rem;
}

/* ── Studio card ── */
.studio-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1rem;
  padding: 2rem 1.5rem 1.5rem;
  background: var(--surface-card);
  border: 1px solid var(--surface-border);
  border-radius: var(--radius-lg, 12px);
  text-decoration: none;
  transition:
    border-color 160ms ease,
    background 160ms ease,
    transform 160ms ease;
  position: relative;
}

.studio-card:hover {
  border-color: var(--surface-border-strong);
  background: var(--surface-raised, rgba(255,255,255,0.04));
  transform: translateY(-2px);
}

/* ── Logo area ── */
.studio-card__logo-wrap {
  width: 100%;
  height: 64px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.studio-card__logo {
  max-width: 140px;
  max-height: 56px;
  width: auto;
  height: auto;
  object-fit: contain;
  /* Invert for dark bg — TMDB logos are usually dark-on-white */
  filter: invert(1) brightness(0.9);
  opacity: 0.85;
  transition: opacity 160ms ease;
}

.studio-card:hover .studio-card__logo {
  opacity: 1;
}

.studio-card__monogram {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  background: var(--surface-raised, rgba(255,255,255,0.06));
  border: 1px solid var(--surface-border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-serif);
  font-size: 1.25rem;
  font-weight: 400;
  color: var(--text-secondary);
  letter-spacing: 0.04em;
}

/* ── Body ── */
.studio-card__body {
  text-align: center;
  flex: 1;
}

.studio-card__name {
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--text-primary);
  margin: 0 0 0.375rem;
  line-height: 1.3;
}

.studio-card__meta {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  flex-wrap: wrap;
}

.studio-card__country,
.studio-card__year {
  font-size: 0.7rem;
  color: var(--text-muted);
  letter-spacing: 0.04em;
}

.studio-card__country::after {
  content: '·';
  margin-left: 0.5rem;
  opacity: 0.5;
}

.studio-card__country:last-child::after {
  display: none;
}

/* ── Film count badge ── */
.studio-card__count {
  font-size: 0.6875rem;
  font-weight: 500;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--text-accent, rgba(212,201,168,0.7));
  margin-top: auto;
}

/* ── Responsive ── */
@media (max-width: 640px) {
  .studios-index {
    padding: 5rem 1rem 4rem;
  }
  .studios-grid {
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 0.75rem;
  }
  .studio-card {
    padding: 1.5rem 1rem 1.25rem;
  }
}
</style>
