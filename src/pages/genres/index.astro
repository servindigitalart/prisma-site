---
export const prerender = false

import BaseLayout from '../../layouts/BaseLayout.astro'
import { createServiceClient } from '../../lib/db/client'
import { GENRE_MAP, getGenreInfo } from '../../lib/genres'

const db = createServiceClient()

const { data: works } = await db
  .from('works')
  .select('genres')
  .eq('is_published', true)

// Count films per genre
const counts: Record<string, number> = {}
for (const w of works ?? []) {
  for (const g of (w.genres as string[]) ?? []) {
    counts[g] = (counts[g] ?? 0) + 1
  }
}

// Build genre list — only genres with 3+ films, sorted by count desc
const genres = Object.entries(counts)
  .filter(([, count]) => count >= 3)
  .sort((a, b) => b[1] - a[1])
  .map(([tmdbName, count]) => ({ ...getGenreInfo(tmdbName), tmdbName, count }))
---

<BaseLayout
  title="Géneros — PRISMA"
  description="Explora el cine de autor por género. Drama, thriller, ciencia ficción, terror y más en el catálogo PRISMA."
  breadcrumbs={[
    { name: 'PRISMA', url: 'https://prisma.film' },
    { name: 'Géneros', url: 'https://prisma.film/genres' },
  ]}
>
  <main class="genres-page">

    <header class="genres-hero">
      <div class="site-container">
        <p class="genres-hero__overline">Catálogo</p>
        <h1 class="genres-hero__title">Géneros</h1>
        <p class="genres-hero__sub">El cine clasificado por su naturaleza</p>
      </div>
    </header>

    <section class="genres-grid-section">
      <div class="site-container">
        <div class="genres-grid">
          {genres.map(genre => (
            <a href={`/genres/${genre.slug}`} class="genre-card">
              <span class="genre-card__icon" aria-hidden="true" set:html={genre.svg} />
              <h2 class="genre-card__name">{genre.name}</h2>
              <p class="genre-card__count">{genre.count} película{genre.count !== 1 ? 's' : ''}</p>
              {genre.description && (
                <p class="genre-card__desc">{genre.description}</p>
              )}
            </a>
          ))}
        </div>
      </div>
    </section>

  </main>
</BaseLayout>

<style>
.genres-page {
  padding-bottom: 6rem;
}

/* Hero */
.genres-hero {
  padding-top: 8rem;
  padding-bottom: 3.5rem;
  border-bottom: 1px solid var(--surface-border);
}

.genres-hero__overline {
  font-size: 0.65rem;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 0.75rem;
}

.genres-hero__title {
  font-family: var(--font-serif);
  font-size: clamp(2.25rem, 6vw, 4rem);
  font-weight: 400;
  color: var(--text-primary);
  margin-bottom: 0.5rem;
  line-height: 1.1;
}

.genres-hero__sub {
  font-size: 1rem;
  color: var(--text-muted);
}

/* Grid */
.genres-grid-section {
  padding-top: 3rem;
}

.genres-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 1px;
  border: 1px solid var(--surface-border);
  border-radius: 8px;
  overflow: hidden;
  background: var(--surface-border);
}

.genre-card {
  display: flex;
  flex-direction: column;
  gap: 0.375rem;
  padding: 1.75rem 1.5rem;
  background: var(--surface-base);
  text-decoration: none;
  transition: background 160ms ease, transform 160ms ease;
  position: relative;
}

.genre-card:hover {
  background: var(--surface-card);
  transform: translateY(-1px);
  z-index: 1;
}

.genre-card__icon {
  display: block;
  width: 2rem;
  height: 2rem;
  color: var(--text-muted);
  margin-bottom: 0.625rem;
  flex-shrink: 0;
  transition: color 200ms ease, transform 200ms ease;
}
.genre-card__icon svg {
  width: 100%;
  height: 100%;
}
.genre-card:hover .genre-card__icon {
  color: var(--text-accent, rgba(212,201,168,0.9));
  transform: scale(1.1);
}

.genre-card__name {
  font-family: var(--font-serif);
  font-size: 1.25rem;
  font-weight: 400;
  color: var(--text-primary);
  margin: 0;
  line-height: 1.2;
}

.genre-card__count {
  font-size: 0.72rem;
  color: var(--text-muted);
  font-family: var(--font-mono);
  letter-spacing: 0.03em;
}

.genre-card__desc {
  font-size: 0.8rem;
  color: var(--text-muted);
  line-height: 1.55;
  margin-top: 0.25rem;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

@media (max-width: 640px) {
  .genres-grid {
    grid-template-columns: repeat(2, 1fr);
  }
  .genre-card {
    padding: 1.25rem 1rem;
  }
  .genre-card__emoji { font-size: 1.5rem; }
  .genre-card__name { font-size: 1rem; }
  .genre-card__desc { display: none; }
}
</style>
