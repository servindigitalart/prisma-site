---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { isSupabaseConfigured, createServiceClient } from '../../lib/db/client';
import { getPaletteEntry } from '../../lib/color/colorPalette';
import { loadAllWorks } from '../../lib/loaders/loadWork';
import type { PrismaColorId } from '../../lib/db/types';
import FilmSortBar from '../../components/ui/FilmSortBar.astro';

export const prerender = true;

export async function getStaticPaths() {
  const decades = ['1920s','1930s','1940s','1950s','1960s','1970s','1980s','1990s','2000s','2010s','2020s'];
  return decades.map(decade => ({ params: { decade } }));
}

const { decade } = Astro.params;
if (!decade) return Astro.redirect('/404');

const startYear = parseInt(decade);
const endYear = startYear + 9;

type FilmEntry = {
  id: string;
  title: string;
  year: number | null;
  tmdb_poster_path: string | null;
  color_iconico: PrismaColorId | null;
  numeric_score: number | null;
};

let films: FilmEntry[] = [];

if (isSupabaseConfigured()) {
  const db = createServiceClient();
  const { data, error } = await db
    .from('works')
    .select(`
      id,
      title,
      year,
      tmdb_poster_path,
      color_assignments(color_iconico, numeric_score)
    `)
    .eq('is_published', true)
    .gte('year', startYear)
    .lte('year', endYear)
    .order('year', { ascending: false })
    .limit(500);

  if (error) console.error('[decades] Error:', error);

  for (const row of (data ?? []) as any[]) {
    const ca = Array.isArray(row.color_assignments)
      ? row.color_assignments[0]
      : row.color_assignments;
    films.push({
      id: row.id,
      title: row.title,
      year: row.year,
      tmdb_poster_path: row.tmdb_poster_path,
      color_iconico: ca?.color_iconico ?? null,
      numeric_score: ca?.numeric_score ?? null,
    });
  }
} else {
  const works = loadAllWorks();
  films = works
    .filter((w) => w.year && w.year >= startYear && w.year <= endYear)
    .map((w) => ({
      id: w.id,
      title: w.title,
      year: w.year ?? null,
      tmdb_poster_path: w.media?.poster_path ?? null,
      color_iconico: (w.prisma_palette?.primary as PrismaColorId) ?? null,
      numeric_score: null,
    }));
}

// Sort: default ranking order for the static page
// (The FilmSortBar provides links; client-side script handles resorting)
const sorted = [...films].sort((a, b) => {
  if (a.numeric_score != null && b.numeric_score != null) return b.numeric_score - a.numeric_score;
  if (a.numeric_score != null) return -1;
  if (b.numeric_score != null) return 1;
  return (b.year ?? 0) - (a.year ?? 0);
});

// Default sort key shown in the sort bar
const sort: 'ranking' | 'year_desc' | 'year_asc' | 'title' = 'ranking';

// Top 5 poster row
const TMDB_IMG = 'https://image.tmdb.org/t/p/w342';
const top5 = sorted.filter(f => f.tmdb_poster_path).slice(0, 5);

// Decade label
const decadeLabel = `los ${decade}`;
const topFilmNames = sorted.slice(0, 3).map(f => f.title);
const topFilmList = topFilmNames.length ? ` Incluye ${topFilmNames.join(', ')} y más.` : '';

const SITE = 'https://prisma.film';
const pageTitle = `Las Mejores Películas de ${decadeLabel} — PRISMA`;
const pageDescription = `El mejor cine de autor de la década de ${decadeLabel} según PRISMA. Ranking editorial con ${films.length} películas seleccionadas por color, premios y peso cultural.${topFilmList}`.slice(0, 160);

const decadeOgImage = sorted.find(f => f.tmdb_poster_path)?.tmdb_poster_path
  ? `https://image.tmdb.org/t/p/w780${sorted.find(f => f.tmdb_poster_path)!.tmdb_poster_path}`
  : undefined;

const decadeJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: pageTitle,
  description: pageDescription,
  url: `${SITE}/decades/${decade}`,
  numberOfItems: films.length,
  itemListElement: sorted.slice(0, 10).map((film, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Movie',
      name: film.title,
      dateCreated: film.year?.toString(),
      url: `${SITE}/films/${film.id.replace(/^work_/, '')}`,
    },
  })),
};

const decadeBreadcrumbs = [
  { name: 'PRISMA', url: SITE },
  { name: 'Rankings', url: `${SITE}/rankings/films` },
  { name: `Década de ${decadeLabel}`, url: `${SITE}/decades/${decade}` },
];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  ogImage={decadeOgImage}
  jsonLd={decadeJsonLd}
  breadcrumbs={decadeBreadcrumbs}
>
  <div class="decade-page page-enter">

    <!-- Header -->
    <section class="decade-header">
      <div class="site-container">
        <div class="decade-header__inner">
          <div class="decade-header__badge" aria-hidden="true">{decade}</div>
          <div class="decade-header__info">
            <div class="decade-header__overline">Cine de Autor por Década</div>
            <h1 class="decade-header__name">Década de {decadeLabel}</h1>
            <p class="decade-header__count">
              {films.length} {films.length === 1 ? 'película' : 'películas'} en el catálogo
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Top 5 poster row -->
    {top5.length > 0 && (
      <section class="decade-posters">
        <div class="site-container">
          <div class="decade-posters__label">Películas Destacadas</div>
          <div class="poster-row">
            {top5.map((film, i) => {
              const filmSlug = film.id.replace(/^work_/, '');
              const palette = film.color_iconico ? getPaletteEntry(film.color_iconico) : null;
              return (
                <a href={`/films/${filmSlug}`} class="poster-card">
                  <img
                    src={`${TMDB_IMG}${film.tmdb_poster_path}`}
                    alt={film.title}
                    class="poster-card__img"
                    loading="lazy"
                    decoding="async"
                  />
                  <span class="poster-card__num">#{i + 1}</span>
                  <div class="poster-card__overlay">
                    <span class="poster-card__overlay-title">{film.title}</span>
                    {film.year && <span class="poster-card__overlay-year">{film.year}</span>}
                    {palette && (
                      <span class="poster-card__overlay-color" style={`color: ${palette.hex}`}>
                        {palette.name}
                      </span>
                    )}
                  </div>
                </a>
              );
            })}
          </div>
        </div>
      </section>
    )}

    <!-- Film poster grid -->
    <section class="decade-films">
      <div class="site-container">
        <div class="decade-films__header">
          <h2 class="decade-films__heading">Catálogo completo</h2>
        </div>
        <FilmSortBar
          currentSort={sort}
          totalCount={sorted.length}
          baseUrl={`/decades/${decade}`}
        />
        <div class="decade-films__grid" id="films-grid">
          {sorted.map((film, i) => {
            const filmSlug = film.id.replace(/^work_/, '');
            const initial = film.title.charAt(0).toUpperCase();
            return (
              <a
                href={`/films/${filmSlug}`}
                class="film-pcard"
                data-idx={i}
                data-score={film.numeric_score ?? ''}
                data-year={film.year ?? ''}
                data-title={film.title}
              >
                <div class="film-pcard__img-wrap">
                  {film.tmdb_poster_path
                    ? <img src={`${TMDB_IMG}${film.tmdb_poster_path}`} alt={film.title} loading="lazy" decoding="async" />
                    : <div class="film-pcard__placeholder"><span>{initial}</span></div>
                  }
                </div>
                <div class="film-pcard__info">
                  <span class="film-pcard__title">{film.title}</span>
                  {film.year && <span class="film-pcard__year">{film.year}</span>}
                </div>
              </a>
            );
          })}
        </div>
        {sorted.length > 40 && (
          <div class="films-pagination" id="films-pagination">
            <button class="films-pagination__btn" id="films-prev" disabled>← Anterior</button>
            <span class="films-pagination__info" id="films-page-info">1 / {Math.ceil(sorted.length / 40)}</span>
            <button class="films-pagination__btn" id="films-next">Siguiente →</button>
          </div>
        )}
      </div>
    </section>

    {films.length === 0 && (
      <div class="decade-empty site-container">
        <p>Aún no hay películas de esta década en el catálogo.</p>
      </div>
    )}
  </div>
</BaseLayout>

<script is:inline>
(function () {
  var PAGE_SIZE = 40;
  var currentPage = 0;

  // ── 1. Read ?sort from the URL ──────────────────────────────────────────
  var params = new URLSearchParams(window.location.search);
  var sort = params.get('sort') || 'ranking';

  // ── 2. Re-order the grid cards client-side ──────────────────────────────
  var grid = document.getElementById('films-grid');
  if (grid) {
    var cards = Array.from(grid.querySelectorAll('.film-pcard'));

    cards.sort(function (a, b) {
      if (sort === 'year_desc') {
        var ay = parseInt(a.dataset.year || '0', 10);
        var by = parseInt(b.dataset.year || '0', 10);
        return by - ay;
      }
      if (sort === 'year_asc') {
        var ay = parseInt(a.dataset.year || '0', 10);
        var by = parseInt(b.dataset.year || '0', 10);
        return ay - by;
      }
      if (sort === 'title') {
        var at = a.dataset.title || '';
        var bt = b.dataset.title || '';
        return at.localeCompare(bt, 'es');
      }
      // default: 'ranking' — by numeric_score desc, then year desc
      var as_ = a.dataset.score !== '' ? parseFloat(a.dataset.score) : null;
      var bs_ = b.dataset.score !== '' ? parseFloat(b.dataset.score) : null;
      if (as_ !== null && bs_ !== null) return bs_ - as_;
      if (as_ !== null) return -1;
      if (bs_ !== null) return 1;
      var ay = parseInt(a.dataset.year || '0', 10);
      var by = parseInt(b.dataset.year || '0', 10);
      return by - ay;
    });

    // Re-append in sorted order (moves existing DOM nodes — no clone needed)
    cards.forEach(function (card) { grid.appendChild(card); });

    // ── 3. Update the active sort button highlight ─────────────────────────
    document.querySelectorAll('.sort-bar__btn').forEach(function (btn) {
      var href = btn.getAttribute('href') || '';
      var btnSort = new URLSearchParams(href.split('?')[1] || '').get('sort') || 'ranking';
      if (btnSort === sort) {
        btn.classList.add('is-active');
        btn.setAttribute('aria-current', 'true');
      } else {
        btn.classList.remove('is-active');
        btn.removeAttribute('aria-current');
      }
    });
  }

  // ── 4. Pagination ────────────────────────────────────────────────────────
  var allCards = Array.from(document.querySelectorAll('.film-pcard'));
  var totalPages = Math.ceil(allCards.length / PAGE_SIZE);
  if (totalPages <= 1) return;

  function showPage(page) {
    currentPage = page;
    allCards.forEach(function (card, i) {
      card.style.display = (i >= page * PAGE_SIZE && i < (page + 1) * PAGE_SIZE) ? '' : 'none';
    });
    var prev = document.getElementById('films-prev');
    var next = document.getElementById('films-next');
    var info = document.getElementById('films-page-info');
    if (prev) prev.disabled = (page === 0);
    if (next) next.disabled = (page >= totalPages - 1);
    if (info) info.textContent = (page + 1) + ' / ' + totalPages;
  }

  showPage(0);

  var prevBtn = document.getElementById('films-prev');
  var nextBtn = document.getElementById('films-next');
  if (prevBtn) prevBtn.addEventListener('click', function () {
    if (currentPage > 0) {
      showPage(currentPage - 1);
      window.scrollTo({ top: grid.offsetTop - 80, behavior: 'smooth' });
    }
  });
  if (nextBtn) nextBtn.addEventListener('click', function () {
    if (currentPage < totalPages - 1) {
      showPage(currentPage + 1);
      window.scrollTo({ top: grid.offsetTop - 80, behavior: 'smooth' });
    }
  });
})();
</script>

<style>
/* ── Header ── */
.decade-header {
  padding: 6rem 0 3rem;
  border-bottom: 1px solid var(--surface-border);
}

.decade-header__inner {
  display: flex;
  align-items: center;
  gap: 1.5rem;
}

.decade-header__badge {
  font-family: var(--font-serif);
  font-size: 2rem;
  font-weight: 700;
  color: var(--text-accent);
  background: rgba(212, 201, 168, 0.08);
  border: 1px solid rgba(212, 201, 168, 0.15);
  border-radius: 8px;
  padding: 0.5rem 1rem;
  flex-shrink: 0;
}

.decade-header__overline {
  font-size: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  color: var(--text-muted);
  margin-bottom: 0.375rem;
}

.decade-header__name {
  font-family: var(--font-serif);
  font-size: clamp(1.5rem, 3vw, 2.25rem);
  font-weight: 400;
  color: var(--text-primary);
  margin: 0;
}

.decade-header__count {
  font-size: 0.85rem;
  color: var(--text-muted);
  margin-top: 0.375rem;
}

/* ── Poster Row ── */
.decade-posters {
  padding: 2.5rem 0;
  border-bottom: 1px solid var(--surface-border);
}

.decade-posters__label {
  font-size: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--text-muted);
  margin-bottom: 1rem;
}

.poster-row {
  display: flex;
  gap: 1rem;
  overflow-x: auto;
  scrollbar-width: none;
}
.poster-row::-webkit-scrollbar { display: none; }

.poster-card {
  position: relative;
  flex-shrink: 0;
  width: 140px;
  border-radius: 6px;
  overflow: hidden;
  transition: transform var(--duration-fast) var(--ease-editorial);
}
.poster-card:hover { transform: translateY(-4px); }

.poster-card__img {
  width: 100%;
  aspect-ratio: 2/3;
  object-fit: cover;
  display: block;
}

.poster-card__num {
  position: absolute;
  top: 6px;
  left: 6px;
  background: rgba(0,0,0,0.65);
  color: var(--text-accent);
  font-size: 0.65rem;
  font-weight: 600;
  padding: 2px 6px;
  border-radius: 3px;
}

.poster-card__overlay {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 0.5rem;
  background: linear-gradient(to top, rgba(0,0,0,0.75) 0%, transparent 50%);
  opacity: 0;
  transition: opacity var(--duration-fast) var(--ease-editorial);
}
.poster-card:hover .poster-card__overlay { opacity: 1; }

.poster-card__overlay-title {
  font-size: 0.75rem;
  font-weight: 500;
  color: #fff;
  line-height: 1.3;
}

.poster-card__overlay-year {
  font-size: 0.65rem;
  color: rgba(255,255,255,0.6);
}

.poster-card__overlay-color {
  font-size: 0.6rem;
  font-weight: 500;
}

/* ── Film Poster Grid ── */
.decade-films {
  padding: 2rem 0 5rem;
}

.decade-films__header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 1.5rem;
}

.decade-films__heading {
  font-family: var(--font-serif);
  font-size: 1.25rem;
  font-weight: 400;
  color: var(--text-primary);
}

.decade-films__count {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  color: var(--text-muted);
}

.decade-films__grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
  gap: 1rem;
  margin-bottom: 2rem;
}

.film-pcard {
  display: block;
  text-decoration: none;
  transition: transform 200ms ease;
}
.film-pcard:hover { transform: scale(1.03); }

.film-pcard__img-wrap {
  aspect-ratio: 2 / 3;
  border-radius: 4px;
  overflow: hidden;
  background: var(--surface-card);
  box-shadow: 0 2px 8px rgba(0,0,0,0.3);
  transition: box-shadow 200ms ease;
}
.film-pcard:hover .film-pcard__img-wrap { box-shadow: 0 8px 24px rgba(0,0,0,0.5); }

.film-pcard__img-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  display: block;
}

.film-pcard__placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--surface-elevated);
}
.film-pcard__placeholder span {
  font-family: var(--font-serif);
  font-size: 2rem;
  color: var(--text-muted);
  opacity: 0.4;
}

.film-pcard__info {
  padding: 0.45rem 0 0;
  display: flex;
  flex-direction: column;
  gap: 0.15rem;
}

.film-pcard__title {
  font-size: 0.78rem;
  color: var(--text-secondary);
  line-height: 1.3;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  transition: color 160ms ease;
}
.film-pcard:hover .film-pcard__title { color: var(--text-primary); }

.film-pcard__year {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  color: var(--text-muted);
}

/* ── Pagination ── */
.films-pagination {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 1.5rem;
  padding: 1.5rem 0;
  border-top: 1px solid var(--surface-border);
}

.films-pagination__btn {
  font-family: var(--font-sans);
  font-size: 0.78rem;
  color: var(--text-muted);
  background: var(--surface-card);
  border: 1px solid var(--surface-border);
  border-radius: 3px;
  padding: 0.4rem 0.875rem;
  cursor: pointer;
  transition: color 160ms ease, border-color 160ms ease;
}
.films-pagination__btn:hover:not(:disabled) {
  color: var(--text-primary);
  border-color: var(--text-muted);
}
.films-pagination__btn:disabled { opacity: 0.35; cursor: not-allowed; }

.films-pagination__info {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  color: var(--text-muted);
}

.decade-empty {
  padding: 4rem 0;
  text-align: center;
  color: var(--text-muted);
}

@media (max-width: 480px) {
  .decade-films__grid {
    grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
    gap: 0.625rem;
  }
}
</style>
