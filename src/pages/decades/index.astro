---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { isSupabaseConfigured, createServiceClient } from '../../lib/db/client';
import { loadAllWorks } from '../../lib/loaders/loadWork';

export const prerender = true;

const DECADES = ['1920s','1930s','1940s','1950s','1960s','1970s','1980s','1990s','2000s','2010s','2020s'];
const TMDB_SM = 'https://image.tmdb.org/t/p/w185';

type DecadeData = {
  decade: string;
  count: number;
  posters: string[];
};

const decadeData: DecadeData[] = DECADES.map(d => ({ decade: d, count: 0, posters: [] }));

if (isSupabaseConfigured()) {
  try {
    const db = createServiceClient();
    const { data } = await db
      .from('works')
      .select('year, tmdb_poster_path')
      .eq('is_published', true)
      .not('year', 'is', null);

    for (const row of (data ?? []) as { year: number; tmdb_poster_path: string | null }[]) {
      const d = Math.floor(row.year / 10) * 10;
      const entry = decadeData.find(e => e.decade === `${d}s`);
      if (!entry) continue;
      entry.count++;
      if (entry.posters.length < 3 && row.tmdb_poster_path) {
        entry.posters.push(row.tmdb_poster_path);
      }
    }
  } catch {
    // fall through to filesystem
  }
}

if (decadeData.every(d => d.count === 0)) {
  const works = loadAllWorks();
  for (const w of works) {
    if (!w.year) continue;
    const d = Math.floor(w.year / 10) * 10;
    const entry = decadeData.find(e => e.decade === `${d}s`);
    if (!entry) continue;
    entry.count++;
    if (entry.posters.length < 3 && w.media?.poster_path) {
      entry.posters.push(w.media.poster_path);
    }
  }
}

const breadcrumbs = [
  { name: 'PRISMA', url: 'https://prisma.film' },
  { name: 'Décadas', url: 'https://prisma.film/decades' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Cine por Décadas — PRISMA',
  description: 'Explora el catálogo PRISMA a través del tiempo. Cada década, su cine.',
  url: 'https://prisma.film/decades',
};
---

<BaseLayout
  title="Cine por Décadas — PRISMA"
  description="Explora el catálogo PRISMA a través del tiempo. Del cine mudo a la era contemporánea."
  jsonLd={jsonLd}
  breadcrumbs={breadcrumbs}
>
  <div class="decades-page">
    <header class="decades-hero">
      <div class="site-container">
        <p class="decades-hero__eyebrow">Archivo cinematográfico</p>
        <h1 class="decades-hero__title">Cine por Décadas</h1>
        <p class="decades-hero__sub">Explora el catálogo PRISMA a través del tiempo</p>
      </div>
    </header>

    <section class="decades-grid-section">
      <div class="site-container">
        <div class="decades-cards">
          {decadeData.filter(d => d.count > 0 || d.decade >= '1960s').map(d => (
            <a href={`/decades/${d.decade}`} class="decade-card">
              {d.posters.length > 0 && (
                <div class="decade-card__collage" aria-hidden="true">
                  {d.posters.map(p => (
                    <img src={`${TMDB_SM}${p}`} alt="" loading="lazy" decoding="async" />
                  ))}
                </div>
              )}
              <div class="decade-card__overlay" />
              <div class="decade-card__content">
                <span class="decade-card__number">{d.decade.replace('s', '')}</span>
                <span class="decade-card__suffix">s</span>
                {d.count > 0 && (
                  <span class="decade-card__count">{d.count} {d.count === 1 ? 'película' : 'películas'}</span>
                )}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
.decades-page {
  min-height: 100vh;
  background: var(--surface-bg);
}

.decades-hero {
  padding: 8rem 0 4rem;
  border-bottom: 1px solid var(--surface-border);
}

.decades-hero__eyebrow {
  font-family: var(--font-sans);
  font-size: 0.65rem;
  font-weight: 600;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin: 0 0 1.25rem;
}

.decades-hero__title {
  font-family: var(--font-serif);
  font-size: clamp(2.5rem, 5vw, 4.5rem);
  font-weight: 400;
  color: var(--text-primary);
  line-height: 1.05;
  margin: 0 0 1rem;
}

.decades-hero__sub {
  font-size: 1rem;
  color: var(--text-muted);
  margin: 0;
}

.decades-grid-section {
  padding: 4rem 0 8rem;
}

.decades-cards {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 1.5rem;
}

.decade-card {
  position: relative;
  aspect-ratio: 3 / 2;
  border-radius: 8px;
  overflow: hidden;
  background: var(--surface-card);
  border: 1px solid var(--surface-border);
  text-decoration: none;
  display: block;
  transition: transform 220ms ease, border-color 220ms ease;
}

.decade-card:hover {
  transform: translateY(-3px);
  border-color: var(--surface-border-strong);
}

.decade-card__collage {
  position: absolute;
  inset: 0;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  opacity: 0.22;
  transition: opacity 220ms ease;
}
.decade-card:hover .decade-card__collage { opacity: 0.32; }

.decade-card__collage img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.decade-card__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(160deg, rgba(13,13,15,0.3) 0%, rgba(13,13,15,0.75) 100%);
}

.decade-card__content {
  position: relative;
  z-index: 1;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: flex-end;
  padding: 1.25rem;
  gap: 0.25rem;
}

.decade-card__number {
  font-family: var(--font-serif);
  font-size: clamp(2.5rem, 4vw, 3.5rem);
  font-weight: 400;
  color: var(--text-primary);
  line-height: 1;
  letter-spacing: -0.02em;
}

.decade-card__suffix {
  font-family: var(--font-serif);
  font-size: clamp(1.5rem, 2vw, 2rem);
  font-weight: 400;
  color: var(--text-muted);
  line-height: 1;
  margin-top: -0.5rem;
  margin-left: 0.125rem;
}

.decade-card__content {
  flex-direction: row;
  align-items: flex-end;
  flex-wrap: wrap;
}

.decade-card__count {
  width: 100%;
  font-family: var(--font-sans);
  font-size: 0.68rem;
  font-weight: 500;
  color: var(--text-muted);
  letter-spacing: 0.06em;
  margin-top: 0.125rem;
}

@media (max-width: 640px) {
  .decades-cards {
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }
}
</style>
