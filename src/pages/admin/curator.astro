---
// filepath: src/pages/admin/curator.astro
import { createServiceClient } from '../../lib/db/client';
import Layout from '../../layouts/BaseLayout.astro';
import { PRISMA_PALETTE } from '../../lib/color/colorPalette';

const db = createServiceClient();

// Fetch all works with color assignments, ordered by most recently updated
const { data: assignments, error } = await db
  .from('color_assignments')
  .select(`
    work_id,
    color_iconico,
    colores_secundarios,
    color_rank,
    review_status,
    editorial_override,
    updated_at,
    works!inner (
      title,
      year
    )
  `)
  .order('updated_at', { ascending: false });

if (error) {
  console.error('[admin/curator] Error fetching color assignments:', error);
}

const colorAssignments = assignments ?? [];

// Convert palette to array for rendering
const paletteArray = Object.values(PRISMA_PALETTE);
---

<Layout title="Color Curator — PRISMA Admin">
  <main class="max-w-7xl mx-auto px-4 py-12">
    <header class="mb-12">
      <h1 class="text-4xl font-bold mb-4">Color Curator</h1>
      <p class="text-gray-400">
        Editorial override interface for AI-assigned color identities.
        Changes made here take precedence over pipeline results.
      </p>
    </header>

    {colorAssignments.length === 0 ? (
      <div class="bg-yellow-900/20 border border-yellow-700/50 rounded-lg p-6">
        <p class="text-yellow-200">
          ⚠️ No color assignments found. Run the pipeline first.
        </p>
      </div>
    ) : (
      <div class="space-y-4">
        {colorAssignments.map((assignment) => {
          const work = assignment.works;
          const currentColor = PRISMA_PALETTE[assignment.color_iconico];
          const hasOverride = assignment.editorial_override !== null;
          
          return (
            <article 
              class="bg-[var(--surface-card)] border border-[var(--surface-border)] rounded-lg p-6"
              data-work-id={assignment.work_id}
            >
              <div class="flex items-start justify-between gap-6">
                {/* Film info */}
                <div class="flex-1">
                  <h2 class="text-2xl font-semibold mb-2">
                    {work.title} ({work.year})
                  </h2>
                  <div class="flex items-center gap-4 text-sm text-gray-400">
                    <span class="capitalize bg-blue-900/30 text-blue-200 px-2 py-1 rounded">
                      {assignment.review_status.replace(/_/g, ' ')}
                    </span>
                    {hasOverride && (
                      <span class="bg-purple-900/30 text-purple-200 px-2 py-1 rounded">
                        ✎ Editorial Override
                      </span>
                    )}
                    <span>
                      Confidence: {assignment.color_rank ? (assignment.color_rank * 100).toFixed(0) : '0'}%
                    </span>
                    <span class="text-xs text-gray-500">
                      Updated: {assignment.updated_at ? new Date(assignment.updated_at).toLocaleDateString() : 'N/A'}
                    </span>
                  </div>
                </div>

                {/* Current color swatch */}
                <div class="flex flex-col items-center gap-2">
                  <div 
                    class="w-20 h-20 rounded-lg border-2 border-white/20 shadow-lg"
                    style={`background-color: ${currentColor?.hex || '#4A4A4A'}`}
                  ></div>
                  <span class="text-xs text-gray-400 text-center">
                    {currentColor?.name || assignment.color_iconico}
                  </span>
                </div>
              </div>

              {/* Edit panel (collapsed by default) */}
              <details class="mt-6">
                <summary class="cursor-pointer text-sm text-gray-400 hover:text-gray-200 transition-colors">
                  ▸ Edit Color Assignment
                </summary>
                
                <form class="mt-6 space-y-6 override-form">
                  <input type="hidden" name="work_id" value={assignment.work_id} />
                  
                  {/* Primary color selector */}
                  <div>
                    <label class="block text-sm font-medium text-gray-300 mb-3">
                      Primary Color
                    </label>
                    <div class="grid grid-cols-6 gap-3">
                      {paletteArray.map((color) => (
                        <label class="cursor-pointer group">
                          <input
                            type="radio"
                            name="color_iconico"
                            value={color.id}
                            checked={color.id === assignment.color_iconico}
                            class="sr-only peer"
                          />
                          <div class="flex flex-col items-center gap-2">
                            <div 
                              class="w-12 h-12 rounded-lg border-2 transition-all
                                     peer-checked:border-white peer-checked:ring-2 peer-checked:ring-white/50
                                     group-hover:scale-110"
                              style={`background-color: ${color.hex}; border-color: ${color.id === assignment.color_iconico ? 'white' : 'rgba(255,255,255,0.2)'}`}
                            ></div>
                            <span class="text-[10px] text-gray-500 text-center leading-tight max-w-[60px]">
                              {color.name}
                            </span>
                          </div>
                        </label>
                      ))}
                    </div>
                  </div>

                  {/* Secondary colors (multi-select, max 3) */}
                  <div>
                    <label class="block text-sm font-medium text-gray-300 mb-3">
                      Secondary Colors (max 2)
                    </label>
                    <div class="grid grid-cols-6 gap-3">
                      {paletteArray.map((color) => (
                        <label class="cursor-pointer group">
                          <input
                            type="checkbox"
                            name="colores_secundarios"
                            value={color.id}
                            checked={(assignment.colores_secundarios as any)?.includes(color.id)}
                            class="sr-only peer secondary-checkbox"
                          />
                          <div class="flex flex-col items-center gap-2">
                            <div 
                              class="w-12 h-12 rounded-lg border-2 transition-all
                                     peer-checked:border-white peer-checked:ring-2 peer-checked:ring-white/50
                                     group-hover:scale-110"
                              style={`background-color: ${color.hex}; border-color: ${(assignment.colores_secundarios as any)?.includes(color.id) ? 'white' : 'rgba(255,255,255,0.2)'}`}
                            ></div>
                            <span class="text-[10px] text-gray-500 text-center leading-tight max-w-[60px]">
                              {color.name}
                            </span>
                          </div>
                        </label>
                      ))}
                    </div>
                  </div>

                  {/* Editorial note */}
                  <div>
                    <label class="block text-sm font-medium text-gray-300 mb-2">
                      Editorial Note (why this override?)
                    </label>
                    <textarea
                      name="editorial_note"
                      rows="3"
                      class="w-full bg-[var(--surface-elevated)] border border-[var(--surface-border)] 
                             rounded-lg px-4 py-2 text-gray-200 focus:outline-none focus:ring-2 
                             focus:ring-blue-500 resize-none"
                      placeholder="e.g., 'Film is visually dominated by red cheongsams and amber lighting, not blue melancholy'"
                    >{(assignment.editorial_override as any)?.note || ''}</textarea>
                  </div>

                  {/* Actions */}
                  <div class="flex gap-3">
                    <button
                      type="submit"
                      class="bg-green-600 hover:bg-green-700 text-white px-6 py-2 rounded font-medium 
                             transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
                    >
                      ✓ Save Override
                    </button>
                    <button
                      type="button"
                      class="bg-gray-700 hover:bg-gray-600 text-gray-200 px-6 py-2 rounded font-medium 
                             transition-colors reset-form"
                    >
                      Reset
                    </button>
                  </div>

                  <div class="save-status hidden"></div>
                </form>
              </details>
            </article>
          );
        })}
      </div>
    )}

    <div class="mt-12 bg-blue-900/20 border border-blue-700/50 rounded-lg p-6">
      <h3 class="font-semibold mb-2 text-blue-200">Curator Guidelines</h3>
      <ul class="text-sm text-blue-100/80 space-y-1 list-disc list-inside">
        <li>Override when AI assigns color based on emotional symbolism instead of visual dominance</li>
        <li>Example: "In the Mood for Love" (2000) should be red (cheongsams), not blue (melancholy)</li>
        <li>Always provide a clear editorial note explaining the visual evidence</li>
        <li>Secondary colors should support the primary (max 2 recommended)</li>
        <li>Overrides are permanent until manually changed — they persist across pipeline re-runs</li>
      </ul>
    </div>
  </main>

  <script>
    // Client-side form handling
    document.addEventListener('DOMContentLoaded', () => {
      const forms = document.querySelectorAll('.override-form');
      
      forms.forEach((form) => {
        if (!(form instanceof HTMLFormElement)) return;
        
        // Limit secondary colors to max 2
        const secondaryCheckboxes = form.querySelectorAll('.secondary-checkbox');
        secondaryCheckboxes.forEach((checkbox) => {
          if (!(checkbox instanceof HTMLInputElement)) return;
          checkbox.addEventListener('change', () => {
            const checked = form.querySelectorAll('.secondary-checkbox:checked');
            if (checked.length > 2 && checkbox instanceof HTMLInputElement) {
              checkbox.checked = false;
              alert('Maximum 2 secondary colors allowed');
            }
          });
        });

        // Reset button
        const resetBtn = form.querySelector('.reset-form');
        resetBtn?.addEventListener('click', () => {
          if (form instanceof HTMLFormElement) {
            form.reset();
          }
        });

        // Form submission
        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          
          if (!(form instanceof HTMLFormElement)) return;
          const formData = new FormData(form);
          const workId = formData.get('work_id');
          const colorIconico = formData.get('color_iconico');
          const editorialNote = formData.get('editorial_note');
          const coloresSecundarios = formData.getAll('colores_secundarios');
          
          const statusDiv = form.querySelector('.save-status');
          if (!statusDiv) return;
          
          statusDiv.className = 'save-status mt-4 p-3 rounded text-sm';
          statusDiv.textContent = 'Saving...';
          statusDiv.classList.remove('hidden', 'bg-green-900/30', 'bg-red-900/30');
          statusDiv.classList.add('bg-blue-900/30', 'text-blue-200');
          
          try {
            const response = await fetch('/api/admin/override-color', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                work_id: workId,
                color_iconico: colorIconico,
                colores_secundarios: coloresSecundarios,
                editorial_note: editorialNote
              })
            });
            
            if (!response.ok) {
              throw new Error(`HTTP ${response.status}`);
            }
            
            const result = await response.json();
            
            statusDiv.className = 'save-status mt-4 p-3 rounded text-sm bg-green-900/30 text-green-200 border border-green-700/50';
            statusDiv.textContent = '✓ Override saved successfully';
            
            // Update the current color swatch
            const article = form.closest('article');
            const swatch = article?.querySelector('[class*="w-20 h-20"]');
            const swatchLabel = article?.querySelector('.text-xs.text-gray-400');
            
            if (swatch instanceof HTMLElement && result.color_hex) {
              swatch.style.backgroundColor = result.color_hex;
            }
            if (swatchLabel && result.color_name) {
              swatchLabel.textContent = result.color_name;
            }
            
            // Add override badge if not present
            const badges = article?.querySelector('.flex.items-center.gap-4');
            if (badges && !badges.querySelector('.bg-purple-900\\/30')) {
              const overrideBadge = document.createElement('span');
              overrideBadge.className = 'bg-purple-900/30 text-purple-200 px-2 py-1 rounded';
              overrideBadge.textContent = '✎ Editorial Override';
              badges.appendChild(overrideBadge);
            }
            
          } catch (err) {
            const errorMessage = err instanceof Error ? err.message : 'Unknown error';
            statusDiv.className = 'save-status mt-4 p-3 rounded text-sm bg-red-900/30 text-red-200 border border-red-700/50';
            statusDiv.textContent = `✗ Error: ${errorMessage}`;
          }
        });
      });
    });
  </script>
</Layout>
