---
// filepath: src/pages/admin/review.astro
import { createServiceClient } from '../../lib/db/client';
import Layout from '../../layouts/BaseLayout.astro';

const db = createServiceClient();

// Fetch generated articles not yet published (pending review)
const { data: articles, error } = await db
  .from('generated_articles')
  .select('*')
  .eq('is_published', false)
  .order('generated_at', { ascending: false });

if (error) {
  console.error('[admin/review] Error fetching articles:', error);
}

const pendingArticles = articles ?? [];
---

<Layout title="Review Queue — PRISMA Admin">
  <main class="max-w-6xl mx-auto px-4 py-12">
    <header class="mb-12">
      <h1 class="text-4xl font-bold mb-4">pSEO Content Review Queue</h1>
      <p class="text-gray-600">
        Articles awaiting editorial approval before publication.
      </p>
    </header>

    {pendingArticles.length === 0 ? (
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <p class="text-green-800">
          ✅ All clear! No articles pending review.
        </p>
      </div>
    ) : (
      <div class="space-y-6">
        {pendingArticles.map((article) => (
          <article class="bg-white border border-gray-200 rounded-lg p-6">
            <div class="flex items-start justify-between mb-4">
              <div class="flex-1">
                <h2 class="text-2xl font-semibold mb-2">{article.title}</h2>
                <div class="flex items-center gap-4 text-sm text-gray-600">
                  <span class="capitalize bg-blue-100 text-blue-800 px-2 py-1 rounded">
                    {article.template_type?.replace(/_/g, ' ')}
                  </span>
                  <span>{article.word_count} words</span>
                  <span>
                    Generated: {article.generated_at ? new Date(article.generated_at).toLocaleDateString() : 'Unknown'}
                  </span>
                </div>
              </div>
            </div>

            {article.excerpt && (
              <p class="text-gray-700 mb-4 line-clamp-3">{article.excerpt}</p>
            )}

            <div class="flex gap-3">
              <form action="/api/admin/approve-article" method="POST">
                <input type="hidden" name="article_id" value={article.id} />
                <button
                  type="submit"
                  class="bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded font-medium transition-colors"
                >
                  ✓ Approve & Publish
                </button>
              </form>

              <form action="/api/admin/reject-article" method="POST">
                <input type="hidden" name="article_id" value={article.id} />
                <button
                  type="submit"
                  class="bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded font-medium transition-colors"
                >
                  ✗ Reject (back to draft)
                </button>
              </form>

              <a
                href={`/admin/review/${article.id}`}
                class="bg-gray-200 hover:bg-gray-300 text-gray-800 px-4 py-2 rounded font-medium transition-colors"
              >
                View Full Article
              </a>
            </div>
          </article>
        ))}
      </div>
    )}

    <div class="mt-12 bg-blue-50 border border-blue-200 rounded-lg p-6">
      <h3 class="font-semibold mb-2">Review Guidelines</h3>
      <ul class="text-sm text-gray-700 space-y-1 list-disc list-inside">
        <li>Minimum 800 words required for publication</li>
        <li>Check for keyword stuffing or unnatural language</li>
        <li>Verify all film/person/color links are correct</li>
        <li>Ensure intro and closing paragraphs are editorial (not AI-generated)</li>
        <li>Confirm no duplicate H1s across published articles</li>
      </ul>
    </div>
  </main>
</Layout>

<style>
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
