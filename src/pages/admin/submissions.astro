---
export const prerender = false

import BaseLayout from '../../layouts/BaseLayout.astro'
import { requireAdmin } from '../../lib/admin'
import { createServiceClient } from '../../lib/db/client'

const isAdmin = await requireAdmin(Astro.locals)
if (!isAdmin) return Astro.redirect('/')

const db = createServiceClient()

const { data: submissions } = await db
  .from('film_submissions')
  .select('*')
  .order('submitted_at', { ascending: false })

const allSubs = submissions || []
const statusCounts: Record<string, number> = {}
allSubs.forEach((s: any) => {
  statusCounts[s.status] = (statusCounts[s.status] || 0) + 1
})

const statuses = ['pending', 'under_review', 'approved', 'awaiting_ficha', 'ficha_received', 'published', 'rejected']
const statusLabels: Record<string, string> = {
  pending: 'Pending',
  under_review: 'Under Review',
  approved: 'Approved',
  awaiting_ficha: 'Awaiting Ficha',
  ficha_received: 'Ficha Received',
  published: 'Published',
  rejected: 'Rejected',
}
const statusColors: Record<string, string> = {
  pending: '#C98A2E',
  under_review: '#4A90D9',
  approved: '#3dba6f',
  awaiting_ficha: '#D4C9A8',
  ficha_received: '#7BC96F',
  published: '#1F7A5C',
  rejected: '#8E1B1B',
}
const typeBadges: Record<string, string> = {
  short: 'SHORT',
  feature: 'FILM',
  series: 'SERIES',
  music_video: 'MUSIC VIDEO',
}
---

<BaseLayout title="Submissions — PRISMA Admin">
  <main class="admin-page">
    <header class="admin-header">
      <h1>Submissions</h1>
      <div class="status-counts">
        {statuses.map(s => (
          <span class="status-count" style={`--sc: ${statusColors[s]}`}>
            {statusLabels[s]}: {statusCounts[s] || 0}
          </span>
        ))}
      </div>
    </header>

    <div class="filter-tabs" id="filter-tabs">
      <button class="filter-tab is-active" data-filter="all">All ({allSubs.length})</button>
      {statuses.map(s => (
        <button class="filter-tab" data-filter={s}>
          {statusLabels[s]} ({statusCounts[s] || 0})
        </button>
      ))}
    </div>

    <div class="submissions-list" id="submissions-list">
      {allSubs.length === 0 && <p class="empty">No submissions yet.</p>}
      {allSubs.map((sub: any) => {
        const driveLink = sub.storage_path || ''
        const metaLines = (sub.reviewer_notes || '').split('\n')
        const contentType = metaLines.find((l: string) => l.startsWith('Content type:'))?.replace('Content type: ', '') || ''
        const typeBadge = typeBadges[contentType] || contentType.toUpperCase() || '—'
        const submitted = sub.submitted_at ? new Date(sub.submitted_at).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) : '—'
        return (
          <div class="sub-card" data-status={sub.status} data-id={sub.id}>
            <div class="sub-card__header">
              <div class="sub-card__title-row">
                <span class="type-badge">{typeBadge}</span>
                <h3 class="sub-card__title">{sub.title}</h3>
                <span class="sub-card__year">{sub.year || '—'}</span>
              </div>
              <span class="status-badge" style={`--sb: ${statusColors[sub.status]}`}>
                {statusLabels[sub.status]}
              </span>
            </div>

            <div class="sub-card__meta">
              <span>{sub.filmmaker_name} · {sub.filmmaker_email}</span>
              <span>Submitted {submitted}</span>
              {sub.runtime_min && <span>{sub.runtime_min} min</span>}
            </div>

            <details class="sub-card__synopsis">
              <summary>Synopsis</summary>
              <p>{sub.synopsis || 'No synopsis provided.'}</p>
            </details>

            {driveLink && (
              <a href={driveLink} target="_blank" rel="noopener" class="drive-link">
                Open Drive link ↗
              </a>
            )}

            <div class="sub-card__notes">
              <label for={`notes-${sub.id}`}>Reviewer notes</label>
              <textarea
                id={`notes-${sub.id}`}
                class="notes-textarea"
                data-sub-id={sub.id}
                rows={2}
              >{sub.reviewer_notes || ''}</textarea>
            </div>

            <div class="sub-card__actions">
              {sub.status === 'pending' && (
                <>
                  <button class="action-btn action-btn--primary" data-action="under_review" data-sub-id={sub.id}>Mark as Under Review</button>
                  <button class="action-btn action-btn--danger" data-action="reject" data-sub-id={sub.id}>Reject</button>
                </>
              )}
              {sub.status === 'under_review' && (
                <>
                  <button class="action-btn action-btn--primary" data-action="approved" data-sub-id={sub.id}>Approve</button>
                  <button class="action-btn action-btn--danger" data-action="reject" data-sub-id={sub.id}>Reject</button>
                </>
              )}
              {sub.status === 'approved' && (
                <button class="action-btn action-btn--accent" data-action="send_ficha" data-sub-id={sub.id}>Send Ficha Request</button>
              )}
              {sub.status === 'awaiting_ficha' && (
                <>
                  <span class="ficha-note">Ficha requested</span>
                  <button class="action-btn action-btn--accent" data-action="send_ficha" data-sub-id={sub.id}>Resend</button>
                </>
              )}
              {sub.status === 'ficha_received' && (
                <a href={`/admin/ficha/${sub.id}`} class="action-btn action-btn--primary">Review Ficha</a>
              )}
              {sub.status === 'published' && sub.work_id && (
                <a href={`/films/${sub.work_id.replace(/^work_/, '')}`} class="action-btn action-btn--subtle">View on site ↗</a>
              )}
            </div>

            <div class="reject-form" id={`reject-${sub.id}`} hidden>
              <textarea class="reject-reason" placeholder="Reason for rejection…" rows={2}></textarea>
              <button class="action-btn action-btn--danger" data-action="confirm_reject" data-sub-id={sub.id}>Confirm Rejection</button>
            </div>
          </div>
        )
      })}
    </div>
  </main>
</BaseLayout>

<script is:inline>
(function() {
  // Filter tabs
  var tabs = document.querySelectorAll('.filter-tab');
  var cards = document.querySelectorAll('.sub-card');
  tabs.forEach(function(tab) {
    tab.addEventListener('click', function() {
      tabs.forEach(function(t) { t.classList.remove('is-active'); });
      tab.classList.add('is-active');
      var filter = tab.dataset.filter;
      cards.forEach(function(card) {
        card.style.display = (filter === 'all' || card.dataset.status === filter) ? '' : 'none';
      });
    });
  });

  // Auto-save notes on blur
  document.querySelectorAll('.notes-textarea').forEach(function(ta) {
    ta.addEventListener('blur', async function() {
      var id = ta.dataset.subId;
      await fetch('/api/admin/submissions/' + id, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ reviewer_notes: ta.value })
      });
    });
  });

  // Action buttons
  document.addEventListener('click', async function(e) {
    var btn = e.target.closest('[data-action]');
    if (!btn) return;
    var action = btn.dataset.action;
    var id = btn.dataset.subId;

    if (action === 'reject') {
      var rejectForm = document.getElementById('reject-' + id);
      if (rejectForm) rejectForm.hidden = false;
      return;
    }

    if (action === 'confirm_reject') {
      var form = document.getElementById('reject-' + id);
      var reason = form.querySelector('.reject-reason').value.trim();
      if (!reason) { alert('Please provide a rejection reason.'); return; }
      btn.disabled = true;
      var res = await fetch('/api/admin/submissions/' + id, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status: 'rejected', rejection_reason: reason })
      });
      if (res.ok) location.reload();
      else alert('Error: ' + (await res.json()).error);
      btn.disabled = false;
      return;
    }

    if (action === 'send_ficha') {
      btn.disabled = true;
      btn.textContent = 'Sending…';
      var res = await fetch('/api/admin/send-ficha', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ submission_id: Number(id) })
      });
      if (res.ok) location.reload();
      else alert('Error: ' + (await res.json()).error);
      btn.disabled = false;
      return;
    }

    // Status change (under_review, approved)
    btn.disabled = true;
    var res = await fetch('/api/admin/submissions/' + id, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ status: action })
    });
    if (res.ok) location.reload();
    else alert('Error: ' + (await res.json()).error);
    btn.disabled = false;
  });
})();
</script>

<style>
  .admin-page {
    max-width: 960px;
    margin: 0 auto;
    padding: 3rem 1.5rem 6rem;
  }

  .admin-header { margin-bottom: 1.5rem; }

  .admin-header h1 {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    font-weight: 400;
    color: var(--text-primary);
    margin: 0 0 0.75rem;
  }

  .status-counts {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .status-count {
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--sc);
    background: color-mix(in srgb, var(--sc) 10%, transparent);
    padding: 0.25rem 0.625rem;
    border-radius: 4px;
  }

  /* Filter tabs */
  .filter-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-bottom: 2rem;
    border-bottom: 1px solid var(--surface-border);
    padding-bottom: 0.75rem;
  }

  .filter-tab {
    background: none;
    border: 1px solid transparent;
    border-radius: 4px;
    color: var(--text-muted);
    font-size: 0.72rem;
    font-weight: 500;
    padding: 0.375rem 0.75rem;
    cursor: pointer;
    transition: all 120ms ease;
  }

  .filter-tab:hover { color: var(--text-secondary); }
  .filter-tab.is-active {
    color: var(--text-primary);
    border-color: var(--surface-border-strong);
    background: var(--surface-card);
  }

  /* Cards */
  .sub-card {
    background: var(--surface-card);
    border: 1px solid var(--surface-border);
    border-radius: 8px;
    padding: 1.25rem;
    margin-bottom: 0.75rem;
  }

  .sub-card__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }

  .sub-card__title-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .type-badge {
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    background: var(--surface-elevated);
    padding: 0.2rem 0.5rem;
    border-radius: 3px;
  }

  .sub-card__title {
    font-family: var(--font-serif);
    font-size: 1.0625rem;
    font-weight: 400;
    color: var(--text-primary);
    margin: 0;
  }

  .sub-card__year {
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  .status-badge {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--sb);
    border: 1px solid var(--sb);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .sub-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
  }

  .sub-card__synopsis {
    margin-bottom: 0.75rem;
  }

  .sub-card__synopsis summary {
    font-size: 0.75rem;
    color: var(--text-muted);
    cursor: pointer;
  }

  .sub-card__synopsis p {
    font-size: 0.8rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0.5rem 0 0;
  }

  .drive-link {
    display: inline-block;
    font-size: 0.75rem;
    color: #4A90D9;
    margin-bottom: 0.75rem;
  }

  .drive-link:hover { text-decoration: underline; }

  .sub-card__notes { margin-bottom: 0.75rem; }

  .sub-card__notes label {
    display: block;
    font-size: 0.68rem;
    font-weight: 500;
    color: var(--text-muted);
    margin-bottom: 0.25rem;
  }

  .notes-textarea {
    width: 100%;
    background: var(--surface-elevated);
    border: 1px solid var(--surface-border);
    border-radius: 4px;
    color: var(--text-secondary);
    font-family: var(--font-sans);
    font-size: 0.78rem;
    padding: 0.5rem;
    resize: vertical;
    outline: none;
    box-sizing: border-box;
  }

  .notes-textarea:focus { border-color: var(--surface-border-strong); }

  /* Actions */
  .sub-card__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }

  .action-btn {
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.375rem 0.875rem;
    border-radius: 5px;
    border: 1px solid var(--surface-border);
    background: var(--surface-elevated);
    color: var(--text-secondary);
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    transition: all 120ms ease;
  }

  .action-btn:hover {
    border-color: var(--surface-border-strong);
    color: var(--text-primary);
  }

  .action-btn:disabled { opacity: 0.5; cursor: not-allowed; }

  .action-btn--primary {
    background: rgba(74, 144, 217, 0.1);
    border-color: rgba(74, 144, 217, 0.3);
    color: #4A90D9;
  }

  .action-btn--accent {
    background: rgba(212, 201, 168, 0.1);
    border-color: rgba(212, 201, 168, 0.3);
    color: var(--text-accent);
  }

  .action-btn--danger {
    background: rgba(142, 27, 27, 0.1);
    border-color: rgba(142, 27, 27, 0.3);
    color: #c04040;
  }

  .action-btn--subtle {
    border-color: transparent;
    color: var(--text-muted);
  }

  .ficha-note {
    font-size: 0.72rem;
    color: var(--text-accent);
    font-style: italic;
  }

  /* Reject form */
  .reject-form {
    margin-top: 0.75rem;
    display: flex;
    gap: 0.5rem;
    align-items: flex-end;
  }

  .reject-form[hidden] { display: none; }

  .reject-reason {
    flex: 1;
    background: var(--surface-elevated);
    border: 1px solid rgba(142, 27, 27, 0.3);
    border-radius: 4px;
    color: var(--text-secondary);
    font-family: var(--font-sans);
    font-size: 0.78rem;
    padding: 0.5rem;
    resize: vertical;
    outline: none;
    box-sizing: border-box;
  }

  .empty {
    color: var(--text-muted);
    font-size: 0.875rem;
    text-align: center;
    padding: 3rem 0;
  }
</style>
