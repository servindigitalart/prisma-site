---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  jsonLd?: string;
}

const { title, description, ogImage, jsonLd } = Astro.props;
---

<BaseLayout title={title} description={description} ogImage={ogImage} jsonLd={jsonLd}>
  <div class="film-page page-enter">
    <slot />
  </div>
</BaseLayout>

<style>
.film-page {
  /* hero starts at viewport top, nav overlays via fixed positioning */
}
</style>
