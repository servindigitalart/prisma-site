---
import BaseLayout from './BaseLayout.astro';
import type { BreadcrumbItem } from '../lib/seo/breadcrumbs';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  jsonLd?: string | Record<string, unknown>;
  jsonLdExtra?: Record<string, unknown>;
  breadcrumbs?: BreadcrumbItem[];
}

const { title, description, ogImage, ogType, jsonLd, jsonLdExtra, breadcrumbs } = Astro.props;
---

<BaseLayout title={title} description={description} ogImage={ogImage} ogType={ogType} jsonLd={jsonLd} jsonLdExtra={jsonLdExtra} breadcrumbs={breadcrumbs}>
  <div class="film-page page-enter">
    <slot />
  </div>
</BaseLayout>

<style>
.film-page {
  /* hero starts at viewport top, nav overlays via fixed positioning */
}
</style>
