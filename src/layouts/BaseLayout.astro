              <form action="/auth/signout" method="POST" style="margin-left:auto">
                <button type="submit" style="background:none;border:1px solid var(--surface-border);border-radius:4px;color:var(--text-muted);font-size:0.8rem;padding:0.5rem 0.875rem;cursor:pointer;">Cerrar sesión</button>
