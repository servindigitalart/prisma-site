---
import '../styles/global.css';
import AuthModal from '../components/auth/AuthModal.astro';
import { buildBreadcrumbJsonLd, type BreadcrumbItem } from '../lib/seo/breadcrumbs';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonicalUrl?: string;
  bodyClass?: string;
  jsonLd?: string | Record<string, unknown>;
  jsonLdExtra?: Record<string, unknown>;
  breadcrumbs?: BreadcrumbItem[];
}

const {
  title = 'PRISMA — Cine de Autor a través del Color',
  description = 'PRISMA — Descubre el cine de autor a través del color. Una base de datos cinematográfica curada con paletas visuales, rankings y análisis editorial.',
  ogImage,
  ogType = 'website',
  canonicalUrl,
  bodyClass = '',
  jsonLd,
  jsonLdExtra,
  breadcrumbs,
} = Astro.props;

const jsonLdString = jsonLd
  ? typeof jsonLd === 'string' ? jsonLd : JSON.stringify(jsonLd)
  : null;

const jsonLdExtraString = jsonLdExtra ? JSON.stringify(jsonLdExtra) : null;
const breadcrumbJsonLd = breadcrumbs?.length ? JSON.stringify(buildBreadcrumbJsonLd(breadcrumbs)) : null;

const siteUrl = 'https://prisma.film';
const resolvedCanonical = canonicalUrl ?? `${siteUrl}${Astro.url.pathname}`;
const resolvedOgImage = ogImage
  ? (ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`)
  : `${siteUrl}/og-default.jpg`;

// Auth state — read from middleware locals (set by session sync)
const user = Astro.locals.user;
---

<!doctype html>
<html lang="es" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Supabase config for client-side auth -->
    <meta name="supabase-url"      content={import.meta.env.PUBLIC_SUPABASE_URL} />
    <meta name="supabase-anon-key" content={import.meta.env.PUBLIC_SUPABASE_ANON_KEY} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={resolvedCanonical} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:url" content={resolvedCanonical} />
    <meta property="og:site_name" content="PRISMA" />
    <meta property="og:locale" content="es_MX" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />

    <!-- Structured data (JSON-LD) -->
    {jsonLdString && <script type="application/ld+json" set:html={jsonLdString} />}
    {jsonLdExtraString && <script type="application/ld+json" set:html={jsonLdExtraString} />}
    {breadcrumbJsonLd && <script type="application/ld+json" set:html={breadcrumbJsonLd} />}

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap.xml" />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/brand/isotipo.png" sizes="32x32" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts: DM Serif Display + Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class={bodyClass}>
    <!-- Site navigation -->
    <nav class="site-nav">
      <a href="/" class="site-nav-logo" aria-label="PRISMA — inicio">
        <span class="site-nav-logo-text">PRISMA</span>
      </a>

      <!-- Hamburger (mobile only) -->
      <button class="nav-hamburger" id="nav-hamburger" aria-label="Abrir menú" aria-expanded="false" aria-controls="nav-mobile-overlay">
        <span class="nav-hamburger__line"></span>
        <span class="nav-hamburger__line"></span>
        <span class="nav-hamburger__line"></span>
      </button>

      <ul class="site-nav-links">
        <li><a href="/rankings/films">Rankings</a></li>
        <li><a href="/colors">Colores</a></li>
        <li class="site-nav-dropdown" id="nav-explorar">
          <a href="/explorar" class="site-nav-trigger">Explorar</a>
          <div class="site-nav-dropdown-menu">
            <div class="site-nav-dropdown-menu-inner">
              <div class="site-nav-dropdown-group">
                <p class="site-nav-dropdown-label">Ritmo Visual</p>
                <a href="/ritmo/dinamico-frenetico">Frenético</a>
                <a href="/ritmo/dinamico-energico">Cinético</a>
                <a href="/ritmo/moderado-balanceado">Narrativo</a>
                <a href="/ritmo/lento-contemplativo">Contemplativo</a>
                <a href="/ritmo/estatico-ritualistico">Ritual</a>
              </div>
              <div class="site-nav-dropdown-group">
                <p class="site-nav-dropdown-label">Temperatura</p>
                <a href="/temperatura/calido-apasionado">Ardiente</a>
                <a href="/temperatura/calido-nostalgico">Nostálgico</a>
                <a href="/temperatura/neutral-contemplativo">Ecuánime</a>
                <a href="/temperatura/frio-melancolico">Melancólico</a>
                <a href="/temperatura/frio-perturbador">Perturbador</a>
                <a href="/temperatura/frio-alienado">Alienante</a>
              </div>
              <div class="site-nav-dropdown-group">
                <p class="site-nav-dropdown-label">Abstracción</p>
                <a href="/abstraccion/extremadamente-realista">Documental</a>
                <a href="/abstraccion/realista-con-estilizacion">Realista</a>
                <a href="/abstraccion/estilizado">Estilizado</a>
                <a href="/abstraccion/muy-estilizado">Expresionista</a>
                <a href="/abstraccion/extremadamente-abstracto">Surrealista</a>
              </div>
            </div>
          </div>
        </li>
        <li class="site-nav-dropdown" id="nav-decades">
          <a href="/decades" class="site-nav-trigger">Décadas</a>
          <div class="site-nav-dropdown-menu">
            <div class="site-nav-dropdown-menu-inner site-nav-dropdown-menu-inner--decades">
