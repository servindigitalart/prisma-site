---
import '../styles/global.css';
import AuthModal from '../components/auth/AuthModal.astro';
import { buildBreadcrumbJsonLd, type BreadcrumbItem } from '../lib/seo/breadcrumbs';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonicalUrl?: string;
  bodyClass?: string;
  jsonLd?: string | Record<string, unknown>;
  jsonLdExtra?: Record<string, unknown>;
  breadcrumbs?: BreadcrumbItem[];
}

const {
  title = 'PRISMA — Cine de Autor a través del Color',
  description = 'PRISMA — Descubre el cine de autor a través del color. Una base de datos cinematográfica curada con paletas visuales, rankings y análisis editorial.',
  ogImage,
  ogType = 'website',
  canonicalUrl,
  bodyClass = '',
  jsonLd,
  jsonLdExtra,
  breadcrumbs,
} = Astro.props;

const jsonLdString = jsonLd
  ? typeof jsonLd === 'string' ? jsonLd : JSON.stringify(jsonLd)
  : null;

const jsonLdExtraString = jsonLdExtra ? JSON.stringify(jsonLdExtra) : null;
const breadcrumbJsonLd = breadcrumbs?.length ? JSON.stringify(buildBreadcrumbJsonLd(breadcrumbs)) : null;

const siteUrl = 'https://prisma.film';
const resolvedCanonical = canonicalUrl ?? `${siteUrl}${Astro.url.pathname}`;
const resolvedOgImage = ogImage
  ? (ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`)
  : `${siteUrl}/og-default.jpg`;

// Auth state — read from middleware locals (set by session sync)
const user = Astro.locals.user;
---

<!doctype html>
<html lang="es" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Supabase config for client-side auth -->
    <meta name="supabase-url"      content={import.meta.env.PUBLIC_SUPABASE_URL} />
    <meta name="supabase-anon-key" content={import.meta.env.PUBLIC_SUPABASE_ANON_KEY} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={resolvedCanonical} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:url" content={resolvedCanonical} />
    <meta property="og:site_name" content="PRISMA" />
    <meta property="og:locale" content="es_MX" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />

    <!-- Structured data (JSON-LD) -->
    {jsonLdString && <script type="application/ld+json" set:html={jsonLdString} />}
    {jsonLdExtraString && <script type="application/ld+json" set:html={jsonLdExtraString} />}
    {breadcrumbJsonLd && <script type="application/ld+json" set:html={breadcrumbJsonLd} />}

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap.xml" />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/brand/isotipo.png" sizes="32x32" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts: DM Serif Display + Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class={bodyClass}>
    <!-- Site navigation -->
    <nav class="site-nav">
      <a href="/" class="site-nav-logo" aria-label="PRISMA — inicio">
        <span class="site-nav-logo-text">PRISMA</span>
      </a>
      <ul class="site-nav-links">
        <li><a href="/rankings/films">Rankings</a></li>
        <li><a href="/colors">Colores</a></li>
        <li class="site-nav-dropdown" id="nav-explorar">
          <a href="/explorar" class="site-nav-trigger">Explorar</a>
          <div class="site-nav-dropdown-menu">
            <div class="site-nav-dropdown-menu-inner">
              <div class="site-nav-dropdown-group">
                <p class="site-nav-dropdown-label">Ritmo Visual</p>
                <a href="/ritmo/dinamico-frenetico">Frenético</a>
                <a href="/ritmo/dinamico-energico">Cinético</a>
                <a href="/ritmo/moderado-balanceado">Narrativo</a>
                <a href="/ritmo/lento-contemplativo">Contemplativo</a>
                <a href="/ritmo/estatico-ritualistico">Ritual</a>
              </div>
              <div class="site-nav-dropdown-group">
                <p class="site-nav-dropdown-label">Temperatura</p>
                <a href="/temperatura/calido-apasionado">Ardiente</a>
                <a href="/temperatura/calido-nostalgico">Nostálgico</a>
                <a href="/temperatura/neutral-contemplativo">Ecuánime</a>
                <a href="/temperatura/frio-melancolico">Melancólico</a>
                <a href="/temperatura/frio-perturbador">Perturbador</a>
                <a href="/temperatura/frio-alienado">Alienante</a>
              </div>
              <div class="site-nav-dropdown-group">
                <p class="site-nav-dropdown-label">Abstracción</p>
                <a href="/abstraccion/extremadamente-realista">Documental</a>
                <a href="/abstraccion/realista-con-estilizacion">Realista</a>
                <a href="/abstraccion/estilizado">Estilizado</a>
                <a href="/abstraccion/muy-estilizado">Expresionista</a>
                <a href="/abstraccion/extremadamente-abstracto">Surrealista</a>
              </div>
            </div>
          </div>
        </li>
        <li class="site-nav-dropdown" id="nav-decades">
          <a href="/decades" class="site-nav-trigger">Décadas</a>
          <div class="site-nav-dropdown-menu">
            <div class="site-nav-dropdown-menu-inner site-nav-dropdown-menu-inner--decades">
              <a href="/decades" class="decades-all">Todas las décadas →</a>
              <div class="decades-grid">
                <a href="/decades/1920s">1920s</a>
                <a href="/decades/1930s">1930s</a>
                <a href="/decades/1940s">1940s</a>
                <a href="/decades/1950s">1950s</a>
                <a href="/decades/1960s">1960s</a>
                <a href="/decades/1970s">1970s</a>
                <a href="/decades/1980s">1980s</a>
                <a href="/decades/1990s">1990s</a>
                <a href="/decades/2000s">2000s</a>
                <a href="/decades/2010s">2010s</a>
                <a href="/decades/2020s">2020s</a>
              </div>
            </div>
          </div>
        </li>
        <li><a href="/countries">Países</a></li>
        <li><a href="/festivals">Festivales</a></li>
        <li><a href="/people">Cineastas</a></li>
        <li><a href="/submit" class="nav-submit">Enviar</a></li>
      </ul>

      <!-- Auth -->
      <div class="site-nav-auth">
        {user ? (
          <div class="nav-user">
            {user.user_metadata?.avatar_url ? (
              <a href={`/u/${user.id}`} class="nav-avatar-link" title="Mi perfil">
                <img
                  src={user.user_metadata.avatar_url}
                  alt={user.user_metadata?.full_name ?? 'Profile'}
                  class="nav-avatar"
                  referrerpolicy="no-referrer"
                />
              </a>
            ) : (
              <a href={`/u/${user.id}`} class="nav-avatar-link nav-avatar--initials" title="Mi perfil">
                {(user.user_metadata?.full_name ?? user.email ?? '?')[0].toUpperCase()}
              </a>
            )}
            <form action="/auth/signout" method="POST" style="display:inline">
              <button type="submit" class="nav-signout">Cerrar sesión</button>
            </form>
          </div>
        ) : (
          <button class="nav-signin" onclick="window.showAuthModal?.()">Iniciar sesión</button>
        )}
      </div>
    </nav>

    <!-- Auth modal — rendered once globally; shown via window.showAuthModal() -->
    {!user && <AuthModal />}

    <!-- Page content -->
    <slot />
    
    <!-- Design system: nav scroll state + scroll-reveal animations -->
    <script>
      // Nav scroll: add .scrolled class when page is scrolled past 40px
      const nav = document.querySelector('.site-nav');
      if (nav) {
        const updateNav = () => nav.classList.toggle('scrolled', window.scrollY > 40);
        window.addEventListener('scroll', updateNav, { passive: true });
        updateNav();
      }

      // Dropdown: JS-driven hover with bridge gap to prevent flicker
      function initDropdown(id: string) {
        const dropdown = document.getElementById(id);
        if (!dropdown) return;
        let closeTimer: ReturnType<typeof setTimeout> | null = null;
        dropdown.addEventListener('mouseenter', () => {
          if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }
          dropdown.classList.add('is-open');
        });
        dropdown.addEventListener('mouseleave', () => {
          closeTimer = setTimeout(() => {
            dropdown.classList.remove('is-open');
          }, 120);
        });
      }
      initDropdown('nav-explorar');
      initDropdown('nav-decades');

      // Scroll reveal: activate .reveal elements via IntersectionObserver
      if (typeof IntersectionObserver !== 'undefined') {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              const el = entry.target as HTMLElement;
              const delay = el.dataset.delay;
              if (delay) el.style.setProperty('--reveal-delay', `${delay}ms`);
              el.classList.add('is-visible');
              observer.unobserve(el);
            });
          },
          { rootMargin: '0px 0px -60px 0px', threshold: 0.08 }
        );
        document.querySelectorAll<HTMLElement>('.reveal').forEach((el) => observer.observe(el));
      } else {
        // Fallback: show everything
        document.querySelectorAll('.reveal').forEach((el) => el.classList.add('is-visible'));
      }
    </script>

    <!-- Client-side handlers -->
    <script is:inline>
      console.log('[BaseLayout] Client script loaded');
      
      // Handle sign out form submission
      const signOutForm = document.querySelector('form[action="/auth/signout"]');
      if (signOutForm) {
        console.log('[BaseLayout] Sign out form found, attaching handler');
        signOutForm.addEventListener('submit', function(e) {
          console.log('[BaseLayout] Sign out form submitted');
          // Let the form submit naturally, but force a page reload after
          setTimeout(function() {
            window.location.href = '/';
          }, 100);
        });
      }
    </script>
  </body>
</html>

<style>
/* ── Nav auth area ── */
.site-nav-auth {
  display: flex;
  align-items: center;
  margin-left: auto;
  padding-left: 1.5rem;
  flex-shrink: 0;
}

.nav-user {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.nav-avatar-link {
  display: block;
  width: 30px;
  height: 30px;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  transition: opacity 120ms ease;
}
.nav-avatar-link:hover { opacity: 0.8; }

.nav-avatar {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.nav-avatar--initials {
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--surface-card);
  border: 1px solid var(--surface-border);
  color: var(--text-secondary);
  font-size: 0.75rem;
  font-weight: 600;
  text-decoration: none;
}

.nav-signout {
  background: none;
  border: none;
  color: var(--text-muted);
  font-size: 0.75rem;
  cursor: pointer;
  padding: 0;
  transition: color 120ms ease;
}
.nav-signout:hover { color: var(--text-secondary); }

.nav-signin {
  background: none;
  border: 1px solid var(--surface-border);
  border-radius: 4px;
  color: var(--text-muted);
  font-size: 0.75rem;
  font-weight: 500;
  cursor: pointer;
  padding: 0.375rem 0.75rem;
  transition: color 120ms ease, border-color 120ms ease;
}
.nav-signin:hover {
  color: var(--text-primary);
  border-color: var(--surface-border-strong);
}

.nav-submit {
  color: var(--text-accent) !important;
  border: 1px solid rgba(212, 201, 168, 0.2);
  border-radius: 4px;
  padding: 0.25rem 0.625rem;
  transition: color var(--duration-fast) var(--ease-editorial), border-color var(--duration-fast) var(--ease-editorial);
}
.nav-submit:hover {
  color: var(--text-primary) !important;
  border-color: rgba(212, 201, 168, 0.4);
}

/* ── Decades dropdown layout ── */
.site-nav-dropdown-menu-inner--decades {
  grid-template-columns: 1fr !important;
  min-width: 260px !important;
  gap: 0.75rem !important;
}

.decades-all {
  display: block;
  font-size: 0.75rem;
  font-weight: 500;
  color: var(--text-accent) !important;
  letter-spacing: 0.04em;
  padding: 0.25rem 0.5rem;
  border-radius: var(--radius-sm);
  transition: color 120ms ease;
}
.decades-all:hover { color: var(--text-primary) !important; }

.decades-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0.25rem;
}

.decades-grid a {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.75rem !important;
  font-weight: 500;
  color: var(--text-secondary) !important;
  padding: 0.4rem 0.25rem !important;
  border-radius: var(--radius-sm);
  letter-spacing: 0.02em !important;
  text-transform: none !important;
  transition: all var(--dur-fast);
  text-align: center;
}
.decades-grid a:hover {
  color: var(--text-primary) !important;
  background: rgba(255,255,255,0.06);
}

/* Make site-nav-trigger work as a link */
a.site-nav-trigger {
  text-decoration: none;
}
</style>
