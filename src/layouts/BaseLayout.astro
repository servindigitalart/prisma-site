        {user
          ? <a href={`/u/${user.id}`} class="nav-bottom-bar__item"><span class="nav-bottom-bar__icon">👤</span><span>Cuenta</span></a>
          : <button class="nav-bottom-bar__item" style="background:none;border:none;cursor:pointer;" onclick="window.showAuthModal?.()"><span class="nav-bottom-bar__icon">👤</span><span>Cuenta</span></button>
        }
      </div>
    </nav>
    {!user && <AuthModal />}

    <!-- ─── Global search overlay ─────────────────────────────────────────── -->
    <div class="search-overlay" id="search-overlay" aria-hidden="true" role="dialog" aria-label="Buscar en PRISMA">
      <div class="search-overlay__backdrop" id="search-backdrop"></div>
      <div class="search-overlay__panel">
        <div class="search-overlay__input-row">
          <svg class="search-overlay__icon" width="18" height="18" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <circle cx="6.5" cy="6.5" r="4.5" stroke="currentColor" stroke-width="1.4"/>
            <path d="M10 10l3.5 3.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
          </svg>
          <input
            id="search-input"
            type="search"
            class="search-overlay__input"
            placeholder="Buscar películas, cineastas…"
            autocomplete="off"
            spellcheck="false"
          />
          <kbd class="search-overlay__esc">ESC</kbd>
        </div>
        <div class="search-overlay__results" id="search-results" aria-live="polite">
          <p class="search-overlay__hint">Escribe al menos 2 caracteres para buscar.</p>
        </div>
      </div>
    </div>

    <!-- Page content -->
    <slot />
    
    <!-- Design system: nav scroll state + scroll-reveal animations -->
    <script>
      // Nav scroll: add .scrolled class when page is scrolled past 40px
      const nav = document.querySelector('.site-nav');
      if (nav) {
        const updateNav = () => nav.classList.toggle('scrolled', window.scrollY > 40);
        window.addEventListener('scroll', updateNav, { passive: true });
        updateNav();
      }

      // Dropdown: JS-driven hover with bridge gap to prevent flicker
      function initDropdown(id: string) {
        const dropdown = document.getElementById(id);
        if (!dropdown) return;
        let closeTimer: ReturnType<typeof setTimeout> | null = null;
        dropdown.addEventListener('mouseenter', () => {
          if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }
          dropdown.classList.add('is-open');
        });
        dropdown.addEventListener('mouseleave', () => {
          closeTimer = setTimeout(() => {
            dropdown.classList.remove('is-open');
          }, 120);
        });
      }
      initDropdown('nav-explorar');
      initDropdown('nav-decades');

      // ── Mobile menu ──────────────────────────────────────────────────────
      const hamburger = document.getElementById('nav-hamburger');
      const overlay   = document.getElementById('nav-mobile-overlay');

      function openNavMenu() {
        hamburger?.classList.add('is-open');
        overlay?.classList.add('is-open');
        hamburger?.setAttribute('aria-expanded', 'true');
        overlay?.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
      }

      function closeNavMenu() {
        hamburger?.classList.remove('is-open');
        overlay?.classList.remove('is-open');
        hamburger?.setAttribute('aria-expanded', 'false');
        overlay?.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      }

      // Expose for inline onclick in auth buttons
      (window as any).closeNavMenu = closeNavMenu;

      hamburger?.addEventListener('click', () => {
        const isOpen = hamburger.classList.contains('is-open');
        isOpen ? closeNavMenu() : openNavMenu();
      });

      // Close on tap outside overlay content
      overlay?.addEventListener('click', (e) => {
        if (e.target === overlay) closeNavMenu();
      });

      // Close on Escape
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeNavMenu();
      });

      // Accordion items
      document.querySelectorAll<HTMLButtonElement>('.nav-mobile-accordion-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          const key = btn.dataset.accordion;
          const panel = document.getElementById(`accordion-${key}`);
          const isOpen = btn.classList.contains('is-open');
          // Close all others
          document.querySelectorAll('.nav-mobile-accordion-btn').forEach((b) => b.classList.remove('is-open'));
          document.querySelectorAll('.nav-mobile-accordion-content').forEach((p) => p.classList.remove('is-open'));
          if (!isOpen) {
            btn.classList.add('is-open');
            panel?.classList.add('is-open');
            btn.setAttribute('aria-expanded', 'true');
          } else {
            btn.setAttribute('aria-expanded', 'false');
          }
        });
      });

      // ── Global search ─────────────────────────────────────────────────────
      const searchOverlay = document.getElementById('search-overlay');
      const searchInput   = document.getElementById('search-input') as HTMLInputElement | null;
      const searchResults = document.getElementById('search-results');
      const searchBackdrop = document.getElementById('search-backdrop');

      function openSearch() {
        searchOverlay?.classList.add('is-open');
        searchOverlay?.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
        setTimeout(() => searchInput?.focus(), 50);
      }

      function closeSearch() {
        searchOverlay?.classList.remove('is-open');
        searchOverlay?.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
        if (searchInput) searchInput.value = '';
        if (searchResults) searchResults.innerHTML = '<p class="search-overlay__hint">Escribe al menos 2 caracteres para buscar.</p>';
      }

      document.getElementById('nav-search-btn')?.addEventListener('click', openSearch);
      searchBackdrop?.addEventListener('click', closeSearch);

      // Cmd+K / Ctrl+K to open
      document.addEventListener('keydown', (e) => {
        if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
          e.preventDefault();
          searchOverlay?.classList.contains('is-open') ? closeSearch() : openSearch();
        }
        if (e.key === 'Escape' && searchOverlay?.classList.contains('is-open')) {
          closeSearch();
        }
      });

      // Debounced search
      let searchTimer: ReturnType<typeof setTimeout> | null = null;
      searchInput?.addEventListener('input', () => {
        if (searchTimer) clearTimeout(searchTimer);
        const q = searchInput.value.trim();
        if (q.length < 2) {
          if (searchResults) searchResults.innerHTML = '<p class="search-overlay__hint">Escribe al menos 2 caracteres para buscar.</p>';
          return;
        }
        if (searchResults) searchResults.innerHTML = '<p class="search-overlay__hint search-overlay__hint--loading">Buscando…</p>';
        searchTimer = setTimeout(async () => {
          try {
            const res = await fetch(`/api/search?q=${encodeURIComponent(q)}`);
            const data = await res.json() as { films: Array<{id:string;title:string;year:number|null;poster:string|null;slug:string}>; people: Array<{id:string;name:string;photo:string|null;slug:string;role:string|null}> };
            renderSearchResults(data, q);
          } catch {
            if (searchResults) searchResults.innerHTML = '<p class="search-overlay__hint">Error al buscar. Inténtalo de nuevo.</p>';
          }
        }, 220);
      });

      function renderSearchResults(data: { films: Array<{id:string;title:string;year:number|null;poster:string|null;slug:string}>; people: Array<{id:string;name:string;photo:string|null;slug:string;role:string|null}> }, q: string) {
        if (!searchResults) return;
        const { films, people } = data;
        if (!films.length && !people.length) {
          searchResults.innerHTML = `<p class="search-overlay__hint">Sin resultados para "<strong>${q}</strong>".</p>`;
          return;
        }
        let html = '';
        if (films.length) {
          html += '<div class="search-section"><p class="search-section__label">Películas</p><ul class="search-list">';
          for (const f of films) {
            html += `<li><a href="/films/${f.slug}" class="search-item" onclick="(window as any).closeSearch?.()">`;
            if (f.poster) {
              html += `<img src="${f.poster}" alt="${f.title}" class="search-item__img" loading="lazy" />`;
            } else {
              html += `<span class="search-item__img search-item__img--placeholder"></span>`;
            }
            html += `<span class="search-item__info"><span class="search-item__title">${f.title}</span>`;
            if (f.year) html += `<span class="search-item__meta">${f.year}</span>`;
            html += `</span></a></li>`;
          }
          html += '</ul></div>';
        }
        if (people.length) {
          html += '<div class="search-section"><p class="search-section__label">Cineastas</p><ul class="search-list">';
          for (const p of people) {
            html += `<li><a href="/people/${p.slug}" class="search-item" onclick="(window as any).closeSearch?.()">`;
            if (p.photo) {
              html += `<img src="${p.photo}" alt="${p.name}" class="search-item__img search-item__img--round" loading="lazy" />`;
            } else {
              html += `<span class="search-item__img search-item__img--placeholder search-item__img--round"></span>`;
            }
            html += `<span class="search-item__info"><span class="search-item__title">${p.name}</span>`;
            if (p.role) html += `<span class="search-item__meta">${p.role}</span>`;
            html += `</span></a></li>`;
          }
          html += '</ul></div>';
        }
        searchResults.innerHTML = html;

        // Close search on result click
        searchResults.querySelectorAll<HTMLAnchorElement>('.search-item').forEach((a) => {
          a.addEventListener('click', closeSearch);
        });
      }

      // Expose for inline handlers
      (window as any).closeSearch = closeSearch;

      // Scroll reveal: activate .reveal elements via IntersectionObserver
      if (typeof IntersectionObserver !== 'undefined') {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              const el = entry.target as HTMLElement;
              const delay = el.dataset.delay;
              if (delay) el.style.setProperty('--reveal-delay', `${delay}ms`);
              el.classList.add('is-visible');
              observer.unobserve(el);
            });
          },
          { rootMargin: '0px 0px -60px 0px', threshold: 0.08 }
        );
        document.querySelectorAll<HTMLElement>('.reveal').forEach((el) => observer.observe(el));
      } else {
        // Fallback: show everything
        document.querySelectorAll('.reveal').forEach((el) => el.classList.add('is-visible'));
      }
    </script>

    <!-- Client-side handlers -->
    <script is:inline>
      console.log('[BaseLayout] Client script loaded');
      
      // Handle sign out form submission
      const signOutForm = document.querySelector('form[action="/auth/signout"]');
      if (signOutForm) {
        console.log('[BaseLayout] Sign out form found, attaching handler');
        signOutForm.addEventListener('submit', function(e) {
          console.log('[BaseLayout] Sign out form submitted');
          // Let the form submit naturally, but force a page reload after
          setTimeout(function() {
            window.location.href = '/';
          }, 100);
        });
      }
    </script>
  </body>
</html>

