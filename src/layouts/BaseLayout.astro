        <a href="/people" class="nav-mobile-item">Cineastas</a>
        <a href="/submit" class="nav-mobile-item">Enviar</a>

        <!-- Auth -->
        <div class="nav-mobile-auth">
          {user ? (
            <div style="display:flex; align-items:center; gap:1rem;">
              <a href={`/u/${user.id}`} style="display:flex; align-items:center; gap:0.75rem; text-decoration:none; color:var(--text-secondary); font-size:0.95rem;">
                {user.user_metadata?.avatar_url
                  ? <img src={user.user_metadata.avatar_url} alt="" style="width:36px;height:36px;border-radius:50%;object-fit:cover;" referrerpolicy="no-referrer" />
                  : <span style="width:36px;height:36px;border-radius:50%;background:var(--surface-card);border:1px solid var(--surface-border);display:flex;align-items:center;justify-content:center;font-size:0.8rem;font-weight:600;">{(user.user_metadata?.full_name ?? user.email ?? '?')[0].toUpperCase()}</span>
