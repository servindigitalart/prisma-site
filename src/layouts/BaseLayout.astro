                <a href="/ritmo/dinamico-frenetico" class="nav-mobile-sublink">Frenético</a>
                <a href="/ritmo/dinamico-energico" class="nav-mobile-sublink">Cinético</a>
                <a href="/ritmo/moderado-balanceado" class="nav-mobile-sublink">Narrativo</a>
                <a href="/ritmo/lento-contemplativo" class="nav-mobile-sublink">Contemplativo</a>
                <a href="/ritmo/estatico-ritualistico" class="nav-mobile-sublink">Ritual</a>
              </div>
            </div>
            <div class="nav-mobile-subgroup">
