                <a href="/decades/1960s">1960s</a>
                <a href="/decades/1970s">1970s</a>
                <a href="/decades/1980s">1980s</a>
                <a href="/decades/1990s">1990s</a>
                <a href="/decades/2000s">2000s</a>
                <a href="/decades/2010s">2010s</a>
                <a href="/decades/2020s">2020s</a>
              </div>
            </div>
          </div>
        </li>
        <li><a href="/genres">Géneros</a></li>
        <li><a href="/studios">Estudios</a></li>
        <li><a href="/countries">Países</a></li>
        <li><a href="/festivals">Festivales</a></li>
        <li><a href="/people">Cineastas</a></li>
        <li><a href="/submit" class="nav-submit">Enviar</a></li>
      </ul>

      <!-- Search trigger (desktop) -->
      <button class="nav-search-btn" id="nav-search-btn" aria-label="Buscar" title="Buscar (⌘K)">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <circle cx="6.5" cy="6.5" r="4.5" stroke="currentColor" stroke-width="1.4"/>
          <path d="M10 10l3.5 3.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
        </svg>
      </button>

      <!-- Auth (desktop) -->
      <div class="site-nav-auth">
        {user ? (
          <div class="nav-user">
            {user.user_metadata?.avatar_url ? (
              <a href={`/u/${user.id}`} class="nav-avatar-link" title="Mi perfil">
                <img
                  src={user.user_metadata.avatar_url}
                  alt={user.user_metadata?.full_name ?? 'Profile'}
