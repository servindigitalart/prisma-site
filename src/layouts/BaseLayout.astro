              </div>
            </div>
          </div>
        </div>

        <!-- Décadas accordion -->
        <button class="nav-mobile-accordion-btn" id="mob-acc-decades" aria-expanded="false">
          Décadas
          <span class="nav-mobile-accordion-btn__chevron">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M2 5l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </button>
        <div class="nav-mobile-accordion-content" id="mob-acc-decades-panel">
          <div class="nav-mobile-accordion-content__inner">
            <div class="nav-mobile-decades-grid">
              <a href="/decades/1920s">1920s</a>
              <a href="/decades/1930s">1930s</a>
              <a href="/decades/1940s">1940s</a>
              <a href="/decades/1950s">1950s</a>
              <a href="/decades/1960s">1960s</a>
              <a href="/decades/1970s">1970s</a>
              <a href="/decades/1980s">1980s</a>
              <a href="/decades/1990s">1990s</a>
              <a href="/decades/2000s">2000s</a>
              <a href="/decades/2010s">2010s</a>
              <a href="/decades/2020s">2020s</a>
            </div>
          </div>
        </div>

        <!-- Remaining top-level items -->
        <a href="/genres"     class="nav-mobile-item">Géneros</a>
        <a href="/studios"    class="nav-mobile-item">Estudios</a>
        <a href="/countries"  class="nav-mobile-item">Países</a>
        <a href="/festivals"  class="nav-mobile-item">Festivales</a>
        <a href="/people"     class="nav-mobile-item">Cineastas</a>
        <a href="/submit"     class="nav-mobile-item">Enviar</a>

        <!-- Auth at bottom -->
        <div class="nav-mobile-auth">
          {user ? (
            <div style="display:flex; align-items:center; gap:1rem;">
              <a href={`/u/${user.id}`} style="color:var(--text-secondary); font-size:0.9rem;">
                {user.user_metadata?.full_name ?? user.email ?? 'Mi perfil'}
              </a>
              <form action="/auth/signout" method="POST" style="display:inline">
                <button type="submit" class="nav-signout" style="font-size:0.85rem;">Cerrar sesión</button>
              </form>
            </div>
          ) : (
            <button
              class="nav-signin"
              style="width:100%; padding:0.75rem; font-size:0.9rem;"
              onclick="window.showAuthModal?.(); document.getElementById('nav-mobile-overlay')?.classList.remove('is-open');"
            >
              Iniciar sesión
            </button>
          )}
        </div>

      </div>
    </div>

    <!-- Fixed bottom navigation bar (mobile only) -->
    <nav class="nav-bottom-bar" aria-label="Navegación principal">
      <div class="nav-bottom-bar__inner">
        <a href="/rankings/films" class="nav-bottom-bar__item">
          <span class="nav-bottom-bar__icon">🎬</span>
          <span>Películas</span>
        </a>
        <a href="/colors" class="nav-bottom-bar__item">
          <span class="nav-bottom-bar__icon">🎨</span>
          <span>Colores</span>
