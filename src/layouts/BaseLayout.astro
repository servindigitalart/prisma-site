          </a>
        ) : (
          <button
            class="nav-bottom-bar__item"
            style="background:none; border:none; cursor:pointer; font-family:var(--font-sans);"
            onclick="window.showAuthModal?.()"
          >
            <span class="nav-bottom-bar__icon">👤</span>
            <span>Cuenta</span>
          </button>
        )}
      </div>
    </nav>

    <!-- ─── Mobile overlay menu ──────────────────────────────────────────── -->
    <div class="nav-mobile-overlay" id="nav-mobile-overlay" aria-hidden="true" role="dialog" aria-label="Menú de navegación">
      <div class="nav-mobile-overlay__inner">

        <a href="/rankings/films" class="nav-mobile-item">Rankings</a>
        <a href="/colors" class="nav-mobile-item">Colores</a>

        <!-- Explorar accordion -->
        <button class="nav-mobile-accordion-btn" data-accordion="explorar" aria-expanded="false">
          Explorar
          <span class="nav-mobile-accordion-btn__chevron">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
