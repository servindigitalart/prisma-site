                <a href="/ritmo/lento-contemplativo" class="nav-mobile-sublink">Contemplativo</a>
                <a href="/ritmo/estatico-ritualistico" class="nav-mobile-sublink">Ritual</a>
              </div>
            </div>
            <div class="nav-mobile-subgroup">
              <p class="nav-mobile-subgroup__label">Temperatura</p>
              <div class="nav-mobile-subgroup__links">
                <a href="/temperatura/calido-apasionado" class="nav-mobile-sublink">Ardiente</a>
                <a href="/temperatura/calido-nostalgico" class="nav-mobile-sublink">Nostálgico</a>
                <a href="/temperatura/neutral-contemplativo" class="nav-mobile-sublink">Ecuánime</a>
                <a href="/temperatura/frio-melancolico" class="nav-mobile-sublink">Melancólico</a>
                <a href="/temperatura/frio-perturbador" class="nav-mobile-sublink">Perturbador</a>
                <a href="/temperatura/frio-alienado" class="nav-mobile-sublink">Alienante</a>
              </div>
            </div>
            <div class="nav-mobile-subgroup">
              <p class="nav-mobile-subgroup__label">Abstracción</p>
              <div class="nav-mobile-subgroup__links">
                <a href="/abstraccion/extremadamente-realista" class="nav-mobile-sublink">Documental</a>
                <a href="/abstraccion/realista-con-estilizacion" class="nav-mobile-sublink">Realista</a>
                <a href="/abstraccion/estilizado" class="nav-mobile-sublink">Estilizado</a>
                <a href="/abstraccion/muy-estilizado" class="nav-mobile-sublink">Expresionista</a>
                <a href="/abstraccion/extremadamente-abstracto" class="nav-mobile-sublink">Surrealista</a>
              </div>
            </div>
          </div>
        </div>

        <!-- Décadas accordion -->
        <button class="nav-mobile-accordion-btn" data-accordion="decades" aria-expanded="false">
          Décadas
          <span class="nav-mobile-accordion-btn__chevron">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
