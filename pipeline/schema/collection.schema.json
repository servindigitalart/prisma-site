{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Collection Schema",
  "description": "Schema for editorial collections (curated essays with film selections)",
  "type": "object",
  "required": ["id", "title", "slug", "essay", "primary_color", "films", "created_at"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique collection identifier",
      "pattern": "^collection_"
    },
    "title": {
      "type": "string",
      "description": "Collection title",
      "minLength": 1,
      "maxLength": 100
    },
    "slug": {
      "type": "string",
      "description": "URL-friendly slug",
      "pattern": "^[a-z0-9-]+$"
    },
    "subtitle": {
      "type": "string",
      "description": "Optional subtitle or tagline",
      "maxLength": 200
    },
    "essay": {
      "type": "string",
      "description": "Main essay content (Markdown supported)",
      "minLength": 100
    },
    "primary_color": {
      "type": "string",
      "description": "Primary color this collection explores",
      "pattern": "^(azul_profundo|verde_esperanza|ambar_dorado|rojo_pasion|violeta_onirico|turquesa_retro|rosa_melancolico|naranja_vibrante|gris_industrial|sepia_nostalgico|cyan_clinico|verde_acido|claroscuro_dramatico|monocromatico_intimo)$"
    },
    "themes": {
      "type": "array",
      "description": "Thematic tags for collection",
      "items": {"type": "string"},
      "minItems": 1,
      "maxItems": 5
    },
    "films": {
      "type": "array",
      "description": "Films included in collection",
      "minItems": 3,
      "maxItems": 30,
      "items": {
        "type": "object",
        "required": ["work_id"],
        "properties": {
          "work_id": {
            "type": "string",
            "pattern": "^work_"
          },
          "note": {
            "type": "string",
            "description": "Curator's note about why this film is included",
            "maxLength": 500
          },
          "position": {
            "type": "integer",
            "description": "Order in collection (1-based)",
            "minimum": 1
          },
          "featured": {
            "type": "boolean",
            "description": "Whether to feature this film prominently",
            "default": false
          }
        }
      }
    },
    "people": {
      "type": "array",
      "description": "Key people featured in collection (directors, DPs)",
      "items": {
        "type": "object",
        "required": ["person_id", "role"],
        "properties": {
          "person_id": {
            "type": "string",
            "pattern": "^person_"
          },
          "role": {
            "type": "string",
            "enum": ["director", "cinematographer", "production_designer", "other"]
          },
          "note": {
            "type": "string",
            "description": "Note about their contribution to the color theme",
            "maxLength": 300
          }
        }
      }
    },
    "references": {
      "type": "array",
      "description": "External references and further reading",
      "items": {
        "type": "object",
        "properties": {
          "title": {"type": "string"},
          "url": {"type": "string", "format": "uri"},
          "type": {
            "type": "string",
            "enum": ["article", "book", "video", "interview", "other"]
          }
        }
      }
    },
    "curator": {
      "type": "object",
      "description": "Collection curator information",
      "required": ["name"],
      "properties": {
        "name": {"type": "string"},
        "bio": {"type": "string", "maxLength": 200},
        "avatar_url": {"type": "string", "format": "uri"}
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO8601 timestamp"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        },
        "published": {
          "type": "boolean",
          "description": "Whether collection is publicly visible",
          "default": false
        },
        "featured": {
          "type": "boolean",
          "description": "Whether to feature on homepage",
          "default": false
        },
        "view_count": {
          "type": "integer",
          "description": "Number of views (if tracking enabled)",
          "minimum": 0
        }
      }
    },
    "og_image": {
      "type": "string",
      "description": "Path to Open Graph image for social sharing",
      "pattern": "^/og/collections/"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO8601 timestamp of creation"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO8601 timestamp of last update"
    }
  }
}
