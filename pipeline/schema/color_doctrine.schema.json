{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Color Doctrine Schema",
  "description": "Schema for color_doctrine.json - defines Prisma color palette and assignment rules",
  "type": "object",
  "required": ["version", "last_updated", "colors", "monochromatic_modes", "assignment_rules"],
  "properties": {
    "$schema": {"type": "string"},
    "version": {"type": "string", "pattern": "^\\d+\\.\\d+$"},
    "last_updated": {"type": "string", "format": "date"},
    "colors": {
      "type": "array",
      "minItems": 12,
      "maxItems": 12,
      "items": {
        "type": "object",
        "required": ["id", "hex", "name", "moods", "genre_associations", "cinematographic_notes"],
        "properties": {
          "id": {"type": "string"},
          "hex": {"type": "string", "pattern": "^#[0-9a-fA-F]{6}$"},
          "name": {"type": "string"},
          "moods": {"type": "array", "items": {"type": "string"}},
          "genre_associations": {"type": "array", "items": {"type": "string"}},
          "cinematographic_notes": {"type": "string"}
        }
      }
    },
    "monochromatic_modes": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "type": "object",
        "required": ["id", "name", "description", "moods", "genre_associations", "cinematographic_notes"],
        "properties": {
          "id": {"type": "string"},
          "name": {"type": "string"},
          "description": {"type": "string"},
          "moods": {"type": "array", "items": {"type": "string"}},
          "genre_associations": {"type": "array", "items": {"type": "string"}},
          "cinematographic_notes": {"type": "string"},
          "historical_context": {"type": "string"}
        }
      }
    },
    "assignment_rules": {
      "type": "object",
      "required": ["primary_color", "secondary_colors", "monochromatic_detection"],
      "properties": {
        "primary_color": {"type": "object"},
        "secondary_colors": {"type": "object"},
        "monochromatic_detection": {"type": "object"},
        "edge_cases": {"type": "object"}
      }
    }
  }
}
