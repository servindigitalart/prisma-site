# ─────────────────────────────────────────────────────────────────────────────
# PRISMA — Environment Variables
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

# Project URL (safe for client-side — prefixed PUBLIC_)
PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Anon/public key (safe for client-side — respects RLS)
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key (SERVER-SIDE ONLY — bypasses RLS — NEVER expose to browser)
# Used by: migrate_to_db.py, Astro build-time queries, API routes
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ─── Google Gemini AI ─────────────────────────────────────────────────────────
# Used by: pipeline/2a_reason/, pipeline/2d_execute_research/
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ─── TMDB (The Movie Database) ────────────────────────────────────────────────
# Used by: pipeline/ingest_tmdb.py
# Get from: https://www.themoviedb.org/settings/api
# Pro plan ($50/year) recommended for batch ingestion
TMDB_API_KEY=your-tmdb-api-key-here
TMDB_ACCESS_TOKEN=your-tmdb-v4-bearer-token-here

# ─── OMDB (IMDB ratings) ──────────────────────────────────────────────────────
# Used by: pipeline/omdb_fetch.py (Phase 3 enrichment)
# Get from: https://www.omdbapi.com/apikey.aspx ($1/month for 100K requests/day)
OMDB_API_KEY=your-omdb-api-key-here

# ─── Bunny Stream (short film hosting) ───────────────────────────────────────
# Used by: streaming player, film submission approval workflow
# Get from: https://panel.bunny.net → Stream → API
BUNNY_LIBRARY_ID=your-bunny-library-id
BUNNY_API_KEY=your-bunny-api-key-here
BUNNY_CDN_HOSTNAME=your-cdn-hostname.b-cdn.net
# Security token for signed URL generation (prevents hotlinking)
BUNNY_TOKEN_AUTH_KEY=your-bunny-token-authentication-key

# ─── Resend (transactional email) ────────────────────────────────────────────
# Used by: filmmaker submission notifications, user auth emails
# Get from: https://resend.com/api-keys
# Free tier: 3,000 emails/month, 100/day
RESEND_API_KEY=re_your-resend-api-key-here

# ─── Site ─────────────────────────────────────────────────────────────────────
# The canonical public URL (used for sitemap, OG images, canonical links)
PUBLIC_SITE_URL=https://prisma.film

# ─── Optional: Google Search Console ────────────────────────────────────────
# Used by: /admin/seo dashboard (Phase 6)
# Get from: Google Search Console → Settings → Users & Permissions
# GOOGLE_SEARCH_CONSOLE_KEY=your-gsc-service-account-key-json-base64
