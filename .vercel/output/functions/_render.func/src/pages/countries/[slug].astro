---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { isSupabaseConfigured, createServiceClient } from '../../lib/db/client';
import { getPaletteEntry } from '../../lib/color/colorPalette';
import { isoToFlag, isoToName, slugToIso } from '../../lib/countries';
import { loadAllWorks } from '../../lib/loaders/loadWork';
import type { PrismaColorId } from '../../lib/db/types';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/404');

const iso2 = slugToIso(slug);
const countryName = isoToName(iso2);
const countryFlag = isoToFlag(iso2);

type FilmEntry = {
  id: string;
  title: string;
  year: number | null;
  tmdb_poster_path: string | null;
  color_iconico: PrismaColorId | null;
  numeric_score: number | null;
};

let films: FilmEntry[] = [];

if (isSupabaseConfigured()) {
  const db = createServiceClient();
  const { data, error } = await db
    .from('works')
    .select(`
      id,
      title,
      year,
      tmdb_poster_path,
      color_assignments(color_iconico, numeric_score)
    `)
    .contains('countries', [iso2])
    .eq('is_published', true)
    .order('year', { ascending: false })
    .limit(500);

  if (error) console.error('[countries/slug] Error:', error);

  for (const row of (data ?? []) as any[]) {
    const ca = Array.isArray(row.color_assignments)
      ? row.color_assignments[0]
      : row.color_assignments;
    films.push({
      id: row.id,
      title: row.title,
      year: row.year,
      tmdb_poster_path: row.tmdb_poster_path,
      color_iconico: ca?.color_iconico ?? null,
      numeric_score: ca?.numeric_score ?? null,
    });
  }
} else {
  const works = loadAllWorks();
  films = works
    .filter((w) => (w.countries ?? []).includes(iso2))
    .map((w) => ({
      id: w.id,
      title: w.title,
      year: w.year ?? null,
      tmdb_poster_path: w.media?.poster_path ?? null,
      color_iconico: (w.prisma_palette?.primary as PrismaColorId) ?? null,
      numeric_score: null,
    }));
}

if (films.length === 0) return Astro.redirect('/404');

// Top 5 poster row — films with posters, sorted by score desc
const TMDB_IMG = 'https://image.tmdb.org/t/p/w342';
const top5 = films
  .filter((f) => f.tmdb_poster_path)
  .sort((a, b) => (b.numeric_score ?? 0) - (a.numeric_score ?? 0))
  .slice(0, 5);

// Film list sorted: scored first (score desc), then unscored (year desc)
const sorted = [...films].sort((a, b) => {
  if (a.numeric_score != null && b.numeric_score != null) return b.numeric_score - a.numeric_score;
  if (a.numeric_score != null) return -1;
  if (b.numeric_score != null) return 1;
  return (b.year ?? 0) - (a.year ?? 0);
});

const pageTitle = `${countryFlag} ${countryName} — PRISMA`;
const pageDescription = `${films.length} films from ${countryName} in the PRISMA catalog.`;
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <div class="country-page page-enter">

    <!-- Header -->
    <section class="country-header">
      <div class="site-container">
        <div class="country-header__inner">
          <div class="country-header__flag" aria-hidden="true">{countryFlag}</div>
          <div class="country-header__info">
            <div class="country-header__overline">National Cinema</div>
            <h1 class="country-header__name">{countryName}</h1>
            <p class="country-header__count">{films.length} {films.length === 1 ? 'film' : 'films'} in the catalog</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Top 5 poster row -->
    {top5.length > 0 && (
      <section class="country-posters">
        <div class="site-container">
          <div class="country-posters__label">Top Films</div>
          <div class="poster-row">
            {top5.map((film, i) => {
              const filmSlug = film.id.replace(/^work_/, '');
              const palette = film.color_iconico ? getPaletteEntry(film.color_iconico) : null;
              return (
                <a href={`/films/${filmSlug}`} class="poster-card">
                  <img
                    src={`${TMDB_IMG}${film.tmdb_poster_path}`}
                    alt={film.title}
                    class="poster-card__img"
                    loading="lazy"
                    decoding="async"
                  />
                  <span class="poster-card__num">#{i + 1}</span>
                  <div class="poster-card__overlay">
                    <span class="poster-card__overlay-title">{film.title}</span>
                    {film.year && <span class="poster-card__overlay-year">{film.year}</span>}
                    {palette && (
                      <span class="poster-card__overlay-color" style={`color: ${palette.hex}`}>
                        {palette.name}
                      </span>
                    )}
                  </div>
                </a>
              );
            })}
          </div>
        </div>
      </section>
    )}

    <!-- Film list -->
    <section class="country-films">
      <div class="site-container">
        <h2 class="country-films__heading">Filmography</h2>
        <div class="country-films__list">
          {sorted.map((film) => {
            const filmSlug = film.id.replace(/^work_/, '');
            const palette = film.color_iconico ? getPaletteEntry(film.color_iconico) : null;
            return (
              <a href={`/films/${filmSlug}`} class="country-film-row">
                <div
                  class="country-film-row__strip"
                  style={palette ? `background: ${palette.hex}` : 'background: var(--surface-border)'}
                />
                <div class="country-film-row__year">
                  {film.year ?? '—'}
                </div>
                <div class="country-film-row__info">
                  <span class="country-film-row__title">{film.title}</span>
                  {palette && (
                    <span class="country-film-row__color">{palette.name}</span>
                  )}
                </div>
                {film.numeric_score != null && (
                  <div class="country-film-row__score">
                    {film.numeric_score.toFixed(1)}
                  </div>
                )}
              </a>
            );
          })}
        </div>
      </div>
    </section>

  </div>
</BaseLayout>

<style>
.country-page {
  padding-bottom: 6rem;
}

/* ─── Header ──────────────────────────────────────────────────────────────── */
.country-header {
  padding-top: 9rem;
  padding-bottom: 4rem;
  border-bottom: 1px solid var(--surface-border);
}

.country-header__inner {
  display: flex;
  gap: 2rem;
  align-items: center;
}

.country-header__flag {
  font-size: 3.5rem;
  line-height: 1;
  flex-shrink: 0;
}

.country-header__overline {
  font-size: 0.65rem;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 0.5rem;
}

.country-header__name {
  font-family: var(--font-serif);
  font-size: clamp(2rem, 5vw, 3.5rem);
  font-weight: 400;
  color: var(--text-primary);
  margin-bottom: 0.5rem;
}

.country-header__count {
  font-size: 0.8rem;
  color: var(--text-muted);
  font-family: var(--font-mono);
}

/* ─── Poster row ──────────────────────────────────────────────────────────── */
.country-posters {
  padding: 3rem 0 0;
}

.country-posters__label {
  font-family: var(--font-sans);
  font-size: 0.65rem;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 1rem;
}

.poster-row {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 1rem;
}

.poster-card {
  position: relative;
  display: block;
  aspect-ratio: 2 / 3;
  border-radius: 3px;
  overflow: hidden;
  text-decoration: none;
  background: var(--surface-card);
}

.poster-card__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  display: block;
  transition: transform 220ms ease;
}
.poster-card:hover .poster-card__img { transform: scale(1.03); }

.poster-card__num {
  position: absolute;
  top: 0.5rem;
  left: 0.5rem;
  font-family: var(--font-mono);
  font-size: 0.65rem;
  color: rgba(255,255,255,0.55);
  pointer-events: none;
  text-shadow: 0 1px 3px rgba(0,0,0,0.6);
}

.poster-card__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.88) 0%, rgba(0,0,0,0.3) 45%, transparent 70%);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 0.625rem 0.625rem 0.75rem;
  opacity: 0;
  transform: translateY(4px);
  transition: opacity 180ms ease, transform 180ms ease;
}
.poster-card:hover .poster-card__overlay { opacity: 1; transform: translateY(0); }

.poster-card__overlay-title {
  font-size: 0.72rem;
  color: #F0EEE8;
  line-height: 1.3;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.poster-card__overlay-year {
  font-size: 0.62rem;
  color: rgba(240,238,232,0.6);
  margin-top: 0.2rem;
  font-family: var(--font-mono);
}

.poster-card__overlay-color {
  font-size: 0.6rem;
  margin-top: 0.25rem;
  opacity: 0.8;
  font-family: var(--font-mono);
  letter-spacing: 0.05em;
}

@media (max-width: 640px) {
  .poster-row {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    gap: 0.625rem;
    padding-bottom: 0.5rem;
    scrollbar-width: none;
  }
  .poster-row::-webkit-scrollbar { display: none; }
  .poster-card {
    width: 140px;
    min-width: 140px;
    aspect-ratio: 2 / 3;
    scroll-snap-align: start;
  }
}

/* ─── Film list ────────────────────────────────────────────────────────────── */
.country-films {
  padding: 3rem 0;
}

.country-films__heading {
  font-family: var(--font-serif);
  font-size: 1.5rem;
  font-weight: 400;
  color: var(--text-primary);
  margin-bottom: 2rem;
}

.country-films__list {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.country-film-row {
  display: grid;
  grid-template-columns: 3px 4rem 1fr auto;
  align-items: center;
  gap: 1.25rem;
  padding: 0.875rem 0;
  border-bottom: 1px solid var(--surface-border);
  text-decoration: none;
  transition: background 160ms ease;
}

.country-film-row:hover {
  background: var(--surface-card);
  padding-left: 0.75rem;
  margin-left: -0.75rem;
  border-radius: 3px;
}

.country-film-row__strip {
  width: 3px;
  height: 2rem;
  border-radius: 1.5px;
  flex-shrink: 0;
}

.country-film-row__year {
  font-family: var(--font-mono);
  font-size: 0.8rem;
  color: var(--text-muted);
  text-align: right;
}

.country-film-row__info {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  min-width: 0;
}

.country-film-row__title {
  font-size: 0.9rem;
  color: var(--text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  transition: color 160ms ease;
}
.country-film-row:hover .country-film-row__title { color: var(--text-primary); }

.country-film-row__color {
  font-size: 0.7rem;
  color: var(--text-muted);
  flex-shrink: 0;
}

.country-film-row__score {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  color: var(--text-muted);
  flex-shrink: 0;
}

@media (max-width: 600px) {
  .country-film-row { grid-template-columns: 3px 3.5rem 1fr; }
  .country-film-row__score { display: none; }
  .country-header__inner { gap: 1.25rem; }
  .country-header__flag { font-size: 2.5rem; }
}
</style>
