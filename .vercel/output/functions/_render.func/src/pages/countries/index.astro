---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { isSupabaseConfigured, createServiceClient } from '../../lib/db/client';
import { isoToFlag, isoToName, countryToSlug } from '../../lib/countries';
import { loadAllWorks } from '../../lib/loaders/loadWork';

type CountryEntry = {
  iso2: string;
  name: string;
  flag: string;
  slug: string;
  count: number;
};

const countMap: Map<string, number> = new Map();

if (isSupabaseConfigured()) {
  const db = createServiceClient();
  const { data } = await db
    .from('works')
    .select('countries')
    .eq('is_published', true)
    .limit(2000);

  for (const row of (data ?? []) as { countries: string[] }[]) {
    for (const iso2 of (row.countries ?? [])) {
      countMap.set(iso2, (countMap.get(iso2) ?? 0) + 1);
    }
  }
} else {
  const works = loadAllWorks();
  for (const w of works) {
    for (const iso2 of (w.countries ?? [])) {
      countMap.set(iso2, (countMap.get(iso2) ?? 0) + 1);
    }
  }
}

const countries: CountryEntry[] = Array.from(countMap.entries())
  .map(([iso2, count]) => ({
    iso2,
    name: isoToName(iso2),
    flag: isoToFlag(iso2),
    slug: countryToSlug(iso2),
    count,
  }))
  .sort((a, b) => b.count - a.count);

const totalFilms = Array.from(countMap.values()).reduce((s, c) => s + c, 0);

const SITE = 'https://prisma.film';

const countriesBreadcrumbs = [
  { name: 'PRISMA', url: SITE },
  { name: 'Países', url: `${SITE}/countries` },
];

const countriesJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Países — Cine de Autor por País de Origen',
  description: `Explora películas de cine de autor por país de origen. ${countries.length} cines nacionales con ${totalFilms} películas en el catálogo PRISMA.`,
  url: `${SITE}/countries`,
  numberOfItems: countries.length,
  itemListElement: countries.slice(0, 30).map((c, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: c.name,
    url: `${SITE}/countries/${c.slug}`,
  })),
};
---

<BaseLayout title="Países — PRISMA" description="Explora películas por país de origen. Cada cine nacional tiene una identidad visual." jsonLd={countriesJsonLd} breadcrumbs={countriesBreadcrumbs}>
  <div class="countries-page page-enter">
    <div class="countries-header site-container">
      <h1 class="countries-header__title">Países</h1>
      <p class="countries-header__desc">
        {countries.length} cines nacionales · {totalFilms} películas
      </p>
    </div>

    <div class="site-container">
      {countries.length === 0 ? (
        <p class="countries-empty">Aún no hay datos de países disponibles.</p>
      ) : (
        <div class="country-grid">
          {countries.map((c) => (
            <a href={`/countries/${c.slug}`} class="country-card">
              <span class="country-card__flag" aria-hidden="true">{c.flag}</span>
              <div class="country-card__info">
                <span class="country-card__name">{c.name}</span>
                <span class="country-card__count">{c.count} {c.count === 1 ? 'película' : 'películas'}</span>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </div>
</BaseLayout>

<style>
.countries-page {
  padding-top: 8rem;
  padding-bottom: 6rem;
}

.countries-header {
  margin-bottom: 3rem;
}

.countries-header__title {
  font-family: var(--font-serif);
  font-size: clamp(2rem, 5vw, 3.5rem);
  font-weight: 400;
  color: var(--text-primary);
  margin-bottom: 0.625rem;
}

.countries-header__desc {
  font-size: 0.875rem;
  color: var(--text-muted);
  font-family: var(--font-mono);
  letter-spacing: 0.03em;
}

.countries-empty {
  font-size: 0.875rem;
  color: var(--text-muted);
  font-style: italic;
}

.country-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 1px;
  border: 1px solid var(--surface-border);
  border-radius: 4px;
  overflow: hidden;
}

.country-card {
  display: flex;
  align-items: center;
  gap: 0.875rem;
  padding: 0.875rem 1rem;
  background: var(--surface-card);
  text-decoration: none;
  transition: background 160ms ease;
}

.country-card:hover {
  background: var(--surface-elevated);
}

.country-card__flag {
  font-size: 1.5rem;
  line-height: 1;
  flex-shrink: 0;
  width: 1.75rem;
  text-align: center;
}

.country-card__info {
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
  min-width: 0;
}

.country-card__name {
  font-size: 0.875rem;
  color: var(--text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  transition: color 160ms ease;
}
.country-card:hover .country-card__name { color: var(--text-primary); }

.country-card__count {
  font-size: 0.7rem;
  color: var(--text-muted);
  font-family: var(--font-mono);
}

@media (max-width: 600px) {
  .country-grid { grid-template-columns: 1fr 1fr; }
}
</style>
