---
export const prerender = false

import BaseLayout from '../../layouts/BaseLayout.astro'
import { createServiceClient } from '../../lib/db/client'

const { token } = Astro.params

if (!token) return Astro.redirect('/404')

const db = createServiceClient()

const { data: submission } = await db
  .from('film_submissions')
  .select('*')
  .eq('ficha_token', token)
  .maybeSingle()

if (!submission) return Astro.redirect('/404')

const isExpired = submission.ficha_token_expires_at && new Date(submission.ficha_token_expires_at) < new Date()
const isPublished = submission.status === 'published'
const isAlreadySubmitted = submission.status === 'ficha_received'

const typeBadges: Record<string, string> = {
  short: 'Cortometraje',
  feature: 'Largometraje',
  series: 'Serie',
  music_video: 'Video musical',
}

const metaLines = (submission.reviewer_notes || '').split('\n')
const contentType = metaLines.find((l: string) => l.startsWith('Content type:'))?.replace('Content type: ', '') || ''
const typeLabel = typeBadges[contentType] || contentType || '—'

const roles = ['director', 'writer', 'cinematographer', 'editor', 'music', 'cast'] as const
const roleLabels: Record<string, string> = {
  director: 'Director',
  writer: 'Guionista',
  cinematographer: 'Director de fotografía',
  editor: 'Editor',
  music: 'Música',
  cast: 'Elenco',
}
---

<BaseLayout title={`Ficha técnica — ${submission.title}`} description="Completa la ficha técnica de tu obra para PRISMA.">
  <main class="ficha-page">
    {isExpired ? (
      <div class="ficha-notice">
        <h1>Enlace expirado</h1>
        <p>Este enlace ha expirado. Contacta al equipo de PRISMA para solicitar uno nuevo.</p>
      </div>
    ) : isPublished ? (
      <div class="ficha-notice">
        <h1>Obra ya publicada</h1>
        <p>Tu obra ya fue publicada en el catálogo de PRISMA.</p>
      </div>
    ) : isAlreadySubmitted ? (
      <div class="ficha-notice">
        <h1>Ficha ya recibida</h1>
        <p>Ya recibimos tu ficha técnica. El equipo de PRISMA está revisando tu información.</p>
      </div>
    ) : (
      <>
        <header class="ficha-header">
          <h1>Ficha técnica</h1>
          <p class="ficha-intro">
            Completa la información de tu obra para publicarla en el catálogo de PRISMA.
          </p>
        </header>

        <form class="ficha-form" id="ficha-form" enctype="multipart/form-data">
          <!-- Section 1: Tu obra (read-only) -->
          <fieldset class="form-section">
            <legend>Tu obra</legend>
            <div class="confirmation-grid">
              <div class="confirm-item">
                <span class="confirm-label">Título</span>
                <span class="confirm-value">{submission.title}</span>
              </div>
              <div class="confirm-item">
                <span class="confirm-label">Tipo</span>
                <span class="confirm-value">{typeLabel}</span>
              </div>
              <div class="confirm-item">
                <span class="confirm-label">Año</span>
                <span class="confirm-value">{submission.year || '—'}</span>
              </div>
              <div class="confirm-item">
                <span class="confirm-label">Duración</span>
                <span class="confirm-value">{submission.runtime_min ? `${submission.runtime_min} min` : '—'}</span>
              </div>
            </div>
          </fieldset>

          <!-- Section 2: Créditos -->
          <fieldset class="form-section">
            <legend>Créditos</legend>
            <p class="section-helper">Agrega las personas que participaron en tu obra. Puedes indicar si una persona tuvo más de un rol.</p>

            {roles.map(role => (
              <div class="credit-role">
                <h4>{roleLabels[role]}</h4>
                <div class="credit-entries" id={`credits-${role}`}>
                  <div class="credit-entry">
                    <div class="form-field">
                      <label>Nombre completo</label>
                      <input type="text" name={`credits[${role}][0][name]`} placeholder="Nombre completo" />
                    </div>
                    <div class="form-field">
                      <label>Foto</label>
                      <input type="file" name={`credits[${role}][0][photo]`} accept="image/*" />
                    </div>
                    <div class="form-field">
                      <label>Biografía breve <span class="form-optional">opcional</span></label>
                      <textarea name={`credits[${role}][0][bio]`} placeholder="Biografía breve (opcional)" maxlength="500" rows={2}></textarea>
                    </div>
                    {role !== 'cast' && (
                      <div class="also-roles">
                        <label class="also-label">También acreditado como:</label>
                        <div class="also-checks">
                          {roles.filter(r => r !== role && r !== 'cast').map(r => (
                            <label class="also-check">
                              <input type="checkbox" name={`credits[${role}][0][also][${r}]`} />
                              {roleLabels[r]}
                            </label>
                          ))}
                        </div>
                      </div>
                    )}
                  </div>
                </div>
                <button type="button" class="add-credit" data-role={role}>+ Agregar otro {roleLabels[role].toLowerCase()}</button>
              </div>
            ))}
          </fieldset>

          <!-- Section 3: Sobre ti -->
          <fieldset class="form-section">
            <legend>Sobre ti</legend>

            <div class="form-field">
              <label for="f-bio-full">Biografía completa</label>
              <textarea id="f-bio-full" name="bio_full" maxlength="800" rows={4} placeholder="Tu biografía completa…"></textarea>
              <span class="char-count" id="bio-full-count">0/800</span>
            </div>

            <div class="form-field">
              <label for="f-filmmaker-photo">Foto de perfil</label>
              <input type="file" id="f-filmmaker-photo" name="filmmaker_photo" accept="image/*" />
            </div>

            <div class="form-field">
              <label for="f-website">Sitio web <span class="form-optional">opcional</span></label>
              <input type="url" id="f-website" name="filmmaker_website" placeholder="https://…" />
            </div>

            <div class="form-field">
              <label for="f-instagram">Instagram <span class="form-optional">opcional</span></label>
              <input type="url" id="f-instagram" name="filmmaker_instagram" placeholder="https://instagram.com/…" />
            </div>
          </fieldset>

          <!-- Section 4: Tu obra en detalle -->
          <fieldset class="form-section">
            <legend>Tu obra en detalle</legend>

            <div class="form-field">
              <label for="f-countries">Países <span class="form-helper-inline">separados por coma</span></label>
              <input type="text" id="f-countries" name="countries" placeholder="México, España, Francia…" />
            </div>

            <div class="form-field">
              <label for="f-languages">Idiomas <span class="form-helper-inline">separados por coma</span></label>
              <input type="text" id="f-languages" name="languages" placeholder="Español, Inglés…" />
            </div>

            <div class="form-field">
              <label for="f-genres">Géneros <span class="form-helper-inline">separados por coma</span></label>
              <input type="text" id="f-genres" name="genres" placeholder="Drama, Experimental…" />
            </div>

            <div class="form-field">
              <label for="f-synopsis-full">Sinopsis completa</label>
              <textarea id="f-synopsis-full" name="synopsis_full" maxlength="1000" rows={5} placeholder="Sinopsis detallada…"></textarea>
              <span class="char-count" id="synopsis-full-count">0/1000</span>
            </div>
          </fieldset>

          <div class="form-actions">
            <button type="submit" class="submit-btn" id="ficha-submit-btn">Enviar ficha técnica</button>
          </div>

          <div class="form-message form-message--error" id="ficha-error" hidden></div>
          <div class="form-message form-message--success" id="ficha-success" hidden></div>
        </form>
      </>
    )}
  </main>
</BaseLayout>

<script is:inline>
(function() {
  var form = document.getElementById('ficha-form');
  if (!form) return;

  var submitBtn = document.getElementById('ficha-submit-btn');
  var errorEl = document.getElementById('ficha-error');
  var successEl = document.getElementById('ficha-success');

  // Character counters
  function bindCounter(fieldId, countId, max) {
    var field = document.getElementById(fieldId);
    var counter = document.getElementById(countId);
    if (field && counter) {
      field.addEventListener('input', function() {
        counter.textContent = field.value.length + '/' + max;
      });
    }
  }
  bindCounter('f-bio-full', 'bio-full-count', 800);
  bindCounter('f-synopsis-full', 'synopsis-full-count', 1000);

  // Add credit entry
  var creditIndex = {};
  document.querySelectorAll('.add-credit').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var role = btn.dataset.role;
      if (!creditIndex[role]) creditIndex[role] = 1;
      else creditIndex[role]++;
      var idx = creditIndex[role];
      var container = document.getElementById('credits-' + role);
      if (!container) return;

      var entry = document.createElement('div');
      entry.className = 'credit-entry';
      entry.innerHTML =
        '<div class="form-field"><label>Nombre completo</label><input type="text" name="credits[' + role + '][' + idx + '][name]" placeholder="Nombre completo" /></div>' +
        '<div class="form-field"><label>Foto</label><input type="file" name="credits[' + role + '][' + idx + '][photo]" accept="image/*" /></div>' +
        '<div class="form-field"><label>Biografía breve <span class="form-optional">opcional</span></label><textarea name="credits[' + role + '][' + idx + '][bio]" placeholder="Biografía breve (opcional)" maxlength="500" rows="2"></textarea></div>' +
        '<button type="button" class="remove-credit">✕ Quitar</button>';
      container.appendChild(entry);

      entry.querySelector('.remove-credit').addEventListener('click', function() {
        entry.remove();
      });
    });
  });

  // Submit
  form.addEventListener('submit', async function(e) {
    e.preventDefault();
    errorEl.hidden = true;
    successEl.hidden = true;
    submitBtn.disabled = true;
    submitBtn.textContent = 'Enviando…';

    try {
      var formData = new FormData(form);
      var token = window.location.pathname.split('/').pop();

      var res = await fetch('/api/ficha/' + token, {
        method: 'POST',
        body: formData,
      });

      var result = await res.json();

      if (res.ok && result.success) {
        successEl.innerHTML = '<span style="color:#3dba6f">✦</span> Ficha recibida.<br>El equipo de PRISMA revisará tu información y te avisaremos cuando tu obra esté publicada en el catálogo.';
        successEl.hidden = false;
        form.style.display = 'none';
        successEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
      } else {
        errorEl.textContent = result.error || 'Error al enviar. Intenta de nuevo.';
        errorEl.hidden = false;
        submitBtn.disabled = false;
        submitBtn.textContent = 'Enviar ficha técnica';
      }
    } catch (err) {
      errorEl.textContent = 'Error de red. Verifica tu conexión.';
      errorEl.hidden = false;
      submitBtn.disabled = false;
      submitBtn.textContent = 'Enviar ficha técnica';
    }
  });
})();
</script>

<style>
  .ficha-page {
    max-width: 680px;
    margin: 0 auto;
    padding: 4rem 1.5rem 6rem;
  }

  .ficha-notice {
    text-align: center;
    padding: 4rem 1rem;
  }

  .ficha-notice h1 {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--text-primary);
    margin: 0 0 0.75rem;
  }

  .ficha-notice p {
    color: var(--text-secondary);
    font-size: 0.9rem;
  }

  .ficha-header { margin-bottom: 2.5rem; }

  .ficha-header h1 {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 400;
    color: var(--text-primary);
    margin: 0 0 0.75rem;
  }

  .ficha-intro {
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .ficha-form {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .form-section { border: none; padding: 0; margin: 0; }

  .form-section legend {
    font-family: var(--font-serif);
    font-size: 1.125rem;
    font-weight: 400;
    color: var(--text-primary);
    margin-bottom: 1rem;
    padding: 0;
  }

  .section-helper {
    font-size: 0.78rem;
    color: var(--text-muted);
    margin: 0 0 1.25rem;
    line-height: 1.5;
  }

  .confirmation-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  .confirm-item {
    background: var(--surface-card);
    border: 1px solid var(--surface-border);
    border-radius: 6px;
    padding: 0.75rem;
  }

  .confirm-label {
    display: block;
    font-size: 0.68rem;
    font-weight: 500;
    color: var(--text-muted);
    margin-bottom: 0.25rem;
  }

  .confirm-value {
    font-size: 0.875rem;
    color: var(--text-primary);
  }

  /* Credits */
  .credit-role {
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--surface-border);
  }

  .credit-role h4 {
    font-family: var(--font-serif);
    font-size: 0.9375rem;
    font-weight: 400;
    color: var(--text-primary);
    margin: 0 0 0.75rem;
  }

  .credit-entry {
    background: var(--surface-card);
    border: 1px solid var(--surface-border);
    border-radius: 6px;
    padding: 1rem;
    margin-bottom: 0.5rem;
  }

  .form-field { margin-bottom: 0.75rem; }

  .form-field label {
    display: block;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-secondary);
    margin-bottom: 0.25rem;
  }

  .form-optional {
    font-weight: 400;
    color: var(--text-muted);
    font-size: 0.68rem;
  }

  .form-helper-inline {
    font-weight: 400;
    color: var(--text-muted);
    font-size: 0.68rem;
  }

  .form-field input[type="text"],
  .form-field input[type="email"],
  .form-field input[type="url"],
  .form-field input[type="number"],
  .form-field textarea {
    width: 100%;
    padding: 0.5rem 0.75rem;
    background: var(--surface-elevated);
    border: 1px solid var(--surface-border);
    border-radius: 5px;
    color: var(--text-primary);
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    outline: none;
    box-sizing: border-box;
    transition: border-color 120ms ease;
  }

  .form-field input:focus,
  .form-field textarea:focus {
    border-color: var(--surface-border-strong);
  }

  .form-field input::placeholder,
  .form-field textarea::placeholder {
    color: var(--text-muted);
  }

  .form-field textarea { resize: vertical; min-height: 60px; }

  .form-field input[type="file"] {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .also-roles { margin-top: 0.5rem; }

  .also-label {
    font-size: 0.72rem;
    color: var(--text-muted);
    display: block;
    margin-bottom: 0.375rem;
  }

  .also-checks {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .also-check {
    font-size: 0.75rem;
    color: var(--text-secondary);
    display: flex;
    align-items: center;
    gap: 0.25rem;
    cursor: pointer;
  }

  .also-check input { accent-color: var(--text-accent); }

  .add-credit {
    background: none;
    border: none;
    color: var(--text-accent);
    font-size: 0.75rem;
    cursor: pointer;
    padding: 0.25rem 0;
    margin-top: 0.25rem;
  }

  .add-credit:hover { text-decoration: underline; }

  .remove-credit {
    background: none;
    border: none;
    color: var(--text-muted);
    font-size: 0.72rem;
    cursor: pointer;
    margin-top: 0.5rem;
  }

  .remove-credit:hover { color: #c04040; }

  .char-count {
    display: block;
    text-align: right;
    font-size: 0.68rem;
    color: var(--text-muted);
    margin-top: 0.125rem;
  }

  /* Submit */
  .form-actions { padding-top: 0.5rem; }

  .submit-btn {
    display: inline-block;
    padding: 0.75rem 2rem;
    background: #F0EEE8;
    border: none;
    border-radius: 6px;
    color: #111;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 120ms ease;
  }

  .submit-btn:hover { opacity: 0.88; }
  .submit-btn:disabled { opacity: 0.5; cursor: not-allowed; }

  .form-message {
    padding: 1rem 1.25rem;
    border-radius: 6px;
    font-size: 0.8125rem;
    line-height: 1.6;
  }

  .form-message[hidden] { display: none; }

  .form-message--error {
    background: rgba(142, 27, 27, 0.12);
    border: 1px solid rgba(142, 27, 27, 0.3);
    color: #e8a0a0;
  }

  .form-message--success {
    background: rgba(61, 186, 111, 0.08);
    border: 1px solid rgba(61, 186, 111, 0.2);
    color: var(--text-secondary);
  }

  @media (max-width: 600px) {
    .ficha-page { padding: 2.5rem 1rem 4rem; }
    .confirmation-grid { grid-template-columns: 1fr; }
  }
</style>
