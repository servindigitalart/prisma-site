---
import FilmLayout from '../../layouts/FilmLayout.astro';
import FilmHero from '../../components/film/FilmHero.astro';
import FilmColorBlock from '../../components/film/FilmColorBlock.astro';
import FilmDimensionTags from '../../components/film/FilmDimensionTags.astro';
import FilmSynopsis from '../../components/film/FilmSynopsis.astro';
import FilmPeople from '../../components/film/FilmPeople.astro';
import FilmMetaAccordion from '../../components/film/FilmMetaAccordion.astro';
import FilmAwards from '../../components/film/FilmAwards.astro';
import FilmRankBadge from '../../components/film/FilmRankBadge.astro';
import FilmActions from '../../components/film/FilmActions.astro';
import FilmReviews from '../../components/film/FilmReviews.astro';
import StreamingPlayer from '../../components/film/StreamingPlayer.astro';
import { loadWorkBySlugAsync } from '../../lib/loaders/loadWork';
import { createServiceClient, isSupabaseConfigured } from '../../lib/db/client';
import { createSupabaseServerClient } from '../../lib/supabase/server';
import { buildFilmSeo } from '../../lib/seo/filmSeo';

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/404');
}

const work = await loadWorkBySlugAsync(slug);

if (!work) {
  return Astro.redirect('/404');
}

// Fetch ranking score if Supabase is available
let rankScore: { rank: number | null; score: number | null } | null = null;
if (isSupabaseConfigured()) {
  try {
    const db = createServiceClient();
    const workId = `work_${slug}`;
    const { data } = await db
      .from('ranking_scores')
      .select('rank, score')
      .eq('entity_id', workId)
      .eq('entity_type', 'work')
      .eq('context', 'global')
      .maybeSingle();
    if (data) {
      rankScore = { rank: (data as { rank: number | null; score: number | null }).rank, score: (data as { rank: number | null; score: number | null }).score };
    }
  } catch {
    // Graceful degradation — no rank badge
  }
}

// Resolve color tier from work data
const colorTier: string | null =
  ('color_assignments' in work && work.color_assignments?.tier)
    ? work.color_assignments.tier
    : null;

// ── Cast award highlights ─────────────────────────────────────────────────────
// Tier A/B festival win badges shown below each actor's name in FilmPeople.
// Since work_awards.person_id is null for all rows (film-level attribution),
// we derive per-actor highlights by: actor → their films → those films' wins.
const HIGHLIGHT_AWARD_IDS = new Set([
  'award_oscar-best-picture', 'award_oscar-best-director', 'award_oscar-best-actress',
  'award_oscar-best-actor', 'award_oscar-best-intl-film', 'award_oscar-best-cinematography',
  'award_oscar-best-original-screenplay', 'award_oscar-best-adapted-screenplay',
  'award_oscar-best-original-score', 'award_oscar-best-production-design',
  'award_cannes-palme-dor', 'award_cannes-grand-prix', 'award_cannes-best-director',
  'award_cannes-best-actress', 'award_cannes-best-actor',
  'award_berlin-golden-bear', 'award_berlin-silver-bear-director',
  'award_venice-golden-lion', 'award_venice-silver-lion-director',
  'award_bafta-best-film', 'award_bafta-best-director',
  'award_cesar-best-film', 'award_cesar-best-director',
  'award_gg-best-film-drama', 'award_gg-best-director',
]);

function awardShortName(id: string): string {
  if (id.includes('oscar'))   return 'Oscar';
  if (id.includes('cannes'))  return 'Palme d\'Or';
  if (id.includes('berlin'))  return 'Berlin';
  if (id.includes('venice'))  return 'Venice';
  if (id.includes('bafta'))   return 'BAFTA';
  if (id.includes('cesar'))   return 'César';
  if (id.includes('gg-'))     return 'Golden Globe';
  return id.split('-')[1]?.toUpperCase() ?? id;
}

// castAwardHighlights: person_id → up to 2 award short names (career wins)
const castAwardHighlights: Record<string, string[]> = {};

if (isSupabaseConfigured() && 'work_people' in work) {
  try {
    const db = createServiceClient();
    const workFull = work as import('../../lib/db/types').WorkFull;
    const actorIds = workFull.work_people
      .filter(wp => wp.role === 'actor')
      .map(wp => wp.people.id);

    if (actorIds.length > 0) {
      // All films each actor has appeared in
      const wpRes = await db
        .from('work_people')
        .select('work_id, person_id')
        .in('person_id', actorIds)
        .eq('role', 'actor');

      if (wpRes.data && wpRes.data.length > 0) {
        const allWorkIds = [...new Set(wpRes.data.map(r => r.work_id as string))];

        // Wins for those films from highlight award set
        const waRes = await db
          .from('work_awards')
          .select('work_id, award_id')
          .eq('result', 'win')
          .in('work_id', allWorkIds)
          .in('award_id', [...HIGHLIGHT_AWARD_IDS]);

        if (waRes.data && waRes.data.length > 0) {
          // work_id → award short names
          const workWins: Record<string, string[]> = {};
          for (const row of waRes.data) {
            const wid = row.work_id as string;
            const shortName = awardShortName(row.award_id as string);
            if (!workWins[wid]) workWins[wid] = [];
            if (!workWins[wid].includes(shortName)) workWins[wid].push(shortName);
          }

          // Map back to actors
          for (const wpRow of wpRes.data) {
            const personId = wpRow.person_id as string;
            const wins = workWins[wpRow.work_id as string];
            if (!wins) continue;
            if (!castAwardHighlights[personId]) castAwardHighlights[personId] = [];
            for (const award of wins) {
              if (
                !castAwardHighlights[personId].includes(award) &&
                castAwardHighlights[personId].length < 2
              ) {
                castAwardHighlights[personId].push(award);
              }
            }
          }
        }
      }
    }
  } catch {
    // graceful degradation — no award highlights
  }
}

const seo = buildFilmSeo(work);

// ── Auth + user film state ─────────────────────────────────────────────────
const user = Astro.locals.user;

console.log('[Film Page] User auth state:', {
  hasUser: !!user,
  userId: user?.id,
  userEmail: user?.email
});

let initialRating: number | null = null;
let initialSeen = false;
let initialWatchlist = false;
let initialReview: string | null = null;

if (user && isSupabaseConfigured()) {
  try {
    const db = createServiceClient();
    const workId = `work_${slug}`;

    const [ratingRes, seenRes, wlRes] = await Promise.all([
      db.from('user_ratings').select('rating, review').eq('user_id', user.id).eq('work_id', workId).maybeSingle(),
      db.from('user_watches').select('work_id').eq('user_id', user.id).eq('work_id', workId).limit(1),
      db.from('user_watchlist').select('work_id').eq('user_id', user.id).eq('work_id', workId).maybeSingle(),
    ]);

    initialRating = (ratingRes.data as any)?.rating ?? null;
    initialReview = (ratingRes.data as any)?.review ?? null;
    initialSeen = (seenRes.data?.length ?? 0) > 0;
    initialWatchlist = !!wlRes.data;
  } catch {
    // graceful degradation
  }
}

// Fetch public reviews for this film
let filmReviews: any[] = [];
if (isSupabaseConfigured()) {
  try {
    const db = createServiceClient();
    const { data } = await db
      .from('user_ratings')
      .select('rating, review, user_id, user_profiles(display_name, avatar_url, username)')
      .eq('work_id', `work_${slug}`)
      .eq('is_public', true)
      .not('review', 'is', null)
      .order('updated_at', { ascending: false })
      .limit(5);
    filmReviews = data || [];
  } catch {
    // graceful degradation
  }
}
---

<FilmLayout title={seo.title} description={seo.description} ogImage={seo.ogImage} jsonLd={seo.jsonLd}>
  <FilmHero work={work} />

  <!-- Film action buttons (rate / seen / watchlist) -->
  <div class="film-actions-bar">
    <div class="site-container">
      <FilmActions
        workId={`work_${slug}`}
        userId={user?.id ?? null}
        initialRating={initialRating}
        initialSeen={initialSeen}
        initialWatchlist={initialWatchlist}
        initialReview={initialReview}
      />
    </div>
  </div>

  {/* Streaming player — shown if work has Bunny video linked */}
  {'is_streamable' in work && (work as any).is_streamable && (work as any).bunny_video_id && (
    <div class="film-streaming">
      <div class="site-container">
        <StreamingPlayer
          workId={`work_${slug}`}
          bunnyVideoId={(work as any).bunny_video_id}
          title={work.title}
        />
      </div>
    </div>
  )}

  <div class="film-body">
    <!-- Rank badge (shown if we have ranking data) -->
    {rankScore && (
      <div class="film-body__rank">
        <div class="site-container">
          <FilmRankBadge
            rank={rankScore.rank}
            score={rankScore.score}
            tier={colorTier}
          />
        </div>
      </div>
    )}

    <FilmColorBlock work={work} />
    <FilmDimensionTags work={work} />
    <FilmSynopsis work={work} />
    <FilmPeople work={work} castAwardHighlights={castAwardHighlights} />
    <FilmReviews reviews={filmReviews} />
    <FilmAwards work={work} />
    <FilmMetaAccordion work={work} />
  </div>
</FilmLayout>

<style>
.film-actions-bar {
  background: var(--surface-bg);
  border-bottom: 1px solid var(--surface-border);
  padding: 0.875rem 0;
}

.film-streaming {
  background: var(--surface-bg);
  padding: 0.5rem 0 0;
}

.film-body {
  background: var(--surface-bg);
}

.film-body__rank {
  padding: 2rem 0 0;
}
</style>
