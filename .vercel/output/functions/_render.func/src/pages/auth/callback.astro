---
/**
 * src/pages/auth/callback.astro
 * ─────────────────────────────
 * Server-side PKCE callback.
 * Supabase redirects here with ?code=... after Google consent.
 * We exchange the code for a session, which sets auth cookies via @supabase/ssr.
 */
export const prerender = false

import { createServerClient, parseCookieHeader } from '@supabase/ssr'

const { request, cookies, redirect, url } = Astro

const supabase = createServerClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
  {
    cookies: {
      getAll() {
        const parsed = parseCookieHeader(request.headers.get('Cookie') ?? '')
        return parsed.map(c => ({ name: c.name, value: c.value ?? '' }))
      },
      setAll(cookiesToSet) {
        cookiesToSet.forEach(({ name, value, options }) => {
          cookies.set(name, value, {
            ...options,
            path: '/',
            sameSite: 'lax',
            httpOnly: true,
            secure: import.meta.env.PROD,
          })
        })
      },
    },
  }
)

const code = url.searchParams.get('code')

if (code) {
  const { error } = await supabase.auth.exchangeCodeForSession(code)
  if (error) {
    console.error('[callback] Code exchange error:', error)
    return redirect('/auth/error?message=Code+exchange+failed')
  }
}

return redirect('/')
