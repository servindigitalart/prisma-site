---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { createServiceClient, isSupabaseConfigured } from '../../lib/db/client';
import { formatRole } from '../../lib/color/colorPalette';
import type { PersonRole } from '../../lib/db/types';

const TMDB_BASE = 'https://image.tmdb.org/t/p/w185';
const TMDB_LG   = 'https://image.tmdb.org/t/p/w342';

const TABS = [
  { id: 'director',       label: 'Directores',    dbContext: 'director',       genderFilter: null },
  { id: 'cinematography', label: 'Fotografía',     dbContext: 'cinematography', genderFilter: null },
  { id: 'writer',         label: 'Guionistas',     dbContext: 'writer',         genderFilter: null },
  { id: 'actor',          label: 'Actores',        dbContext: 'actor',          genderFilter: null },
  { id: 'actress',        label: 'Actrices',       dbContext: 'actress',        genderFilter: null },
  { id: 'editor',         label: 'Editores',       dbContext: 'editor',         genderFilter: null },
  { id: 'composer',       label: 'Compositores',   dbContext: 'composer',       genderFilter: null },
] as const;

type TabId = typeof TABS[number]['id'];

const activeTabId = (Astro.url.searchParams.get('role') ?? 'director') as TabId;
const activeTab = TABS.find(t => t.id === activeTabId) ?? TABS[0];

type RankedPerson = {
  rank:        number;
  score:       number;
  entityId:    string;
  slug:        string;
  name:        string;
  initials:    string;
  profilePath: string | null;
  gender:      number;
};

function getInitials(name: string): string {
  return name.split(' ').filter(Boolean).slice(0, 2)
    .map(w => w[0]?.toUpperCase() ?? '').join('');
}

let rankings: RankedPerson[] = [];
let maxScore = 1;

if (isSupabaseConfigured()) {
  const db = createServiceClient();

  const rsRes = await db
    .from('ranking_scores')
    .select('entity_id, score, rank')
    .eq('entity_type', 'person')
    .eq('context', activeTab.dbContext)
    .gt('score', 0)
    .order('rank')
    .limit(100);

  if (rsRes.data && rsRes.data.length > 0) {
    const entityIds = rsRes.data.map(r => r.entity_id as string);

    const peopleRes = await db
      .from('people')
      .select('id, name, profile_path, gender')
      .in('id', entityIds);

    if (peopleRes.data) {
      const peopleMap = new Map(
        peopleRes.data.map(p => [p.id as string, p])
      );

      rankings = rsRes.data
        .map(r => {
          const p = peopleMap.get(r.entity_id as string);
          if (!p) return null;
          return {
            rank:        r.rank as number,
            score:       r.score as number,
            entityId:    r.entity_id as string,
            slug:        (r.entity_id as string).replace(/^person_/, ''),
            name:        p.name as string,
            initials:    getInitials(p.name as string),
            profilePath: (p.profile_path as string | null) ?? null,
            gender:      (p.gender as number) ?? 0,
          };
        })
        .filter((x): x is RankedPerson => x !== null);

      maxScore = rankings[0]?.score ?? 1;
    }
  }
}

const featured = rankings[0] ?? null;
const rest = rankings.slice(1);

const pageTitle = 'Cineastas — PRISMA';
const pageDescription = 'Rankings de los directores, cinefotógrafos, actores y creativos más reconocidos del catálogo PRISMA.';

const SITE = 'https://prisma.film';

const peopleBreadcrumbs = [
  { name: 'PRISMA', url: SITE },
  { name: 'Cineastas', url: `${SITE}/people` },
];

const peopleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Cineastas — Rankings de Directores, Actores y Creativos',
  description: pageDescription,
  url: `${SITE}/people`,
  itemListElement: rankings.slice(0, 20).map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Person',
      name: p.name,
      url: `${SITE}/people/${p.slug}`,
    },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} jsonLd={peopleJsonLd} breadcrumbs={peopleBreadcrumbs}>
  <div class="people-index page-enter">

    <!-- Header -->
    <section class="people-header">
      <div class="site-container">
        <p class="people-header__eyebrow reveal">Catálogo</p>
        <h1 class="people-header__title reveal" data-delay="60">Cineastas</h1>
        <p class="people-header__subtitle reveal" data-delay="120">
          Clasificados por premios, peso cultural y prestigio
        </p>
      </div>
    </section>

    <!-- Tab nav — editorial pill style -->
    <nav class="people-tabs" aria-label="Filtrar por rol">
      <div class="site-container">
        <div class="people-tabs__inner">
          {TABS.map(tab => (
            <a
              href={`/people?role=${tab.id}`}
              class={`people-tabs__tab ${activeTabId === tab.id ? 'people-tabs__tab--active' : ''}`}
            >
              {tab.label}
            </a>
          ))}
        </div>
      </div>
    </nav>

    <!-- Rankings -->
    <section class="people-rankings">
      <div class="site-container">

        {rankings.length === 0 ? (
          <p class="people-rankings__empty">No hay rankings disponibles para esta categoría.</p>
        ) : (
          <>
            <!-- ─── #1 Featured card ─────────────────────────────────────── -->
            {featured && (
              <a href={`/people/${featured.slug}`} class="featured-person reveal">
                <div class="featured-person__photo-wrap">
                  {featured.profilePath
                    ? <img
                        src={`${TMDB_LG}${featured.profilePath}`}
                        alt={featured.name}
                        loading="eager"
                        class="featured-person__photo"
                      />
                    : <span class="featured-person__initials">{featured.initials}</span>
                  }
                </div>
                <div class="featured-person__body">
                  <span class="featured-person__rank">#1</span>
                  <h2 class="featured-person__name">{featured.name}</h2>
                  <div class="featured-person__score-wrap">
                    <div class="featured-person__score-bar">
                      <div class="featured-person__score-fill" style="width: 100%" />
                    </div>
                    <span class="featured-person__score">{featured.score.toFixed(1)} pts</span>
                  </div>
                  <span class="featured-person__role">{activeTab.label}</span>
                </div>
              </a>
            )}

            <!-- ─── Ranked list (2 → N) ──────────────────────────────────── -->
            <ol class="rankings-list" aria-label={`${activeTab.label} rankings`}>
              {rest.map((person, i) => {
                const barPct = Math.max(4, Math.round((person.score / maxScore) * 100));
                const photoUrl = person.profilePath ? `${TMDB_BASE}${person.profilePath}` : null;
                return (
                  <li class="rankings-item reveal" data-delay={String(Math.min(i * 25, 300))}>
                    <span class="rankings-item__rank" aria-label={`Rank ${person.rank}`}>
                      {person.rank}
                    </span>

                    <div class="rankings-item__avatar" aria-hidden="true">
                      {photoUrl
                        ? <img src={photoUrl} alt="" loading="lazy" decoding="async" class="rankings-item__photo" />
                        : <span class="rankings-item__initials">{person.initials}</span>
                      }
                    </div>

                    <div class="rankings-item__body">
                      <a href={`/people/${person.slug}`} class="rankings-item__name">
                        {person.name}
                      </a>
                      <div class="rankings-item__bar-wrap">
                        <div class="rankings-item__bar-track">
                          <div
                            class="rankings-item__bar"
                            style={`width: ${barPct}%`}
                            aria-label={`Score: ${person.score.toFixed(1)}`}
                          />
                        </div>
                        <span class="rankings-item__score">{person.score.toFixed(1)}</span>
                      </div>
                    </div>
                  </li>
                );
              })}
            </ol>
          </>
        )}
      </div>
    </section>

  </div>

  <style>
    .people-index {
      min-height: 100vh;
      padding-bottom: var(--space-16);
    }

    /* ─── Header ──────────────────────────────────────────────────────────── */
    .people-header {
      padding: 7rem 0 var(--space-8);
      border-bottom: 1px solid var(--surface-border);
    }

    .people-header__eyebrow {
      font-size: var(--text-xs);
      font-weight: var(--weight-semi);
      letter-spacing: var(--tracking-widest);
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: var(--space-3);
    }

    .people-header__title {
      font-family: var(--font-serif);
      font-size: clamp(2.5rem, 5vw, 3.5rem);
      font-weight: 400;
      color: var(--text-primary);
      letter-spacing: -0.02em;
      margin-bottom: var(--space-3);
    }

    .people-header__subtitle {
      font-size: var(--text-base);
      color: var(--text-muted);
      line-height: 1.5;
    }

    /* ─── Tabs — editorial strip ──────────────────────────────────────────── */
    .people-tabs {
      position: sticky;
      top: 0;
      z-index: 20;
      background: rgba(13,13,15,0.97);
      border-bottom: 1px solid var(--surface-border);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
    }

    .people-tabs__inner {
      display: flex;
      gap: 0;
      overflow-x: auto;
      scrollbar-width: none;
    }
    .people-tabs__inner::-webkit-scrollbar { display: none; }

    .people-tabs__tab {
      flex-shrink: 0;
      padding: var(--space-4) var(--space-5);
      font-size: var(--text-xs);
      font-weight: var(--weight-medium);
      letter-spacing: var(--tracking-widest);
      text-transform: uppercase;
      color: var(--text-muted);
      text-decoration: none;
      border-bottom: 1px solid transparent;
      transition:
        color var(--dur-fast) var(--ease-editorial),
        border-color var(--dur-fast) var(--ease-editorial);
      white-space: nowrap;
      position: relative;
    }

    .people-tabs__tab:hover {
      color: var(--text-secondary);
    }

    .people-tabs__tab--active {
      color: var(--text-primary);
      border-bottom-color: var(--color-ambar-desertico, #C98A2E);
    }

    /* ─── Rankings ────────────────────────────────────────────────────────── */
    .people-rankings {
      padding: var(--space-8) 0;
    }

    .people-rankings__empty {
      color: var(--text-muted);
      font-size: var(--text-base);
      font-style: italic;
      text-align: center;
      padding: var(--space-16) 0;
    }

    /* ─── Featured #1 card ────────────────────────────────────────────────── */
    .featured-person {
      display: grid;
      grid-template-columns: 120px 1fr;
      gap: var(--space-6);
      align-items: center;
      padding: var(--space-6) var(--space-6);
      background: var(--bg-raised);
      border: 1px solid var(--surface-border);
      border-radius: var(--radius-lg);
      text-decoration: none;
      margin-bottom: var(--space-8);
      transition:
        background var(--dur-base) var(--ease-editorial),
        border-color var(--dur-base) var(--ease-editorial),
        transform var(--dur-base) var(--ease-editorial);
    }

    .featured-person:hover {
      background: var(--bg-elevated);
      border-color: var(--surface-border-strong);
      transform: translateY(-2px);
    }

    .featured-person__photo-wrap {
      width: 120px;
      aspect-ratio: 2 / 3;
      border-radius: var(--radius-md);
      overflow: hidden;
      background: var(--bg-elevated);
      border: 1px solid var(--surface-border);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .featured-person__photo {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: top;
      display: block;
    }

    .featured-person__initials {
      font-family: var(--font-serif);
      font-size: 2rem;
      color: var(--text-muted);
    }

    .featured-person__body {
      display: flex;
      flex-direction: column;
      gap: var(--space-3);
    }

    .featured-person__rank {
      font-family: var(--font-serif);
      font-size: clamp(3rem, 6vw, 5rem);
      font-weight: 400;
      color: var(--text-ghost);
      line-height: 1;
      letter-spacing: -0.04em;
    }

    .featured-person__name {
      font-family: var(--font-serif);
      font-size: clamp(1.5rem, 2.5vw, 2rem);
      font-weight: 400;
      color: var(--text-primary);
      letter-spacing: -0.01em;
      line-height: 1.1;
    }

    .featured-person__score-wrap {
      display: flex;
      align-items: center;
      gap: var(--space-4);
    }

    .featured-person__score-bar {
      flex: 1;
      max-width: 200px;
      height: 2px;
      background: var(--surface-border);
      border-radius: 1px;
      overflow: hidden;
    }

    .featured-person__score-fill {
      height: 100%;
      background: var(--color-ambar-desertico, #C98A2E);
      border-radius: 1px;
    }

    .featured-person__score {
      font-family: var(--font-mono);
      font-size: var(--text-xs);
      color: var(--text-muted);
      white-space: nowrap;
    }

    .featured-person__role {
      font-size: var(--text-xs);
      font-weight: var(--weight-medium);
      letter-spacing: var(--tracking-widest);
      text-transform: uppercase;
      color: var(--text-muted);
    }

    /* ─── Rankings list ───────────────────────────────────────────────────── */
    .rankings-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
    }

    .rankings-item {
      display: grid;
      grid-template-columns: 2.75rem 52px 1fr;
      align-items: center;
      gap: var(--space-4);
      padding: var(--space-3) 0;
      border-bottom: 1px solid var(--surface-border);
      transition: background var(--dur-fast) var(--ease-editorial);
    }

    .rankings-item:hover {
      background: rgba(255,255,255,0.018);
      padding-left: var(--space-3);
      padding-right: var(--space-3);
      margin-left: calc(-1 * var(--space-3));
      margin-right: calc(-1 * var(--space-3));
      border-radius: var(--radius-sm);
    }

    .rankings-item__rank {
      font-family: var(--font-mono);
      font-size: 0.68rem;
      color: var(--text-ghost);
      text-align: right;
      flex-shrink: 0;
    }

    .rankings-item__avatar {
      width: 52px;
      aspect-ratio: 2 / 3;
      border-radius: var(--radius-sm);
      background: var(--bg-raised);
      border: 1px solid var(--surface-border);
      flex-shrink: 0;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .rankings-item__photo {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: top;
      display: block;
    }

    .rankings-item__initials {
      font-size: var(--text-xs);
      font-weight: var(--weight-semi);
      color: var(--text-muted);
      letter-spacing: 0.03em;
    }

    .rankings-item__body {
      display: flex;
      flex-direction: column;
      gap: var(--space-2);
      min-width: 0;
    }

    .rankings-item__name {
      font-size: var(--text-base);
      font-weight: var(--weight-medium);
      color: var(--text-secondary);
      text-decoration: none;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      transition: color var(--dur-fast) var(--ease-editorial);
    }
    .rankings-item__name:hover { color: var(--text-primary); }

    /* Score bar — percentage-based, ultra-thin */
    .rankings-item__bar-wrap {
      display: flex;
      align-items: center;
      gap: var(--space-3);
    }

    .rankings-item__bar-track {
      flex: 1;
      max-width: 160px;
      height: 1px;
      background: var(--surface-border);
      border-radius: 0.5px;
      overflow: hidden;
    }

    .rankings-item__bar {
      height: 100%;
      border-radius: 0.5px;
      background: color-mix(in srgb, var(--color-ambar-desertico, #C98A2E) 70%, var(--text-muted));
      transition: width var(--dur-slow) var(--ease-out-expo);
    }

    .rankings-item__score {
      font-family: var(--font-mono);
      font-size: 0.62rem;
      color: var(--text-muted);
      white-space: nowrap;
    }

    /* ─── Mobile ──────────────────────────────────────────────────────────── */
    @media (max-width: 640px) {
      .featured-person {
        grid-template-columns: 80px 1fr;
        gap: var(--space-4);
        padding: var(--space-4);
      }

      .featured-person__photo-wrap { width: 80px; }
      .featured-person__rank { font-size: 2.5rem; }
      .featured-person__name { font-size: 1.25rem; }

      .rankings-item {
        grid-template-columns: 2.25rem 40px 1fr;
        gap: var(--space-3);
      }
      .rankings-item__avatar { width: 40px; }
      .people-tabs__tab {
        padding: var(--space-3) var(--space-4);
        font-size: 0.6rem;
      }
    }
  </style>
</BaseLayout>
