<script is:inline>
(function () {
  // Bio toggle
  var toggle = document.getElementById('bio-toggle');
  var bioShort = document.getElementById('bio-short');
  var bioFull = document.getElementById('bio-full');
  if (toggle && bioFull) {
    toggle.addEventListener('click', function () {
      var expanded = !bioFull.hidden;
      bioFull.hidden = expanded;
      if (bioShort) bioShort.style.display = expanded ? '' : 'none';
      toggle.textContent = expanded ? 'Leer más' : 'Leer menos';
    });
  }

  // Award group collapsible
  document.querySelectorAll('.award-group__header').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var group = btn.closest('.award-group');
      if (!group) return;
      var list = group.querySelector('.award-group__list');
      if (!list) return;
      var open = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', open ? 'false' : 'true');
      list.hidden = open;
    });
  });
})();
</script>
