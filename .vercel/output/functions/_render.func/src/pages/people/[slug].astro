---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPaletteEntry, formatRole } from '../../lib/color/colorPalette';
import { loadPersonBySlugAsync } from '../../lib/loaders/loadPerson';
import { createServiceClient, isSupabaseConfigured } from '../../lib/db/client';
import { getFestivalLogoUrl, getFestivalMonogram } from '../../lib/festivalUtils';
import { buildPersonSeo } from '../../lib/seo/personSeo';
import type { PersonRole } from '../../lib/db/types';

const { slug } = Astro.params;

if (!slug) return Astro.redirect('/404');

const person = await loadPersonBySlugAsync(slug);

if (!person) {
  return Astro.redirect('/404');
}

// Compute role summary
const roleCounts: Record<string, number> = {};
for (const entry of person.filmography) {
  roleCounts[entry.role] = (roleCounts[entry.role] ?? 0) + 1;
}

const primaryRole = Object.entries(roleCounts)
  .sort((a, b) => b[1] - a[1])[0]?.[0] as PersonRole | undefined;

// Compute color distribution from filmography
const colorCounts: Record<string, number> = {};
for (const entry of person.filmography) {
  const c = entry.color?.color_iconico;
  if (c) colorCounts[c] = (colorCounts[c] ?? 0) + 1;
}

const topColors = Object.entries(colorCounts)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 5);

// Sort filmography by year descending
const filmography = [...person.filmography].sort((a, b) =>
  (b.work.year ?? 0) - (a.work.year ?? 0)
);

const pageTitle = `${person.name} — PRISMA`;
const nationalities = (person.nationality ?? []).join(', ');

// ── Person SEO ────────────────────────────────────────────────────────────────
const personSeo = buildPersonSeo(
  {
    name: person.name,
    id: ('id' in person) ? (person as any).id : `person_${slug}`,
    bio: person.bio ?? null,
    nationality: person.nationality,
    birth_year: person.birth_year ?? null,
    death_year: person.death_year ?? null,
    profile_path: person.profile_path ?? null,
    imdb_id: ('imdb_id' in person) ? (person as any).imdb_id : null,
    wikidata_id: ('wikidata_id' in person) ? (person as any).wikidata_id : null,
    filmography: person.filmography,
  },
  primaryRole,
);

const SITE = 'https://prisma.film';
const personBreadcrumbs = [
  { name: 'PRISMA', url: SITE },
  { name: 'Cineastas', url: `${SITE}/people` },
  { name: person.name, url: `${SITE}/people/${slug}` },
];

// ── Ranking ───────────────────────────────────────────────────────────────────
type PersonRanking = { rank: number; score: number; context: string };
let personRanking: PersonRanking | null = null;
if (isSupabaseConfigured()) {
  try {
    const db = createServiceClient();
    const { data } = await db
      .from('ranking_scores')
      .select('rank, score, context')
      .eq('entity_type', 'person')
      .eq('entity_id', `person_${slug}`)
      .order('score', { ascending: false })
      .limit(1)
      .maybeSingle();
    if (data) {
      personRanking = {
        rank:    (data as { rank: number; score: number; context: string }).rank,
        score:   (data as { rank: number; score: number; context: string }).score,
        context: (data as { rank: number; score: number; context: string }).context,
      };
    }
  } catch {
    // graceful degradation
  }
}

// ── Awards (indirect: this person's work_ids → work_awards) ──────────────────
type PersonAwardRow = {
  result: 'win' | 'nomination';
  year: number | null;
  work_id: string;
  awards: {
    id: string;
    name: string;
    is_grand_prize: boolean;
    tier: string | null;
    festival_id: string | null;
    festivals: {
      id: string;
      name: string;
      country: string | null;
      tier: string | null;
      logo_path: string | null;
    } | null;
  };
};

const TIER_ORDER_A: Record<string, number> = { A: 0, B: 1, C: 2, D: 3 };

function sortAwardRows(a: PersonAwardRow, b: PersonAwardRow) {
  if (a.awards.is_grand_prize !== b.awards.is_grand_prize) return a.awards.is_grand_prize ? -1 : 1;
  const ta = TIER_ORDER_A[a.awards.festivals?.tier ?? a.awards.tier ?? 'C'] ?? 3;
  const tb = TIER_ORDER_A[b.awards.festivals?.tier ?? b.awards.tier ?? 'C'] ?? 3;
  if (ta !== tb) return ta - tb;
  return (b.year ?? 0) - (a.year ?? 0);
}

let personWins: PersonAwardRow[] = [];
let personNoms: PersonAwardRow[] = [];

if (isSupabaseConfigured() && filmography.length > 0) {
  try {
    const db2 = createServiceClient();
    const uniqueWorkIds = [...new Set(filmography.map(e => e.work.id))];
    const { data: awardsData } = await db2
      .from('work_awards')
      .select('result, year, work_id, awards!inner(id, name, is_grand_prize, tier, festival_id, festivals(id, name, country, tier, logo_path))')
      .in('work_id', uniqueWorkIds)
      .order('year', { ascending: false });
    if (awardsData) {
      const all = awardsData as unknown as PersonAwardRow[];
      personWins = all.filter(r => r.result === 'win').sort(sortAwardRows);
      personNoms = all.filter(r => r.result === 'nomination').sort(sortAwardRows);
    }
  } catch {
    // graceful degradation
  }
}

const workTitleMap = new Map(filmography.map(e => [e.work.id, e.work.title]));

function festName(wa: PersonAwardRow): string {
  return wa.awards.festivals?.name ?? '—';
}
function festHref(wa: PersonAwardRow): string | undefined {
  return wa.awards.festival_id
    ? `/festivals/${wa.awards.festival_id.replace(/^festival_/, '')}`
    : undefined;
}
const AWARD_TIER_COLOR: Record<string, string> = {
  A: '#C98A2E',
  B: 'rgba(255,255,255,0.3)',
  C: 'rgba(255,255,255,0.15)',
};
function awardTierColor(wa: PersonAwardRow): string {
  const t = wa.awards.festivals?.tier ?? wa.awards.tier ?? '';
  return AWARD_TIER_COLOR[t] ?? AWARD_TIER_COLOR['C'];
}

// ── Profile photo ─────────────────────────────────────────────────────────────
const TMDB_BASE = 'https://image.tmdb.org/t/p/w185';
let profileUrl: string | null = null;
if (person.profile_path) {
  profileUrl = `${TMDB_BASE}${person.profile_path}`;
}
---

<BaseLayout
  title={personSeo.title}
  description={personSeo.description}
  ogImage={personSeo.ogImage}
  ogType={personSeo.ogType}
  jsonLd={personSeo.jsonLd}
  breadcrumbs={personBreadcrumbs}
>
  <div class="person-page page-enter">

    <!-- ── Header ── -->
    <section class="person-header">
      <div class="site-container">
        <div class="person-header__inner">
          <div class="person-header__avatar" aria-hidden="true">
            {profileUrl ? (
              <img src={profileUrl} alt={person.name} class="person-header__photo" />
            ) : (
              person.name.split(' ').slice(0, 2).map((w) => w[0]?.toUpperCase() ?? '').join('')
            )}
          </div>

          <div class="person-header__info">
            {primaryRole && (
              <div class="person-header__role-label">
                <span class="role-badge">{formatRole(primaryRole)}</span>
              </div>
            )}
            {personRanking && (
              <div class="person-ranking-badge">
                <span class="person-ranking-badge__rank">#{personRanking.rank}</span>
                <a
                  href={`/people?role=${personRanking.context}`}
                  class="person-ranking-badge__role"
                >
                  {formatRole(personRanking.context as PersonRole)}
                </a>
                <span class="person-ranking-badge__sep">·</span>
                <span class="person-ranking-badge__score">{personRanking.score.toFixed(1)} pts</span>
              </div>
            )}
            <h1 class="person-header__name">{person.name}</h1>

            <div class="person-header__meta">
              {person.birth_year && (
                <span class="person-header__meta-item">
                  b. {person.birth_year}{person.death_year ? ` — d. ${person.death_year}` : ''}
                </span>
              )}
              {nationalities && (
                <span class="person-header__meta-item">{nationalities}</span>
              )}
              {filmography.length > 0 && (
                <span class="person-header__meta-item">{filmography.length} obras</span>
              )}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Biography ── -->
    {person.bio && (
      <section class="person-bio">
        <div class="site-container">
          {person.bio.split('\n\n').map(para => (
            <p class="person-bio__para">{para}</p>
          ))}
        </div>
      </section>
    )}

    <!-- ── Awards & Recognition ── -->
    {(personWins.length > 0 || personNoms.length > 0) && (
      <section class="person-awards">
        <div class="site-container">
          <h2 class="person-awards__heading">Premios y Reconocimientos</h2>

          {personWins.length > 0 && (
            <div class="person-awards__wins">
              {personWins.map(wa => {
                const color  = awardTierColor(wa);
                const href   = festHref(wa);
                const logoUrl = getFestivalLogoUrl(wa.awards.festivals?.logo_path ?? null);
                const monogram = getFestivalMonogram(festName(wa));
                const filmTitle = workTitleMap.get(wa.work_id);
                const filmSlug  = wa.work_id.replace(/^work_/, '');
                return (
                  <div class="person-award-card" style={`--tc: ${color}`}>
                    {logoUrl
                      ? <img src={logoUrl} alt="" class="person-award-card__logo" loading="lazy" />
                      : <span class="person-award-card__monogram" aria-hidden="true" style={`background: color-mix(in srgb, ${color} 15%, transparent)`}>{monogram}</span>
                    }
                    <div class="person-award-card__body">
                      <span class="person-award-card__name">{wa.awards.name}</span>
                      <span class="person-award-card__meta">
                        {filmTitle && (
                          <a href={`/films/${filmSlug}`} class="person-award-card__film">{filmTitle}</a>
                        )}
                        {filmTitle && <span aria-hidden="true"> · </span>}
                        {href
                          ? <a href={href} class="person-award-card__fest">{festName(wa)}</a>
                          : <span>{festName(wa)}</span>
                        }
                        {wa.year && <span> · {wa.year}</span>}
                      </span>
                    </div>
                  </div>
                );
              })}
            </div>
          )}

          {personWins.length === 0 && personNoms.length > 0 && (
            <ul class="person-noms-list" role="list">
              {personNoms.slice(0, 3).map(wa => {
                const filmTitle = workTitleMap.get(wa.work_id);
                const filmSlug  = wa.work_id.replace(/^work_/, '');
                const href = festHref(wa);
                return (
                  <li class="person-nom-row">
                    <span class="person-nom-row__name">{wa.awards.name}</span>
                    <span class="person-nom-row__sep" aria-hidden="true">·</span>
                    {filmTitle && (
                      <>
                        <a href={`/films/${filmSlug}`} class="person-nom-row__film">{filmTitle}</a>
                        <span class="person-nom-row__sep" aria-hidden="true">·</span>
                      </>
                    )}
                    {href
                      ? <a href={href} class="person-nom-row__fest">{festName(wa)}</a>
                      : <span class="person-nom-row__fest">{festName(wa)}</span>
                    }
                    {wa.year && <span class="person-nom-row__year">{wa.year}</span>}
                  </li>
                );
              })}
            </ul>
          )}
        </div>
      </section>
    )}

    <!-- ── Color signature ── -->
    {topColors.length > 0 && (
      <section class="person-colors">
        <div class="site-container">
          <div class="person-colors__inner">
            <div class="person-colors__header">
              <h2 class="person-colors__heading">Identidad Visual</h2>
              <p class="person-colors__sub">Colores recurrentes a lo largo de su filmografía</p>
            </div>

            <div class="person-colors__signature">
              {topColors.map(([colorId, count]) => {
                const p = getPaletteEntry(colorId);
                if (!p) return null;
                const pct = Math.round((count / filmography.length) * 100);
                return (
                  <a href={`/colors/${colorId}`} class="person-color-item">
                    <div
                      class="person-color-item__bar"
                      style={`background: ${p.hex}; height: ${Math.max(pct * 1.5, 12)}px;`}
                      title={`${count} películas`}
                    />
                    <span class="person-color-item__name">{p.name}</span>
                    <span class="person-color-item__count">{count}</span>
                  </a>
                );
              })}
            </div>
          </div>
        </div>
      </section>
    )}

    <!-- ── Filmography ── -->
    {filmography.length > 0 && (
      <section class="person-filmography">
        <div class="site-container">
          <h2 class="person-filmography__heading">Filmografía</h2>

          <div class="person-filmography__list">
            {filmography.map((entry) => {
              const filmSlug = entry.work.id.replace(/^work_/, '');
              const colorPalette = entry.color ? getPaletteEntry(entry.color.color_iconico) : null;
              return (
                <a href={`/films/${filmSlug}`} class="filmography-item">
                  <div class="filmography-item__color-strip"
                    style={colorPalette ? `background: ${colorPalette.hex}` : 'background: var(--surface-border)'}
                  />
                  <div class="filmography-item__year">
                    {entry.work.year ?? '—'}
                  </div>
                  <div class="filmography-item__info">
                    <span class="filmography-item__title">{entry.work.title}</span>
                    <span class="role-badge">{formatRole(entry.role)}</span>
                  </div>
                  {colorPalette && (
                    <div class="filmography-item__color-name">
                      {colorPalette.name}
                    </div>
                  )}
                </a>
              );
            })}
          </div>
        </div>
      </section>
    )}

    <!-- Empty state -->
    {filmography.length === 0 && !person.bio && (
      <section class="person-empty">
        <div class="site-container">
          <p class="person-empty__message">
            Filmography data for this person is being processed.
          </p>
        </div>
      </section>
    )}
  </div>
</BaseLayout>

<style>
.person-page {
  padding-bottom: 6rem;
}

/* ── Header ── */
.person-header {
  padding-top: 9rem;
  padding-bottom: 4rem;
  border-bottom: 1px solid var(--surface-border);
}

.person-header__inner {
  display: flex;
  gap: 2.5rem;
  align-items: flex-start;
  max-width: var(--content-max-width);
}

@media (max-width: 640px) {
  .person-header__inner { flex-direction: column; gap: 1.5rem; }
}

.person-header__avatar {
  width: 72px;
  height: 72px;
  border-radius: 50%;
  background: var(--surface-card);
  border: 1px solid var(--surface-border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.2rem;
  font-weight: 500;
  color: var(--text-muted);
  flex-shrink: 0;
  letter-spacing: 0.05em;
  overflow: hidden;
}

.person-header__photo {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.person-header__role-label {
  margin-bottom: 0.375rem;
}

.person-ranking-badge {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  margin-bottom: 0.625rem;
  font-size: 0.78rem;
}

.person-ranking-badge__rank {
  font-family: var(--font-mono);
  font-weight: 600;
  color: var(--color-ambar_desertico, #C8922B);
}

.person-ranking-badge__role {
  color: var(--text-secondary);
  text-decoration: none;
  font-weight: 500;
  transition: color 120ms ease;
}
.person-ranking-badge__role:hover { color: var(--text-primary); }

.person-ranking-badge__sep {
  color: var(--text-muted);
}

.person-ranking-badge__score {
  font-family: var(--font-mono);
  color: var(--text-muted);
}

.person-header__name {
  font-family: var(--font-serif);
  font-size: clamp(1.875rem, 4vw, 3rem);
  font-weight: 400;
  color: var(--text-primary);
  margin-bottom: 0.875rem;
}

.person-header__meta {
  display: flex;
  gap: 1.25rem;
  flex-wrap: wrap;
}

.person-header__meta-item {
  font-size: 0.8rem;
  color: var(--text-muted);
}

/* ── Biography ── */
.person-bio {
  padding: 3rem 0;
  border-bottom: 1px solid var(--surface-border);
}

.person-bio__para {
  font-size: 1.05rem;
  line-height: 1.7;
  color: var(--text-secondary);
  max-width: 680px;
  margin-bottom: 1.25em;
}
.person-bio__para:last-child { margin-bottom: 0; }

/* ── Awards ── */
.person-awards {
  padding: 3rem 0;
  border-bottom: 1px solid var(--surface-border);
}

.person-awards__heading {
  font-family: var(--font-sans);
  font-size: 0.68rem;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 1.5rem;
  padding-bottom: 0.75rem;
  border-bottom: 1px solid var(--surface-border);
}

.person-awards__wins {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 0.625rem;
}

.person-award-card {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.875rem 1rem;
  background: var(--surface-card);
  border: 1px solid var(--surface-border);
  border-left: 3px solid var(--tc, var(--surface-border-strong));
  border-radius: 4px;
}

.person-award-card__logo {
  width: 28px;
  height: 28px;
  object-fit: contain;
  flex-shrink: 0;
  filter: invert(1) brightness(1.8);
  opacity: 0.85;
}

.person-award-card__monogram {
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 3px;
  font-family: var(--font-mono);
  font-size: 0.5rem;
  font-weight: 700;
  color: #C98A2E;
  flex-shrink: 0;
}

.person-award-card__body {
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
  min-width: 0;
  flex: 1;
}

.person-award-card__name {
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--text-primary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.person-award-card__meta {
  font-size: 0.72rem;
  color: var(--text-muted);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.person-award-card__film {
  color: var(--text-secondary);
  text-decoration: none;
  transition: color 120ms ease;
}
.person-award-card__film:hover { color: var(--text-primary); }

.person-award-card__fest {
  color: var(--text-muted);
  text-decoration: none;
  transition: color 120ms ease;
}
.person-award-card__fest:hover { color: var(--text-secondary); }

/* Nominations list (shown only if no wins) */
.person-noms-list {
  list-style: none;
  padding: 0;
  margin: 0;
}

.person-nom-row {
  display: flex;
  align-items: baseline;
  gap: 0.5rem;
  flex-wrap: wrap;
  padding: 0.45rem 0;
  border-bottom: 1px solid var(--surface-border);
  font-size: 0.825rem;
}

.person-nom-row__name { color: var(--text-secondary); }
.person-nom-row__sep  { color: var(--text-muted); font-size: 0.7rem; }
.person-nom-row__film { color: var(--text-secondary); text-decoration: none; }
.person-nom-row__film:hover { color: var(--text-primary); }
.person-nom-row__fest { color: var(--text-muted); text-decoration: none; }
.person-nom-row__year { font-size: 0.72rem; color: var(--text-muted); margin-left: auto; }

/* ── Color signature ── */
.person-colors {
  padding: 4rem 0;
  border-bottom: 1px solid var(--surface-border);
}

.person-colors__inner {
  max-width: var(--content-max-width);
}

.person-colors__header {
  margin-bottom: 2rem;
}

.person-colors__heading {
  font-family: var(--font-serif);
  font-size: 1.5rem;
  font-weight: 400;
  color: var(--text-primary);
  margin-bottom: 0.375rem;
}

.person-colors__sub {
  font-size: 0.8rem;
  color: var(--text-muted);
}

.person-colors__signature {
  display: flex;
  align-items: flex-end;
  gap: 1.25rem;
}

.person-color-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
  text-decoration: none;
  transition: transform 160ms ease;
}
.person-color-item:hover { transform: translateY(-3px); }

.person-color-item__bar {
  width: 40px;
  border-radius: 2px 2px 0 0;
  min-height: 12px;
  transition: opacity 160ms ease;
}
.person-color-item:hover .person-color-item__bar { opacity: 0.8; }

.person-color-item__name {
  font-size: 0.62rem;
  color: var(--text-muted);
  text-align: center;
  max-width: 70px;
  line-height: 1.3;
}

.person-color-item__count {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  color: var(--text-muted);
}

/* ── Filmography ── */
.person-filmography {
  padding: 4rem 0;
}

.person-filmography__heading {
  font-family: var(--font-serif);
  font-size: 1.5rem;
  font-weight: 400;
  color: var(--text-primary);
  margin-bottom: 2rem;
}

.person-filmography__list {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.filmography-item {
  display: grid;
  grid-template-columns: 3px 4rem 1fr auto;
  align-items: center;
  gap: 1.25rem;
  padding: 0.875rem 0;
  border-bottom: 1px solid var(--surface-border);
  text-decoration: none;
  transition: background 160ms ease;
}

.filmography-item:hover {
  background: var(--surface-card);
  padding-left: 0.75rem;
  margin-left: -0.75rem;
  border-radius: 3px;
}

.filmography-item__color-strip {
  width: 3px;
  height: 2rem;
  border-radius: 1.5px;
  flex-shrink: 0;
}

.filmography-item__year {
  font-family: var(--font-mono);
  font-size: 0.8rem;
  color: var(--text-muted);
  text-align: right;
}

.filmography-item__info {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  min-width: 0;
}

.filmography-item__title {
  font-size: 0.9rem;
  color: var(--text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  transition: color 160ms ease;
}
.filmography-item:hover .filmography-item__title { color: var(--text-primary); }

