---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getColorProfile } from '../../lib/db/colors';
import { isSupabaseConfigured, createServiceClient } from '../../lib/db/client';
import { isLightColor } from '../../lib/color/colorPalette';
import type { WorkCard, PrismaColorId } from '../../lib/db/types';

const { slug } = Astro.params;

if (!slug) return Astro.redirect('/404');

// Convert URL slug (hyphen) to database/doctrine format (underscore)
// URL: "cian-melancolico" → DB: "cian_melancolico"
const colorId = slug.replace(/-/g, '_') as PrismaColorId;

const doctrine = getColorProfile(colorId);
if (!doctrine) return Astro.redirect('/404');

const lightBg = isLightColor(colorId);
const heroTextColor = lightBg ? '#0A0A0F' : '#F0EEE8';
const heroSubColor = lightBg ? 'rgba(10,10,15,0.55)' : 'rgba(240,238,232,0.45)';

// Fetch films for this color
type GroupedFilms = { canon: WorkCard[]; core: WorkCard[]; strong: WorkCard[]; peripheral: WorkCard[] };
let films: GroupedFilms = { canon: [], core: [], strong: [], peripheral: [] };

if (isSupabaseConfigured()) {
  try {
    const db = createServiceClient();
    // Query color_assignments directly and join to works
    // This bypasses the works_with_color view for more control
    const { data, error } = await db
      .from('color_assignments')
      .select(`
        color_iconico,
        tier,
        tier_rank,
        numeric_score,
        works!inner(
          id,
          title,
          year,
          countries,
          tmdb_poster_path,
          criterion_title,
          is_published
        )
      `)
      .eq('color_iconico', colorId)
      .eq('review_status', 'approved')
      
      .order('tier', { ascending: true })
      .order('tier_rank', { ascending: true, nullsFirst: false })
      .limit(200);

    if (!error && data) {
      for (const row of data as any[]) {
        const work = row.works;
        if (!work) continue;
        
        const workCard: WorkCard = {
          id: work.id,
          title: work.title,
          year: work.year,
          countries: work.countries,
          tmdb_poster_path: work.tmdb_poster_path,
          criterion_title: work.criterion_title,
          color_iconico: row.color_iconico,
          tier: row.tier,
          tier_rank: row.tier_rank,
          numeric_score: row.numeric_score,
          prestige_score: null,
          global_rank: null,
        };
        
        const t: string = row.tier ?? 'uncertain';
        if (t === 'canon') films.canon.push(workCard);
        else if (t === 'core') films.core.push(workCard);
        else if (t === 'strong') films.strong.push(workCard);
        else if (t === 'peripheral') films.peripheral.push(workCard);
        else films.peripheral.push(workCard);
      }
    }
  } catch (err) {
    console.error('[colors/slug] Error fetching films:', err);
    // Graceful degradation — show color page without films
  }
}

const allFilms = [...films.canon, ...films.core, ...films.strong, ...films.peripheral];

// Top 10 poster grid — films with posters, sorted by numeric_score desc
const top10 = allFilms
  .filter((f) => f.tmdb_poster_path)
  .sort((a, b) => (b.numeric_score ?? 0) - (a.numeric_score ?? 0))
  .slice(0, 10);
const posterRow1 = top10.slice(0, 5);
const posterRow2 = top10.slice(5, 10);

const TMDB_IMG = 'https://image.tmdb.org/t/p/w342';

const pageTitle = `${doctrine.name} — Prisma Color`;
const pageDescription = doctrine.cultural_context;
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <!-- Color Hero -->
  <section
    class="color-hero"
    style={`--c-hex: ${doctrine.hex}; --c-text: ${heroTextColor}; --c-sub: ${heroSubColor};`}
  >
    <div class="color-hero__wash" />
    <div class="color-hero__inner site-container">
      <div class="color-hero__overline">Prisma Palette</div>
      <h1 class="color-hero__name">{doctrine.name}</h1>
      <div class="color-hero__hex">{doctrine.hex}</div>
      <p class="color-hero__context">{doctrine.cultural_context}</p>
      <div class="color-hero__moods">
        {doctrine.moods.map((mood) => (
          <span class="color-hero__mood">{mood}</span>
        ))}
      </div>
    </div>
    <div class="color-hero__bar" style={`background: ${doctrine.hex}`} />
  </section>

  <!-- Cinematographic notes -->
  <section class="color-notes">
    <div class="site-container">
      <div class="color-notes__inner">
        <p class="color-notes__text">{doctrine.cinematographic_notes}</p>
        {doctrine.cinematographer_signatures.length > 0 && (
          <div class="color-notes__sigs">
            <span class="color-notes__sigs-label">Associated cinematographers</span>
            <span class="color-notes__sigs-names">{doctrine.cinematographer_signatures.join(' · ')}</span>
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- Top 10 Poster Grid -->
  {top10.length > 0 && (
    <section class="poster-ranking">
      <div class="site-container">
        <div class="poster-ranking__label">Ranking</div>

        <div class="poster-row">
          {posterRow1.map((film, i) => {
            const filmSlug = film.id.replace(/^work_/, '');
            return (
              <a href={`/films/${filmSlug}`} class="poster-card">
                {film.tmdb_poster_path
                  ? <img
                      src={`${TMDB_IMG}${film.tmdb_poster_path}`}
                      alt={film.title}
                      class="poster-card__img"
                      loading="lazy"
                      decoding="async"
                    />
                  : <div class="poster-card__fallback" style={`background: ${doctrine.hex}`}>
                      <span class="poster-card__fallback-title">{film.title}</span>
                    </div>
                }
                <span class="poster-card__num">#{i + 1}</span>
                <div class="poster-card__overlay">
                  <span class="poster-card__overlay-title">{film.title}</span>
                  {film.year && <span class="poster-card__overlay-year">{film.year}</span>}
                </div>
              </a>
            );
          })}
        </div>

        {posterRow2.length > 0 && (
          <div class="poster-row poster-row--secondary">
            {posterRow2.map((film, i) => {
              const filmSlug = film.id.replace(/^work_/, '');
              return (
                <a href={`/films/${filmSlug}`} class="poster-card">
                  {film.tmdb_poster_path
                    ? <img
                        src={`${TMDB_IMG}${film.tmdb_poster_path}`}
                        alt={film.title}
                        class="poster-card__img"
                        loading="lazy"
                        decoding="async"
                      />
                    : <div class="poster-card__fallback" style={`background: ${doctrine.hex}`}>
                        <span class="poster-card__fallback-title">{film.title}</span>
                      </div>
                  }
                  <span class="poster-card__num">#{i + 6}</span>
                  <div class="poster-card__overlay">
                    <span class="poster-card__overlay-title">{film.title}</span>
                    {film.year && <span class="poster-card__overlay-year">{film.year}</span>}
                  </div>
                </a>
              );
            })}
          </div>
        )}
      </div>
    </section>
  )}

  <!-- Film grid -->
  {allFilms.length > 0 ? (
    <section class="color-films">
      <div class="site-container">
        <div class="color-films__header">
          <h2 class="color-films__heading">Films in this color</h2>
          <span class="color-films__count">{allFilms.length} works</span>
        </div>

        {films.canon.length > 0 && (
          <div class="color-films__tier">
            <div class="color-films__tier-label">
              <span class="tier-badge tier-badge--canon">Canon</span>
            </div>
            <div class="color-films__grid">
              {films.canon.map((film) => {
                const slug = film.id.replace(/^work_/, '');
                return (
                  <a href={`/films/${slug}`} class="film-card">
                    <div class="film-card__rank">
                      {film.tier_rank ? `#${film.tier_rank}` : ''}
                    </div>
                    <div class="film-card__info">
                      <span class="film-card__title">{film.title}</span>
                      {film.year && <span class="film-card__year">{film.year}</span>}
                      {film.criterion_title && (
                        <span class="film-card__criterion">C</span>
                      )}
                    </div>
                  </a>
                );
              })}
            </div>
          </div>
        )}

        {films.core.length > 0 && (
          <div class="color-films__tier">
            <div class="color-films__tier-label">
              <span class="tier-badge tier-badge--core">Core</span>
            </div>
            <div class="color-films__grid">
              {films.core.map((film) => {
                const filmSlug = film.id.replace(/^work_/, '');
                return (
                  <a href={`/films/${filmSlug}`} class="film-card">
                    <div class="film-card__info">
                      <span class="film-card__title">{film.title}</span>
                      {film.year && <span class="film-card__year">{film.year}</span>}
                    </div>
                  </a>
                );
              })}
            </div>
          </div>
        )}

        {films.strong.length > 0 && (
          <div class="color-films__tier">
            <div class="color-films__tier-label">
              <span class="tier-badge tier-badge--strong">Strong</span>
            </div>
            <div class="color-films__grid">
              {films.strong.map((film) => {
                const filmSlug = film.id.replace(/^work_/, '');
                return (
                  <a href={`/films/${filmSlug}`} class="film-card">
                    <div class="film-card__info">
                      <span class="film-card__title">{film.title}</span>
                      {film.year && <span class="film-card__year">{film.year}</span>}
                    </div>
                  </a>
                );
              })}
            </div>
          </div>
        )}

        {films.peripheral.length > 0 && (
          <div class="color-films__tier">
            <div class="color-films__tier-label">
              <span class="tier-badge tier-badge--peripheral">Peripheral</span>
            </div>
            <div class="color-films__grid">
              {films.peripheral.map((film) => {
                const filmSlug = film.id.replace(/^work_/, '');
                return (
                  <a href={`/films/${filmSlug}`} class="film-card">
                    <div class="film-card__info">
                      <span class="film-card__title">{film.title}</span>
                      {film.year && <span class="film-card__year">{film.year}</span>}
                    </div>
                  </a>
                );
              })}
            </div>
          </div>
        )}
      </div>
    </section>
  ) : (
    <section class="color-films">
      <div class="site-container">
        <p class="color-films__empty">No films assigned to this color yet.</p>
      </div>
    </section>
  )}

  <!-- Reference examples -->
  {doctrine.reference_examples.length > 0 && (
    <section class="color-refs">
      <div class="site-container">
        <div class="color-refs__inner">
          <h3 class="color-refs__heading">Reference examples</h3>
          <p class="color-refs__note">Illustrative only — not canonical assignments.</p>
          <ul class="color-refs__list">
            {doctrine.reference_examples.map((ex) => (
              <li class="color-refs__item">{ex}</li>
            ))}
          </ul>
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
/* ─── Top 10 Poster Grid ────────────────────────────────────────────────── */
.poster-ranking {
  padding: 3rem 0 0;
}

.poster-ranking__label {
  font-family: var(--font-sans);
  font-size: 0.65rem;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 1rem;
}

.poster-row {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 1rem;
  margin-bottom: 1rem;
}

.poster-row--secondary {
  /* row 2 is slightly shorter via a smaller aspect-ratio on cards */
}

.poster-card {
  position: relative;
  display: block;
  aspect-ratio: 2 / 3;
  border-radius: 3px;
  overflow: hidden;
  text-decoration: none;
  background: var(--surface-card);
  flex-shrink: 0;
}

.poster-card__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  display: block;
  transition: transform 220ms ease;
}
.poster-card:hover .poster-card__img {
  transform: scale(1.03);
}

.poster-card__fallback {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0.75rem;
}

.poster-card__fallback-title {
  font-size: 0.75rem;
  color: rgba(255,255,255,0.75);
  text-align: center;
  line-height: 1.4;
}

/* Position number */
.poster-card__num {
  position: absolute;
  top: 0.5rem;
  left: 0.5rem;
  font-family: var(--font-mono);
  font-size: 0.65rem;
  color: rgba(255,255,255,0.55);
  font-weight: 400;
  line-height: 1;
  pointer-events: none;
  text-shadow: 0 1px 3px rgba(0,0,0,0.6);
}

/* Hover overlay */
.poster-card__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.88) 0%, rgba(0,0,0,0.3) 45%, transparent 70%);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 0.625rem 0.625rem 0.75rem;
  opacity: 0;
  transform: translateY(4px);
  transition: opacity 180ms ease, transform 180ms ease;
}
.poster-card:hover .poster-card__overlay {
  opacity: 1;
  transform: translateY(0);
}

.poster-card__overlay-title {
  font-size: 0.72rem;
  color: #F0EEE8;
  line-height: 1.3;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.poster-card__overlay-year {
  font-size: 0.62rem;
  color: rgba(240,238,232,0.6);
  margin-top: 0.2rem;
  font-family: var(--font-mono);
}

/* Mobile: horizontal scroll rows */
@media (max-width: 640px) {
  .poster-row {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    gap: 0.625rem;
    padding-bottom: 0.5rem;
    -webkit-overflow-scrolling: touch;
    /* hide scrollbar */
    scrollbar-width: none;
  }
  .poster-row::-webkit-scrollbar { display: none; }

  .poster-card {
    width: 140px;
    min-width: 140px;
    aspect-ratio: 2 / 3;
    scroll-snap-align: start;
  }
}

/* ─── Color hero ─────────────────────────────────────────────────────────── */
.color-hero {
  position: relative;
  min-height: min(90vh, 600px);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding-bottom: 4rem;
  overflow: hidden;
}

.color-hero__wash {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    155deg,
    var(--c-hex) 0%,
    color-mix(in srgb, var(--c-hex) 50%, #0D0D0F) 50%,
    #0D0D0F 100%
  );
}

.color-hero__inner {
  position: relative;
  z-index: 1;
  padding-top: 10rem;
}

.color-hero__bar {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 4px;
  opacity: 0.6;
}

.color-hero__overline {
  font-size: 0.65rem;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--c-sub);
  margin-bottom: 0.875rem;
}

.color-hero__name {
  font-family: var(--font-serif);
  font-size: clamp(2.75rem, 7vw, 5.5rem);
  font-weight: 400;
  line-height: 1.05;
  color: var(--c-text);
  margin-bottom: 0.5rem;
}

.color-hero__hex {
  font-family: var(--font-mono);
  font-size: 0.85rem;
  color: var(--c-sub);
  letter-spacing: 0.1em;
  margin-bottom: 1.75rem;
}

.color-hero__context {
  font-size: 1.05rem;
  line-height: 1.65;
  color: var(--c-sub);
  max-width: 48ch;
  margin-bottom: 1.75rem;
  font-style: italic;
}

.color-hero__moods {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}

.color-hero__mood {
  font-size: 0.62rem;
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 0.25rem 0.625rem;
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: 2px;
  color: var(--c-sub);
}

/* ─── Notes ────────────────────────────────────────────────────────────────── */
.color-notes {
  padding: 4rem 0;
  border-bottom: 1px solid var(--surface-border);
}

.color-notes__inner {
  max-width: var(--content-max-width);
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

.color-notes__text {
  font-size: 1.05rem;
  line-height: 1.8;
  color: var(--text-secondary);
}

.color-notes__sigs {
  display: flex;
  align-items: baseline;
  gap: 1rem;
  flex-wrap: wrap;
}

.color-notes__sigs-label {
  font-size: 0.62rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--text-muted);
  flex-shrink: 0;
}

.color-notes__sigs-names {
  font-size: 0.875rem;
  color: var(--text-secondary);
}

/* ─── Film grid ─────────────────────────────────────────────────────────────── */
.color-films {
  padding: 4rem 0;
}

.color-films__header {
  display: flex;
  align-items: baseline;
  gap: 1.5rem;
  margin-bottom: 3rem;
}

.color-films__heading {
  font-family: var(--font-serif);
  font-size: 1.75rem;
  font-weight: 400;
  color: var(--text-primary);
}

.color-films__count {
  font-size: 0.75rem;
  color: var(--text-muted);
}

.color-films__tier {
  margin-bottom: 2.5rem;
}

.color-films__tier-label {
  margin-bottom: 1rem;
}

.color-films__grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: 0.75rem;
}

.film-card {
  display: flex;
  align-items: center;
  gap: 0.875rem;
  padding: 0.875rem 1rem;
  background: var(--surface-card);
  border: 1px solid var(--surface-border);
  border-radius: 3px;
  transition: border-color 160ms ease, transform 160ms ease;
  text-decoration: none;
}

.film-card:hover {
  border-color: var(--surface-border-strong);
  transform: translateY(-1px);
}

.film-card__rank {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  color: var(--text-muted);
  flex-shrink: 0;
  width: 2.5rem;
}

.film-card__info {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
  min-width: 0;
}

.film-card__title {
  font-size: 0.875rem;
  color: var(--text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  transition: color 160ms ease;
}
.film-card:hover .film-card__title { color: var(--text-primary); }

.film-card__year {
  font-size: 0.7rem;
  color: var(--text-muted);
}

.film-card__criterion {
  display: inline-block;
  font-size: 0.6rem;
  font-weight: 700;
  width: 16px;
  height: 16px;
  line-height: 16px;
  text-align: center;
  background: rgba(212,201,168,0.12);
  border: 1px solid rgba(212,201,168,0.25);
  border-radius: 50%;
  color: var(--text-accent);
}

.color-films__empty {
  color: var(--text-muted);
  font-size: 0.875rem;
  font-style: italic;
}

/* ─── References ─────────────────────────────────────────────────────────────── */
.color-refs {
  padding: 3rem 0 5rem;
  border-top: 1px solid var(--surface-border);
}

.color-refs__inner {
  max-width: var(--content-max-width);
}

.color-refs__heading {
  font-family: var(--font-sans);
  font-size: 0.65rem;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 0.5rem;
}

.color-refs__note {
  font-size: 0.75rem;
  color: var(--text-muted);
  font-style: italic;
  margin-bottom: 1.25rem;
}

.color-refs__list {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.color-refs__item {
  font-size: 0.875rem;
  color: var(--text-secondary);
  padding-left: 1rem;
  position: relative;
}

.color-refs__item::before {
  content: '—';
  position: absolute;
  left: 0;
  color: var(--text-muted);
}
</style>
