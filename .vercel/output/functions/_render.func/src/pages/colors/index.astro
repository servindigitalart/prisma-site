---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllColorProfiles } from '../../lib/db/colors';
import { isLightColor } from '../../lib/color/colorPalette';

const colors = getAllColorProfiles();

const SITE = 'https://prisma.film';

const colorsBreadcrumbs = [
  { name: 'PRISMA', url: SITE },
  { name: 'Colores', url: `${SITE}/colors` },
];

const colorsJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'La Paleta Prisma — Colores del Cine de Autor',
  description: 'Los 18 colores de la paleta Prisma. Cada película tiene un color que define su identidad visual cinematográfica.',
  url: `${SITE}/colors`,
  numberOfItems: colors.length,
  itemListElement: colors.map((c, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: c.name,
    url: `${SITE}/colors/${c.id}`,
  })),
};

const MONO_MODES = [
  {
    id: 'claroscuro_dramatico',
    slug: 'claroscuro-dramatico',
    name: 'Claroscuro Dramático',
    hex: '#1A1A1A',
    gradient: 'linear-gradient(to right, #0A0A0F 30%, #F0EEE8 70%)',
    context: 'High contrast light and shadow. The drama of what is hidden and revealed.',
  },
  {
    id: 'monocromatico_intimo',
    slug: 'monocromatico-intimo',
    name: 'Monocromático Íntimo',
    hex: '#4A4A4A',
    gradient: 'linear-gradient(135deg, #3A3A3A 0%, #909090 50%, #D8D8D8 100%)',
    context: 'Desaturated grey tones. Texture and mood over chromatic spectacle.',
  },
];
---

<BaseLayout
  title="Paleta de Colores — PRISMA"
  description="Los 18 colores de la paleta Prisma. Cada película tiene un color."
  jsonLd={colorsJsonLd}
  breadcrumbs={colorsBreadcrumbs}
>
  <div class="colors-page page-enter">

    <!-- Hero -->
    <div class="colors-hero site-container">
      <div class="colors-hero__inner">
        <p class="colors-hero__eyebrow reveal">Identidad cromática</p>
        <h1 class="colors-hero__title reveal" data-delay="80">La Paleta Prisma</h1>
        <p class="colors-hero__subtitle reveal" data-delay="160">
          Dieciocho colores. Cada uno un registro emocional distinto en el cine de autor.
        </p>
      </div>
    </div>

    <!-- Color grid — chromatic spectrum (16 colors, mono excluded — shown separately below) -->
    <div class="colors-grid site-container">
      {colors.filter(c => c.id !== 'claroscuro_dramatico' && c.id !== 'monocromatico_intimo').map((color, i) => {
        const light = isLightColor(color.id);
        const swatchTextColor = light ? 'rgba(10,10,15,0.55)' : 'rgba(240,238,232,0.5)';
        return (
          <a
            href={`/colors/${color.id}`}
            class="color-card reveal"
            data-delay={String(Math.min(i * 40, 400))}
            style={`--c: ${color.hex}; --ct: ${light ? '#0A0A0F' : '#F0EEE8'}; --cs: ${swatchTextColor};`}
          >
            <!-- Full-color swatch block on top -->
            <div class="color-card__swatch">
              <span class="color-card__swatch-hex">{color.hex}</span>
            </div>

            <!-- Info -->
            <div class="color-card__body">
              <span class="color-card__name">{color.name}</span>
              <span class="color-card__context">
                {color.cultural_context.length > 72
                  ? color.cultural_context.substring(0, 72) + '…'
                  : color.cultural_context}
              </span>
            </div>

            <!-- Color accent line at the bottom on hover -->
            <div class="color-card__accent" />
          </a>
        );
      })}
    </div>

    <!-- Monochromatic modes -->
    <div class="mono-section site-container">
      <div class="section-label reveal">Modos Monocromáticos</div>

      <div class="mono-grid">
        {MONO_MODES.map((mono) => (
          <a href={`/colors/${mono.slug}`} class="color-card color-card--mono" style={`--c: ${mono.hex};`}>
            <div class="color-card__swatch color-card__swatch--gradient" style={`background: ${mono.gradient};`}>
              <span class="color-card__swatch-hex" style="color: rgba(240,238,232,0.45)">B&W MODE</span>
            </div>
            <div class="color-card__body">
              <span class="color-card__name">{mono.name}</span>
              <span class="color-card__context">{mono.context}</span>
            </div>
            <div class="color-card__accent" />
          </a>
        ))}
      </div>
    </div>

  </div>
</BaseLayout>

<style>
.colors-page {
  padding-top: var(--space-16);
  padding-bottom: var(--space-16);
}

/* ─── Hero ─────────────────────────────────────────────────────────────────── */
.colors-hero {
  margin-bottom: var(--space-12);
}

.colors-hero__inner {
  max-width: 50ch;
}

.colors-hero__eyebrow {
  font-family: var(--font-sans);
  font-size: var(--text-xs);
  font-weight: var(--weight-semi);
  letter-spacing: var(--tracking-widest);
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: var(--space-4);
}

.colors-hero__title {
  font-family: var(--font-serif);
  font-size: clamp(2.25rem, 5vw, 4rem);
  font-weight: 400;
  color: var(--text-primary);
  line-height: 1.08;
  letter-spacing: -0.02em;
  margin-bottom: var(--space-5);
}

.colors-hero__subtitle {
  font-size: 1rem;
  color: var(--text-muted);
  max-width: 44ch;
  line-height: 1.7;
}

/* ─── Color card grid ───────────────────────────────────────────────────────── */
.colors-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: var(--space-5);
  margin-bottom: var(--space-12);
}

.color-card {
  display: flex;
  flex-direction: column;
  background: var(--bg-raised);
  border: 1px solid var(--surface-border);
  border-radius: var(--radius-md);
  overflow: hidden;
  text-decoration: none;
  transition:
    transform var(--dur-base) var(--ease-editorial),
    box-shadow var(--dur-base) var(--ease-editorial),
    border-color var(--dur-base) var(--ease-editorial),
    background var(--dur-base) var(--ease-editorial);
  position: relative;
  will-change: transform;
}

.color-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 32px rgba(0,0,0,0.4), 0 0 0 1px color-mix(in srgb, var(--c) 30%, transparent);
  border-color: color-mix(in srgb, var(--c) 25%, var(--surface-border));
  background: color-mix(in srgb, var(--c) 7%, var(--bg-raised));
}

/* The actual color swatch — tall block at top */
.color-card__swatch {
  height: 96px;
  background: var(--c);
  flex-shrink: 0;
  position: relative;
  display: flex;
  align-items: flex-end;
  padding: 0.625rem 0.875rem;
  transition: height var(--dur-base) var(--ease-editorial);
}

.color-card:hover .color-card__swatch {
  height: 112px;
}

.color-card__swatch-hex {
  font-family: var(--font-mono);
  font-size: 0.6rem;
  color: var(--cs, rgba(240,238,232,0.45));
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

.color-card__swatch--gradient {
  background: var(--gradient, #1A1A1A);
}

/* Body — title + context */
.color-card__body {
  padding: var(--space-4) var(--space-5) var(--space-5);
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
  flex: 1;
}

.color-card__name {
  font-family: var(--font-serif);
  font-size: 1rem;
  font-weight: 400;
  color: var(--text-secondary);
  line-height: 1.2;
  transition: color var(--dur-fast) var(--ease-editorial);
}

.color-card:hover .color-card__name {
  color: var(--text-primary);
}

.color-card__context {
  font-size: var(--text-xs);
  color: var(--text-muted);
  line-height: 1.55;
  opacity: 0.8;
  transition: opacity var(--dur-fast) var(--ease-editorial);
}

.color-card:hover .color-card__context {
  opacity: 1;
}

/* Bottom accent: slides in on hover */
.color-card__accent {
  height: 2px;
  background: var(--c);
  transform: scaleX(0);
  transform-origin: left;
  transition: transform var(--dur-base) var(--ease-editorial);
}

.color-card:hover .color-card__accent {
  transform: scaleX(1);
}

/* Mono variant */
.color-card--mono {
  opacity: 0.88;
}

.color-card--mono:hover {
  opacity: 1;
}

/* ─── Mono section ──────────────────────────────────────────────────────────── */
.mono-section {
  padding-top: var(--space-6);
}

.mono-section .section-label {
  margin-bottom: var(--space-6);
}

.mono-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: var(--space-5);
}

/* ─── Mobile ─────────────────────────────────────────────────────────────────── */
@media (max-width: 640px) {
  .colors-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
  }

  .color-card__swatch { height: 72px; }
  .color-card:hover .color-card__swatch { height: 80px; }

  .color-card__body { padding: var(--space-3); }
  .color-card__context { display: none; }

  .mono-grid { grid-template-columns: 1fr; }
}
</style>
