---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getAllColorProfiles } from '../lib/db/colors';
import { getPaletteEntry, isLightColor } from '../lib/color/colorPalette';
import { isSupabaseConfigured, createServiceClient } from '../lib/db/client';
import { loadAllWorks } from '../lib/loaders/loadWork';

// ─── Color strips — spectrum order ───────────────────────────────────────────
const COLOR_STRIP_ORDER = [
  'rojo_pasional',
  'naranja_apocaliptico',
  'ambar_desertico',
  'amarillo_ludico',
  'verde_lima',
  'verde_esmeralda',
  'verde_distopico',
  'cian_melancolico',
  'azul_nocturno',
  'violeta_cinetico',
  'purpura_onirico',
  'magenta_pop',
  'rosa_pastel',
  'blanco_polar',
  'titanio_mecanico',
  'monocromatico_intimo',
  'claroscuro_dramatico',
  'negro_abismo',
];

type StripEntry = {
  id: string;
  hex: string;
  name: string;
  posters: Array<{ slug: string; title: string; path: string }>;
};

const colorStrips: StripEntry[] = COLOR_STRIP_ORDER.map((id) => {
  const p = getPaletteEntry(id)!;
  return { id, hex: p.hex, name: p.name, posters: [] };
});

// Fetch top 3 posters per color from Supabase
if (isSupabaseConfigured()) {
  try {
    const db = createServiceClient();
    const { data } = await db
      .from('color_assignments')
      .select(`color_iconico, works!inner(id, title, tmdb_poster_path, is_published)`)
      .in('color_iconico', COLOR_STRIP_ORDER)
      .eq('works.is_published', true)
      .not('works.tmdb_poster_path', 'is', null)
      .order('color_rank', { ascending: false })
      .limit(500);

    const countPerColor: Record<string, number> = {};
    for (const row of (data ?? []) as any[]) {
      const colorId: string = row.color_iconico;
      const work = row.works as { id: string; title: string; tmdb_poster_path: string | null } | null;
      if (!work?.tmdb_poster_path) continue;
      countPerColor[colorId] = countPerColor[colorId] ?? 0;
      if (countPerColor[colorId] >= 3) continue;
      countPerColor[colorId]++;
      const strip = colorStrips.find((s) => s.id === colorId);
      if (strip) {
        strip.posters.push({ slug: work.id.replace(/^work_/, ''), title: work.title, path: work.tmdb_poster_path });
      }
    }
  } catch {
    // poster overlay silently skipped
  }
}

// ─── Top-ranked films ────────────────────────────────────────────────────────
let topFilms: Array<{
  id: string; title: string; year: number | null; slug: string;
  colorId: string | null; colorHex: string; colorName: string;
  rank: number | null; score?: number | null;
}> = [];

if (isSupabaseConfigured()) {
  try {
    const db = createServiceClient();
    const { data } = await db
      .from('ranking_scores')
      .select(`rank, score, works!inner(id, title, year, is_published, color_assignments(color_iconico, tier))`)
      .eq('entity_type', 'work')
      .eq('context', 'global')
      .order('score', { ascending: false })
      .limit(5);

    for (const row of (data ?? []) as unknown[]) {
      const r = row as {
        rank: number | null; score: number | null;
        works: { id: string; title: string; year: number | null; color_assignments: Array<{ color_iconico: string | null }> | null };
      };
      const colorId = r.works.color_assignments?.[0]?.color_iconico ?? null;
      const p = colorId ? getPaletteEntry(colorId) : null;
      topFilms.push({ id: r.works.id, title: r.works.title, year: r.works.year,
        slug: r.works.id.replace(/^work_/, ''), colorId,
        colorHex: p?.hex ?? '#1B2A41', colorName: p?.name ?? '', rank: r.rank, score: r.score });
    }
    topFilms.sort((a, b) => (b.score ?? 0) - (a.score ?? 0));
  } catch { /* fall through */ }
}

if (topFilms.length === 0) {
  const works = loadAllWorks();
  works.sort((a, b) => ((b as any).tmdb_rating ?? 0) - ((a as any).tmdb_rating ?? 0));
  topFilms = works.slice(0, 5).map((w) => {
    const colorId = w.prisma_palette?.primary ?? null;
    const p = colorId ? getPaletteEntry(colorId) : null;
    return { id: w.id, title: w.title, year: w.year ?? null, slug: w.slug, colorId,
      colorHex: p?.hex ?? '#1B2A41', colorName: p?.name ?? '', rank: null };
  });
}

// ─── Featured colors ─────────────────────────────────────────────────────────
const allColors = getAllColorProfiles();
const FEATURED_COLOR_IDS = ['amarillo_ludico', 'azul_nocturno', 'rojo_pasional'];
const featuredColors = FEATURED_COLOR_IDS
  .map((id) => allColors.find((c) => c.id === id))
  .filter(Boolean) as typeof allColors;

const TMDB_IMG = 'https://image.tmdb.org/t/p/w185';

const homepageJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'PRISMA',
  alternateName: 'PRISMA Film',
  url: 'https://prisma.film',
  description: 'Cada película tiene un color. PRISMA traza el ADN visual del cine a través de una paleta emocional de 18 colores.',
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://prisma.film/rankings/films?q={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
};
---

<BaseLayout
  title="PRISMA — Identidad Cromática del Cine"
  description="Cada película tiene un color. PRISMA traza el ADN visual del cine a través de una paleta emocional de 18 colores."
  jsonLd={homepageJsonLd}
>
  <!-- ─── Hero — Animated Color Strips ───────────────────────────────────────── -->
  <section class="prism-hero" aria-label="PRISMA color spectrum">
    <!-- Layer 1: color strips -->
    <div class="prism-strips" id="prism-strips">
      {colorStrips.map((strip, i) => (
        <div
          class="prism-strip"
          style={`background: ${strip.hex}; animation-delay: ${i * 80}ms;`}
          data-color-id={strip.id}
          data-hex={strip.hex}
          data-posters={JSON.stringify(strip.posters)}
          aria-hidden="true"
        />
      ))}
    </div>

    <!-- Layer 2: dark vignette for text legibility -->
    <div class="prism-vignette" aria-hidden="true" />

    <!-- Layer 3: text overlay -->
    <div class="prism-text-wrap">
      <div class="prism-text">
        <p class="prism-eyebrow">Inteligencia cromática cinematográfica</p>
        <h1 class="prism-title">Cada película<br />tiene un color.</h1>
        <p class="prism-body">
          PRISMA traza el ADN visual del cine a través de una paleta emocional de 18 colores —
          asignando a cada película una identidad cromática singular definida por la memoria colectiva,
          la intención cinematográfica y la resonancia cultural.
        </p>
        <div class="prism-actions">
          <a href="/rankings/films" class="prism-cta">Explorar rankings</a>
          <a href="/colors" class="prism-link">Ver la paleta →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Top films showcase ─────────────────────────────────────────────────── -->
  {topFilms.length > 0 && (
    <section class="home-films">
      <div class="site-container">
        <div class="home-films__header">
          <h2 class="home-films__heading">Mejor rankeadas</h2>
          <a href="/rankings/films" class="home-films__see-all">Ver todas →</a>
        </div>

        <div class="home-films__scroll">
          {topFilms.map((film) => {
            const cardColorHex = film.colorHex || '#1A1A1F';
            return (
            <a href={`/films/${film.slug}`} class="home-film-card" style={`--fc: ${cardColorHex};`}>
              <div class="home-film-card__color-wash" />
              <div class="home-film-card__content">
                {film.rank && <span class="home-film-card__rank">#{film.rank}</span>}
                <h3 class="home-film-card__title">{film.title}</h3>
                {film.year && <span class="home-film-card__year">{film.year}</span>}
                {film.colorName && (
                  <div class="home-film-card__color">
                    <span class="home-film-card__color-dot" style={`background: ${cardColorHex}`} />
                    <span class="home-film-card__color-name">{film.colorName}</span>
                  </div>
                )}
              </div>
            </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- ─── Featured colors ────────────────────────────────────────────────────── -->
  {featuredColors.length > 0 && (
    <section class="home-colors">
      <div class="site-container">
        <div class="home-colors__header">
          <h2 class="home-colors__heading">Explora la paleta</h2>
          <a href="/colors" class="home-colors__see-all">Los 18 colores →</a>
        </div>

        <div class="home-colors__grid">
          {featuredColors.map((color) => {
            const light = isLightColor(color.id);
            return (
              <a
                href={`/colors/${color.id}`}
                class="home-color-block"
                style={`--c: ${color.hex}; --ct: ${light ? '#0A0A0F' : '#F0EEE8'}; --cs: ${light ? 'rgba(10,10,15,0.55)' : 'rgba(240,238,232,0.5)'};`}
              >
                <div class="home-color-block__wash" />
                <div class="home-color-block__content">
                  <span class="home-color-block__name">{color.name}</span>
                  <span class="home-color-block__context">{color.cultural_context}</span>
                  <div class="home-color-block__moods">
                    {color.moods.slice(0, 3).map((m) => (
                      <span class="home-color-block__mood">{m}</span>
                    ))}
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- ─── Manifesto ───────────────────────────────────────────────────────────── -->
  <section class="home-manifesto">
    <div class="site-container">
      <div class="home-manifesto__inner">
        <h2 class="home-manifesto__heading">
          El color no es decoración.<br />Es argumento.
        </h2>
        <div class="home-manifesto__body">
          <p>
            La paleta Prisma es un rechazo deliberado al conteo de píxeles. La identidad cromática
            en el cine la determina lo que el público se lleva consigo — el rojo lastimado de una
            confrontación final, el azul frío de un café nocturno, el amarillo difuso
            de una infancia recordada.
          </p>
          <p>
            Nuestro sistema de 18 colores traza el registro emocional del lenguaje visual del cine.
            No lo más frecuente en pantalla, sino lo más verdadero.
          </p>
        </div>
        <a href="/colors" class="home-manifesto__link">Leer la doctrina →</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
/* ─── Hero — Color Strips ───────────────────────────────────────────────────── */
.prism-hero {
  position: relative;
  height: 65vh;
  min-height: 480px;
  overflow: hidden;
}

/* Layer 1: strips */
.prism-strips {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: row;
}

.prism-strip {
  flex: 1;
  min-width: 0;
  cursor: pointer;
  transition: flex 400ms cubic-bezier(0.25, 0.46, 0.45, 0.94),
              filter 200ms ease;
  animation: strip-breathe 4s ease-in-out infinite alternate;
  will-change: flex, filter;
}

/* Hover: expand hovered, compress siblings, dim siblings */
.prism-strips:hover .prism-strip {
  flex: 0.6;
  filter: brightness(0.7);
}
.prism-strips:hover .prism-strip:hover {
  flex: 2.5;
  filter: brightness(1.05);
}

/* Breathing keyframes — GPU-only via filter */
@keyframes strip-breathe {
  from { filter: brightness(0.88); }
  to   { filter: brightness(1.0); }
}
/* Preserve breathing baseline when not in hover state */
.prism-strips:not(:hover) .prism-strip {
  animation: strip-breathe 4s ease-in-out infinite alternate;
}

/* Poster cards injected by JS */
.prism-poster {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%) translateY(8px);
  width: 90%;
  max-width: 110px;
  border-radius: 3px;
  overflow: hidden;
  text-decoration: none;
  opacity: 0;
  transition: opacity 220ms ease, transform 220ms ease;
  box-shadow: 0 4px 20px rgba(0,0,0,0.5);
  z-index: 10;
}
.prism-poster--visible {
  opacity: 1;
  transform: translateX(-50%) translateY(0);
}
.prism-poster img {
  display: block;
  width: 100%;
  aspect-ratio: 2 / 3;
  object-fit: cover;
}
.prism-poster__label {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 0.4rem 0.35rem 0.35rem;
  font-size: 0.55rem;
  color: #F0EEE8;
  line-height: 1.2;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* Layer 2: vignette for text */
.prism-vignette {
  position: absolute;
  inset: 0;
  background: radial-gradient(
    ellipse 70% 80% at 50% 50%,
    rgba(0,0,0,0.55) 0%,
    rgba(0,0,0,0.2) 60%,
    transparent 100%
  );
  pointer-events: none;
  z-index: 5;
}

/* Layer 3: text */
.prism-text-wrap {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 20;
  pointer-events: none;
}

.prism-text {
  text-align: center;
  padding: 0 1.5rem;
  pointer-events: auto;
}

.prism-eyebrow {
  font-size: 0.62rem;
  font-weight: 600;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: rgba(240,238,232,0.6);
  margin-bottom: 1.25rem;
  text-shadow: 0 1px 6px rgba(0,0,0,0.6);
}

.prism-title {
  font-family: var(--font-serif);
  font-size: clamp(2.75rem, 7vw, 5.5rem);
  font-weight: 400;
  line-height: 1.04;
  color: #F0EEE8;
  margin-bottom: 1.5rem;
  text-shadow: 0 2px 16px rgba(0,0,0,0.55);
}

.prism-body {
  font-size: clamp(0.85rem, 1.5vw, 1rem);
  line-height: 1.75;
  color: rgba(240,238,232,0.75);
  max-width: 48ch;
  margin: 0 auto 2rem;
  text-shadow: 0 1px 8px rgba(0,0,0,0.5);
}

.prism-actions {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 2rem;
  flex-wrap: wrap;
}

.prism-cta {
  display: inline-block;
  padding: 0.7rem 1.6rem;
  background: rgba(240,238,232,0.95);
  color: #0A0A0F;
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  border-radius: 2px;
  transition: background 160ms ease;
  text-decoration: none;
}
.prism-cta:hover { background: #fff; }

.prism-link {
  font-size: 0.82rem;
  color: rgba(240,238,232,0.7);
  transition: color 160ms ease;
  text-decoration: none;
  text-shadow: 0 1px 6px rgba(0,0,0,0.4);
}
.prism-link:hover { color: #F0EEE8; }

/* Mobile: horizontal bands */
@media (max-width: 640px) {
  .prism-hero { height: auto; min-height: 0; }
  .prism-strips {
    position: relative;
    flex-direction: column;
    height: calc(18 * 48px);
  }
  .prism-strip {
    flex: none;
    height: 48px;
    animation: none;
    filter: brightness(0.92);
  }
  .prism-strips:hover .prism-strip,
  .prism-strips:hover .prism-strip:hover {
    flex: none;
    filter: brightness(0.92);
  }
  .prism-vignette { display: none; }
  .prism-text-wrap {
    position: relative;
    background: var(--surface-bg);
    padding: 3.5rem 1.5rem 3rem;
  }
  .prism-eyebrow { color: var(--text-muted); text-shadow: none; }
  .prism-title { color: var(--text-primary); text-shadow: none; font-size: 2.5rem; }
  .prism-body { color: var(--text-secondary); text-shadow: none; }
  .prism-cta { background: var(--text-primary); color: var(--surface-bg); }
  .prism-link { color: var(--text-muted); text-shadow: none; }
}

/* ─── Top films ─────────────────────────────────────────────────────────────── */
.home-films {
  padding: 5rem 0;
  border-top: 1px solid var(--surface-border);
}

.home-films__header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 2.5rem;
}

.home-films__heading {
  font-family: var(--font-serif);
  font-size: 1.5rem;
  font-weight: 400;
  color: var(--text-primary);
}

.home-films__see-all {
  font-size: 0.78rem;
  color: var(--text-muted);
  transition: color 160ms ease;
}
.home-films__see-all:hover { color: var(--text-secondary); }

.home-films__scroll {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 1px;
  border: 1px solid var(--surface-border);
  border-radius: 4px;
  overflow: hidden;
}

@media (min-width: 768px) {
  .home-films__scroll { grid-template-columns: repeat(5, 1fr); }
}

.home-film-card {
  position: relative;
  padding: 1.5rem 1.25rem;
  text-decoration: none;
  overflow: hidden;
  background: var(--surface-card);
  min-height: 200px;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  transition: background 160ms ease;
}
.home-film-card:hover { background: var(--surface-elevated); }

.home-film-card__color-wash {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 4px;
  background: var(--fc);
}

.home-film-card__content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 0.35rem;
}

.home-film-card__rank {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  color: var(--text-muted);
}

.home-film-card__title {
  font-family: var(--font-serif);
  font-size: 1rem;
  font-weight: 400;
  color: var(--text-secondary);
  line-height: 1.25;
  transition: color 160ms ease;
}
.home-film-card:hover .home-film-card__title { color: var(--text-primary); }

.home-film-card__year {
  font-size: 0.72rem;
  color: var(--text-muted);
}

.home-film-card__color {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  margin-top: 0.25rem;
}

.home-film-card__color-dot {
  width: 7px; height: 7px;
  border-radius: 50%;
  flex-shrink: 0;
}

.home-film-card__color-name {
  font-size: 0.62rem;
  color: var(--text-muted);
}

/* ─── Featured colors ───────────────────────────────────────────────────────── */
.home-colors {
  padding: 5rem 0;
  border-top: 1px solid var(--surface-border);
}

.home-colors__header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 2.5rem;
}

.home-colors__heading {
  font-family: var(--font-serif);
  font-size: 1.5rem;
  font-weight: 400;
  color: var(--text-primary);
}

.home-colors__see-all {
  font-size: 0.78rem;
  color: var(--text-muted);
  transition: color 160ms ease;
}
.home-colors__see-all:hover { color: var(--text-secondary); }

.home-colors__grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 1px;
  border: 1px solid var(--surface-border);
  border-radius: 4px;
  overflow: hidden;
}

@media (min-width: 900px) {
  .home-colors__grid { grid-template-columns: repeat(3, 1fr); }
}

.home-color-block {
  position: relative;
  min-height: 240px;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 1.5rem;
  text-decoration: none;
  overflow: hidden;
}

.home-color-block__wash {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    165deg,
    var(--c) 0%,
    color-mix(in srgb, var(--c) 40%, #0D0D0F) 60%,
    #0D0D0F 100%
  );
  transition: opacity 280ms ease;
}
.home-color-block:hover .home-color-block__wash { opacity: 0.9; }

.home-color-block__content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.home-color-block__name {
  font-family: var(--font-serif);
  font-size: 1.35rem;
  font-weight: 400;
  color: var(--ct);
  line-height: 1.1;
}

.home-color-block__context {
  font-size: 0.75rem;
  color: var(--cs);
  line-height: 1.5;
}

.home-color-block__moods {
  display: flex;
  gap: 0.4rem;
  flex-wrap: wrap;
  margin-top: 0.25rem;
}

.home-color-block__mood {
  font-size: 0.58rem;
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--cs);
  padding: 0.2rem 0.5rem;
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 2px;
}

/* ─── Manifesto ──────────────────────────────────────────────────────────────── */
.home-manifesto {
  padding: 6rem 0 8rem;
  border-top: 1px solid var(--surface-border);
}

.home-manifesto__inner { max-width: var(--content-max-width); }

.home-manifesto__heading {
  font-family: var(--font-serif);
  font-size: clamp(1.75rem, 3.5vw, 2.75rem);
  font-weight: 400;
  color: var(--text-primary);
  line-height: 1.2;
  margin-bottom: 2rem;
}

.home-manifesto__body {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
  margin-bottom: 2.5rem;
}

.home-manifesto__body p {
  font-size: 1rem;
  line-height: 1.85;
  color: var(--text-secondary);
}

.home-manifesto__link {
  font-size: 0.85rem;
  color: var(--text-muted);
  transition: color 160ms ease;
}
.home-manifesto__link:hover { color: var(--text-secondary); }
</style>

<script is:inline>
(function () {
  var TMDB = 'https://image.tmdb.org/t/p/w185';

  function hexToRgba(hex, alpha) {
    var r = parseInt(hex.slice(1, 3), 16);
    var g = parseInt(hex.slice(3, 5), 16);
    var b = parseInt(hex.slice(5, 7), 16);
    return 'rgba(' + r + ',' + g + ',' + b + ',' + alpha + ')';
  }

  // Skip on mobile
  if (window.matchMedia('(max-width: 640px)').matches) return;

  var strips = document.querySelectorAll('.prism-strip');

  strips.forEach(function (strip) {
    var posters = [];
    try { posters = JSON.parse(strip.dataset.posters || '[]'); } catch (_) {}
    var hex = strip.dataset.hex || '#888';
    var injected = [];
    var leaveTimer = null;

    strip.addEventListener('mouseenter', function () {
      if (leaveTimer) { clearTimeout(leaveTimer); leaveTimer = null; }
      if (injected.length > 0 || posters.length === 0) return;

      var n = posters.length;
      var positions = n === 1 ? ['bottom'] : n === 2 ? ['30%', '70%'] : ['18%', '50%', '82%'];

      posters.forEach(function (poster, i) {
        var a = document.createElement('a');
        a.href = '/films/' + poster.slug;
        a.className = 'prism-poster';
        a.style.left = positions[i];
        a.style.transform = 'translateX(-50%) translateY(8px)';

        var img = document.createElement('img');
        img.src = TMDB + poster.path;
        img.alt = poster.title;
        img.loading = 'lazy';
        img.decoding = 'async';

        var label = document.createElement('span');
        label.className = 'prism-poster__label';
        label.textContent = poster.title;
        label.style.background = hexToRgba(hex, 0.85);

        a.appendChild(img);
        a.appendChild(label);
        strip.appendChild(a);
        injected.push(a);

        // Stagger entrance
        setTimeout(function () {
          a.classList.add('prism-poster--visible');
        }, i * 60 + 20);
      });
    });

    strip.addEventListener('mouseleave', function () {
      if (injected.length === 0) return;
      injected.forEach(function (el) {
        el.classList.remove('prism-poster--visible');
      });
      leaveTimer = setTimeout(function () {
        injected.forEach(function (el) { el.remove(); });
        injected = [];
        leaveTimer = null;
      }, 260);
    });
  });
})();
</script>
