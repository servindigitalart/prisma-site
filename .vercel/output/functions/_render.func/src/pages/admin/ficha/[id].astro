---
export const prerender = false

import BaseLayout from '../../../layouts/BaseLayout.astro'
import { requireAdmin } from '../../../lib/admin'
import { createServiceClient } from '../../../lib/db/client'

const isAdmin = await requireAdmin(Astro.locals)
if (!isAdmin) return Astro.redirect('/')

const { id } = Astro.params
if (!id) return Astro.redirect('/admin/submissions')

const db = createServiceClient()

const { data: sub } = await db
  .from('film_submissions')
  .select('*')
  .eq('id', Number(id))
  .maybeSingle()

if (!sub) return Astro.redirect('/admin/submissions')

// Parse ficha data (columns added via migration 003)
const credits: Record<string, any[]> = (sub as any).ficha_credits || {}
const bioFull: string = (sub as any).ficha_bio_full || ''
const filmmakerPhoto: string = (sub as any).ficha_filmmaker_photo || ''
const filmmakerWebsite: string = (sub as any).ficha_filmmaker_website || ''
const filmmakerInstagram: string = (sub as any).ficha_filmmaker_instagram || ''
const fichaCountries: string[] = (sub as any).ficha_countries || []
const fichaLanguages: string[] = (sub as any).ficha_languages || []
const fichaGenres: string[] = (sub as any).ficha_genres || []
const synopsisFull: string = (sub as any).ficha_synopsis_full || ''
const fichaSubmittedAt: string = (sub as any).ficha_submitted_at || ''

// Parse content type from reviewer_notes
const metaLines = (sub.reviewer_notes || '').split('\n')
const contentType = metaLines.find((l: string) => l.startsWith('Content type:'))?.replace('Content type: ', '') || ''

// Role label mapping (ficha form roles → display labels)
const roleLabels: Record<string, string> = {
  director: 'Director',
  writer: 'Writer',
  cinematographer: 'Cinematographer',
  editor: 'Editor',
  music: 'Music / Composer',
  cast: 'Cast',
}

// Ficha form roles → DB person_role enum values
const roleToDbRole: Record<string, string> = {
  director: 'director',
  writer: 'writer',
  cinematographer: 'cinematography',
  editor: 'editor',
  music: 'composer',
  cast: 'actor',
}

// Content type mapping to work_type enum
const typeMapping: Record<string, string> = {
  short: 'short',
  feature: 'film',
  series: 'series',
  music_video: 'music_video',
}
const workType = typeMapping[contentType] || 'film'

// Generate suggested slug
const suggestedSlug = sub.title
  .toLowerCase()
  .normalize('NFD')
  .replace(/[\u0300-\u036f]/g, '')
  .replace(/[^a-z0-9]+/g, '-')
  .replace(/^-+|-+$/g, '')

const hasFichaData = Object.keys(credits).length > 0 || bioFull || synopsisFull

// Fetch linked work for streaming status
let workRecord: any = null
if (sub.work_id) {
  const { data } = await db
    .from('works')
    .select('id, streaming_id, streaming_type, is_streamable')
    .eq('id', sub.work_id)
    .maybeSingle()
  workRecord = data
}
---

<BaseLayout title={`Review Ficha — ${sub.title}`}>
  <main class="admin-ficha">
    <a href="/admin/submissions" class="back-link">← Back to submissions</a>

    <header class="ficha-header">
      <h1>{sub.title}</h1>
      <div class="ficha-meta">
        <span class="meta-item">{sub.filmmaker_name}</span>
        <span class="meta-item">{sub.year || '—'}</span>
        {sub.runtime_min && <span class="meta-item">{sub.runtime_min} min</span>}
        <span class="status-badge" data-status={sub.status}>{sub.status.replace('_', ' ')}</span>
      </div>
      {fichaSubmittedAt && (
        <p class="ficha-date">Ficha submitted {new Date(fichaSubmittedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' })}</p>
      )}
    </header>

    {!hasFichaData ? (
      <div class="empty-state">
        <p>No ficha data has been submitted yet for this work.</p>
        <p>Current status: <strong>{sub.status}</strong></p>
      </div>
    ) : (
      <>
        {/* ── Filmmaker Info ── */}
        <section class="review-section">
          <h2>Filmmaker</h2>
          <div class="filmmaker-card">
            {filmmakerPhoto && (
              <img src={filmmakerPhoto} alt={sub.filmmaker_name} class="filmmaker-photo" />
            )}
            <div class="filmmaker-details">
              <h3>{sub.filmmaker_name}</h3>
              <p class="filmmaker-email">{sub.filmmaker_email}</p>
              {filmmakerWebsite && <a href={filmmakerWebsite} target="_blank" rel="noopener" class="filmmaker-link">{filmmakerWebsite}</a>}
              {filmmakerInstagram && <a href={filmmakerInstagram} target="_blank" rel="noopener" class="filmmaker-link">{filmmakerInstagram}</a>}
            </div>
          </div>
          {bioFull && (
            <div class="bio-block">
              <h4>Biography</h4>
              <p>{bioFull}</p>
            </div>
          )}
        </section>

        {/* ── Credits ── */}
        <section class="review-section">
          <h2>Credits</h2>
          {Object.keys(credits).length === 0 ? (
            <p class="empty-note">No credits submitted.</p>
          ) : (
            Object.entries(credits).map(([role, entries]) => (
              <div class="credit-group">
                <h3>{roleLabels[role] || role} <span class="db-role">→ {roleToDbRole[role] || role}</span></h3>
                <div class="credit-list">
                  {(entries as any[]).map((entry: any, i: number) => (
                    <div class="credit-card">
                      {entry.photo_url && (
                        <img src={entry.photo_url} alt={entry.name} class="credit-photo" />
                      )}
                      <div class="credit-info">
                        <span class="credit-name">{entry.name}</span>
                        {entry.bio && <p class="credit-bio">{entry.bio}</p>}
                        {entry.also && entry.also.length > 0 && (
                          <span class="credit-also">Also: {entry.also.map((r: string) => roleLabels[r] || r).join(', ')}</span>
                        )}
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            ))
          )}
        </section>

        {/* ── Work Details ── */}
        <section class="review-section">
          <h2>Work Details</h2>
          <div class="detail-grid">
            <div class="detail-item">
              <span class="detail-label">Countries</span>
              <span class="detail-value">{fichaCountries.length > 0 ? fichaCountries.join(', ') : '—'}</span>
            </div>
            <div class="detail-item">
              <span class="detail-label">Languages</span>
              <span class="detail-value">{fichaLanguages.length > 0 ? fichaLanguages.join(', ') : '—'}</span>
            </div>
            <div class="detail-item">
              <span class="detail-label">Genres</span>
              <span class="detail-value">{fichaGenres.length > 0 ? fichaGenres.join(', ') : '—'}</span>
            </div>
            <div class="detail-item detail-item--full">
              <span class="detail-label">Full Synopsis</span>
              <p class="detail-value">{synopsisFull || '—'}</p>
            </div>
          </div>
        </section>

        {/* ── Publish Section ── */}
        <section class="review-section publish-section">
          <h2>Publish to Catalog</h2>
          <p class="publish-help">
            Review all data above. Publishing will create a <code>work</code> record, <code>people</code> records (if they don't exist), and <code>work_people</code> entries. The submission status will change to <strong>published</strong>.
          </p>

          <form id="publish-form" class="publish-form">
            <div class="form-field">
              <label for="p-slug">Work slug</label>
              <div class="slug-preview">
                <span class="slug-prefix">work_</span>
                <input type="text" id="p-slug" name="slug" value={suggestedSlug} required />
              </div>
              <span class="form-hint">URL will be: /films/{suggestedSlug}</span>
            </div>

            <div class="form-field">
              <label for="p-work-type">Type</label>
              <select id="p-work-type" name="work_type">
                <option value="film" selected={workType === 'film'}>Film</option>
                <option value="short" selected={workType === 'short'}>Short</option>
                <option value="series" selected={workType === 'series'}>Series</option>
                <option value="music_video" selected={workType === 'music_video'}>Music Video</option>
              </select>
            </div>

            <h3 class="subsection-title">People Linking</h3>
            <p class="publish-help">
              For each person, you can link to an existing person record or create a new one.
              Leave the ID field blank to auto-generate from their name.
            </p>

            <div id="people-entries">
              {Object.entries(credits).flatMap(([role, entries]) =>
                (entries as any[]).map((entry: any, i: number) => {
                  const personSlug = entry.name
                    .toLowerCase()
                    .normalize('NFD')
                    .replace(/[\u0300-\u036f]/g, '')
                    .replace(/[^a-z0-9]+/g, '-')
                    .replace(/^-+|-+$/g, '')
                  const suggestedId = `person_${personSlug}`
                  const dbRole = roleToDbRole[role] || role
                  const alsoRoles = (entry.also || []).map((r: string) => roleToDbRole[r] || r)
                  return (
                    <div class="person-entry" data-role={dbRole} data-also-roles={JSON.stringify(alsoRoles)}>
                      <div class="person-entry__header">
                        <strong>{entry.name}</strong>
                        <span class="person-role-tag">{roleLabels[role] || role}</span>
                        {alsoRoles.length > 0 && (
                          <span class="person-also-tag">+ {alsoRoles.join(', ')}</span>
                        )}
                      </div>
                      <div class="person-entry__fields">
                        <div class="form-field form-field--inline">
                          <label>Person ID</label>
                          <input type="text" name={`person_id_${role}_${i}`} value={suggestedId} class="person-id-input" />
                        </div>
                        <div class="form-field form-field--inline">
                          <label>Name (as stored)</label>
                          <input type="text" name={`person_name_${role}_${i}`} value={entry.name} />
                        </div>
                      </div>
                    </div>
                  )
                })
              )}
            </div>

            <div class="publish-actions">
              <button type="submit" class="publish-btn" id="publish-btn">
                Publish to Catalog
              </button>
            </div>
          </form>

          <div class="form-message form-message--error" id="publish-error" hidden></div>
          <div class="form-message form-message--success" id="publish-success" hidden></div>
        </section>
      </>
    )}

    {/* ── Bunny Stream Upload ── */}
    {sub.work_id && (
      <section class="review-section bunny-section">
        <h2>Upload to Bunny Stream</h2>
        {workRecord?.streaming_id ? (
          <div class="bunny-status">
            <p class="bunny-linked">✓ Video linked</p>
            <div class="detail-grid">
              <div class="detail-item">
                <span class="detail-label">Video ID</span>
                <code class="detail-value">{workRecord.streaming_id}</code>
              </div>
              <div class="detail-item">
                <span class="detail-label">Streamable</span>
                <span class="detail-value">{workRecord.is_streamable ? '✓ Yes' : '✗ Not yet (upload or encoding pending)'}</span>
              </div>
            </div>
            <div class="bunny-actions">
              <a href="https://dash.bunny.net/stream" target="_blank" rel="noopener" class="action-btn action-btn--subtle">
                Open Bunny Dashboard ↗
              </a>
              {!workRecord.is_streamable && (
                <button class="action-btn action-btn--primary" id="btn-mark-streamable" data-work-id={sub.work_id}>
                  Mark as Streamable
                </button>
              )}
            </div>
          </div>
        ) : (
          <div class="bunny-create">
            <p class="publish-help">
              Create a video slot in Bunny Stream, then upload the file via the Bunny dashboard.
              Once uploaded and encoded, mark the work as streamable to enable the player on the film page.
            </p>
            <button class="action-btn action-btn--accent" id="btn-create-bunny" data-submission-id={sub.id} data-title={sub.title}>
              Create Bunny Video Slot
            </button>
            <div id="bunny-result" hidden>
              <div class="detail-grid" style="margin-top: 0.75rem;">
                <div class="detail-item detail-item--full">
                  <span class="detail-label">Video ID</span>
                  <code class="detail-value" id="bunny-video-id-display"></code>
                </div>
              </div>
              <p class="publish-help" style="margin-top: 0.75rem;">
                Video slot created. Upload the file in the Bunny dashboard, then return here to mark it as streamable.
              </p>
              <a href="https://dash.bunny.net/stream" target="_blank" rel="noopener" class="action-btn action-btn--primary">
                Open Bunny Dashboard to Upload ↗
              </a>
            </div>
          </div>
        )}
      </section>
    )}
  </main>
</BaseLayout>

<script is:inline define:vars={{ submissionId: sub.id }}>
(function() {
  var form = document.getElementById('publish-form');
  if (!form) return;

  var publishBtn = document.getElementById('publish-btn');
  var errorEl = document.getElementById('publish-error');
  var successEl = document.getElementById('publish-success');

  form.addEventListener('submit', async function(e) {
    e.preventDefault();
    errorEl.hidden = true;
    successEl.hidden = true;

    if (!confirm('Are you sure you want to publish this work to the catalog? This will create database records.')) {
      return;
    }

    publishBtn.disabled = true;
    publishBtn.textContent = 'Publishing…';

    try {
      var fd = new FormData(form);
      var slug = fd.get('slug');
      var workType = fd.get('work_type');

      // Collect people data from the form
      var personEntries = document.querySelectorAll('.person-entry');
      var people = [];
      personEntries.forEach(function(el) {
        var role = el.dataset.role;
        var alsoRoles = JSON.parse(el.dataset.alsoRoles || '[]');
        var idInput = el.querySelector('.person-id-input');
        var nameInput = el.querySelectorAll('input')[1];
        people.push({
          person_id: idInput.value.trim(),
          name: nameInput.value.trim(),
          role: role,
          also_roles: alsoRoles
        });
      });

      var res = await fetch('/api/admin/publish/' + submissionId, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ slug: slug, work_type: workType, people: people })
      });

      var result = await res.json();

      if (res.ok && result.success) {
        successEl.innerHTML = '✦ Published! <a href="/films/' + slug + '">View on site →</a>';
        successEl.hidden = false;
        publishBtn.textContent = 'Published';
        form.querySelectorAll('input, select, button').forEach(function(el) { el.disabled = true; });
      } else {
        errorEl.textContent = result.error || 'Error publishing. Check console.';
        errorEl.hidden = false;
        publishBtn.disabled = false;
        publishBtn.textContent = 'Publish to Catalog';
      }
    } catch (err) {
      errorEl.textContent = 'Network error. Check connection.';
      errorEl.hidden = false;
      publishBtn.disabled = false;
      publishBtn.textContent = 'Publish to Catalog';
    }
  });
})();

// ── Bunny Stream ──
(function() {
  // Create video slot
  var createBtn = document.getElementById('btn-create-bunny');
  if (createBtn) {
    createBtn.addEventListener('click', async function() {
      createBtn.disabled = true;
      createBtn.textContent = 'Creating…';
      try {
        var res = await fetch('/api/admin/bunny-upload', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            submission_id: Number(createBtn.dataset.submissionId),
            title: createBtn.dataset.title
          })
        });
        var data = await res.json();
        if (data.videoId) {
          document.getElementById('bunny-video-id-display').textContent = data.videoId;
          document.getElementById('bunny-result').hidden = false;
          createBtn.textContent = '✓ Slot created';
        } else {
          alert('Error: ' + (data.error || 'Unknown error'));
          createBtn.disabled = false;
          createBtn.textContent = 'Create Bunny Video Slot';
        }
      } catch (err) {
        alert('Network error');
        createBtn.disabled = false;
        createBtn.textContent = 'Create Bunny Video Slot';
      }
    });
  }

  // Mark as streamable
  var streamBtn = document.getElementById('btn-mark-streamable');
  if (streamBtn) {
    streamBtn.addEventListener('click', async function() {
      if (!confirm('Mark this work as streamable? The player will appear on the film page.')) return;
      streamBtn.disabled = true;
      streamBtn.textContent = 'Updating…';
      try {
        var res = await fetch('/api/admin/submissions/' + submissionId, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ mark_streamable: true, work_id: streamBtn.dataset.workId })
        });
        if (res.ok) {
          location.reload();
        } else {
          var data = await res.json();
          alert('Error: ' + (data.error || 'Unknown error'));
          streamBtn.disabled = false;
          streamBtn.textContent = 'Mark as Streamable';
        }
      } catch (err) {
        alert('Network error');
        streamBtn.disabled = false;
        streamBtn.textContent = 'Mark as Streamable';
      }
    });
  }
})();
</script>

<style>
  .admin-ficha {
    max-width: 800px;
    margin: 0 auto;
    padding: 3rem 1.5rem 6rem;
  }

  .back-link {
    display: inline-block;
    font-size: 0.78rem;
    color: var(--text-muted);
    text-decoration: none;
    margin-bottom: 1.5rem;
  }
  .back-link:hover { color: var(--text-secondary); }

  .ficha-header { margin-bottom: 2rem; }

  .ficha-header h1 {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    font-weight: 400;
    color: var(--text-primary);
    margin: 0 0 0.5rem;
  }

  .ficha-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .status-badge {
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    background: rgba(123, 201, 111, 0.1);
    border: 1px solid rgba(123, 201, 111, 0.3);
    color: #7BC96F;
  }

  .status-badge[data-status="ficha_received"] {
    background: rgba(123, 201, 111, 0.1);
    border-color: rgba(123, 201, 111, 0.3);
    color: #7BC96F;
  }

  .status-badge[data-status="published"] {
    background: rgba(31, 122, 92, 0.1);
    border-color: rgba(31, 122, 92, 0.3);
    color: #1F7A5C;
  }

  .ficha-date {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: 0.375rem;
  }

  .empty-state {
    text-align: center;
    padding: 4rem 1rem;
    color: var(--text-muted);
  }

  .empty-state p { margin: 0.5rem 0; font-size: 0.875rem; }

  /* Sections */
  .review-section {
    margin-bottom: 2.5rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--surface-border);
  }

  .review-section:last-child { border-bottom: none; }

  .review-section h2 {
    font-family: var(--font-serif);
    font-size: 1.1875rem;
    font-weight: 400;
    color: var(--text-primary);
    margin: 0 0 1rem;
  }

  /* Filmmaker */
  .filmmaker-card {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
  }

  .filmmaker-photo {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--surface-border);
  }

  .filmmaker-details h3 {
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-primary);
    margin: 0 0 0.25rem;
  }

  .filmmaker-email {
    font-size: 0.78rem;
    color: var(--text-muted);
    margin: 0 0 0.25rem;
  }

  .filmmaker-link {
    display: block;
    font-size: 0.75rem;
    color: #4A90D9;
    text-decoration: none;
  }
  .filmmaker-link:hover { text-decoration: underline; }

  .bio-block { margin-top: 1rem; }

  .bio-block h4 {
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--text-muted);
    margin: 0 0 0.375rem;
  }

  .bio-block p {
    font-size: 0.8125rem;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  /* Credits */
  .credit-group { margin-bottom: 1.5rem; }

  .credit-group h3 {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-primary);
    margin: 0 0 0.75rem;
  }

  .db-role {
    font-size: 0.68rem;
    font-weight: 400;
    color: var(--text-muted);
  }

  .credit-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .credit-card {
    display: flex;
    gap: 0.875rem;
    align-items: flex-start;
    background: var(--surface-card);
    border: 1px solid var(--surface-border);
    border-radius: 6px;
    padding: 0.75rem;
  }

  .credit-photo {
    width: 48px;
    height: 48px;
    border-radius: 6px;
    object-fit: cover;
    flex-shrink: 0;
  }

  .credit-name {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text-primary);
  }

  .credit-bio {
    font-size: 0.75rem;
    color: var(--text-secondary);
    line-height: 1.5;
    margin: 0.25rem 0 0;
  }

  .credit-also {
    display: block;
    font-size: 0.68rem;
    color: var(--text-accent);
    margin-top: 0.25rem;
  }

  .empty-note {
    font-size: 0.8125rem;
    color: var(--text-muted);
    font-style: italic;
  }

  /* Details */
  .detail-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  .detail-item {
    background: var(--surface-card);
    border: 1px solid var(--surface-border);
    border-radius: 6px;
    padding: 0.75rem;
  }

  .detail-item--full { grid-column: 1 / -1; }

  .detail-label {
    display: block;
    font-size: 0.68rem;
    font-weight: 500;
    color: var(--text-muted);
    margin-bottom: 0.25rem;
  }

  .detail-value {
    font-size: 0.8125rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  /* Publish */
  .publish-section {
    background: var(--surface-card);
    border: 1px solid var(--surface-border);
    border-radius: 8px;
    padding: 1.5rem;
    margin-top: 1rem;
  }

  .publish-help {
    font-size: 0.78rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0 0 1.25rem;
  }

  .publish-help code {
    background: var(--surface-elevated);
    padding: 0.125rem 0.375rem;
    border-radius: 3px;
    font-size: 0.72rem;
  }

  .publish-form { display: flex; flex-direction: column; gap: 1rem; }

  .form-field { display: flex; flex-direction: column; gap: 0.25rem; }

  .form-field label {
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--text-muted);
  }

  .form-field input,
  .form-field select {
    padding: 0.5rem 0.75rem;
    background: var(--surface-elevated);
